---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConsultationCTA from '../components/ConsultationCTA.astro';
---

<BaseLayout
  title="Mother's Rights Attorney Maryland | Child Custody for Mothers | Child Custody with a Plan"
  description="Maryland mother's rights attorneys fighting for primary custody, safe parenting arrangements, and protection from parental alienation. Empowering advocacy for Maryland mothers. Free consultation."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-teal-900 via-teal-800 to-teal-700 text-white py-20 relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gold-400 via-gold-300 to-gold-400"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-gold-400 bg-opacity-20 border border-gold-400 border-opacity-50 text-gold-300 px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
          👩‍👧‍👦 Mother's Rights
        </div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">
          Maryland Mother's Rights <span class="text-gold-400">Attorneys</span>
        </h1>
        <p class="text-teal-100 text-xl leading-relaxed mb-8">
          Empowering Maryland mothers to protect their children, secure fair custody, and build safe, stable futures — with fierce, strategic legal advocacy.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/free-consultation" class="inline-flex items-center gap-2 bg-gold-400 hover:bg-gold-500 text-white font-bold px-8 py-4 rounded-lg transition-all shadow-lg">
            Free Mother's Rights Consultation
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="tel:3012898917" class="inline-flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-teal-800 font-bold px-8 py-4 rounded-lg transition-all">
            (301) 289-8917
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Breadcrumb -->
  <div class="bg-white border-b border-gray-100 py-3">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-gray-500">
        <a href="/" class="hover:text-teal-600">Home</a>
        <span class="mx-2">/</span>
        <a href="/services" class="hover:text-teal-600">Services</a>
        <span class="mx-2">/</span>
        <span class="text-teal-700 font-medium">Mother's Rights</span>
      </nav>
    </div>
  </div>

  <!-- Main Content -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main -->
        <div class="lg:col-span-2">
          <div class="gold-bar"></div>
          <h2 class="font-serif text-3xl font-bold text-teal-800 mb-5">Empowered Mothers, Protected Children</h2>

          <div class="space-y-5 text-gray-600">
            <p class="leading-relaxed">
              Mothers facing custody disputes carry an enormous weight — the responsibility of protecting their children while navigating a legal system that can feel overwhelming and unpredictable. At Child Custody with a Plan, we are uncompromising advocates for Maryland mothers who need strong, strategic legal representation.
            </p>
            <p class="leading-relaxed">
              Whether you are seeking primary custody, dealing with an abusive or unfit co-parent, fighting parental alienation, or facing a custody modification petition, our attorneys will stand beside you every step of the way.
            </p>
            <p class="leading-relaxed">
              Maryland law has evolved significantly. Courts now emphasize both parents' involvement in children's lives — which means mothers who assume they will automatically receive primary custody can be surprised by the outcome. Having skilled, prepared legal counsel is not optional; it is essential.
            </p>
          </div>

          <!-- Services Grid -->
          <div class="mt-10">
            <h3 class="font-serif font-bold text-teal-800 text-xl mb-6">How We Advocate for Mothers</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { title: "Primary Custody Cases", desc: "Building strong cases for primary physical and legal custody based on the child's genuine best interests." },
                { title: "Safety-Focused Parenting Plans", desc: "Crafting parenting arrangements that protect children when the other parent poses risks." },
                { title: "Domestic Violence Protection", desc: "Protective orders, safety planning, and custody strategies when domestic violence is a factor." },
                { title: "Parental Alienation Response", desc: "Addressing and legally challenging tactics used to turn children against you." },
                { title: "Custody in High-Conflict Divorces", desc: "Protecting maternal rights when divorce proceedings become contentious." },
                { title: "Preventing Wrongful Relocation", desc: "Stopping an ex-partner from taking children out of state without court approval." },
                { title: "Modifications for Changed Circumstances", desc: "Seeking increased custody or reduced visitation when the co-parent's situation deteriorates." },
                { title: "Opposing Paternity Fraud", desc: "Handling disputed paternity claims that affect custody and support arrangements." },
              ].map((item) => (
                <div class="bg-teal-50 rounded-xl p-5 border border-teal-100">
                  <h4 class="font-semibold text-teal-800 text-sm mb-2">{item.title}</h4>
                  <p class="text-gray-600 text-xs leading-relaxed">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Domestic Violence Section -->
          <div class="mt-12 bg-red-50 border border-red-200 rounded-xl p-7">
            <div class="flex gap-4">
              <div class="text-3xl flex-shrink-0">🛡️</div>
              <div>
                <h3 class="font-serif font-bold text-red-800 text-xl mb-3">If You Are in an Unsafe Situation</h3>
                <p class="text-red-700 text-sm leading-relaxed mb-4">
                  If you or your children are in immediate danger, please call 911. If you are in a domestic violence situation and need to address custody, we can help you seek emergency protective orders and safety-focused custody arrangements simultaneously.
                </p>
                <div class="flex flex-wrap gap-3">
                  <a href="/emergency-custody" class="bg-red-600 hover:bg-red-700 text-white font-semibold px-5 py-2.5 rounded-lg text-sm transition-colors">Emergency Custody Options</a>
                  <a href="tel:3012898917" class="border border-red-400 text-red-700 hover:bg-red-100 font-semibold px-5 py-2.5 rounded-lg text-sm transition-colors">(301) 289-8917</a>
                </div>
              </div>
            </div>
          </div>

          <!-- FAQ -->
          <div class="mt-12">
            <h3 class="font-serif font-bold text-teal-800 text-2xl mb-6">Mother's Rights FAQ</h3>
            <div class="space-y-4">
              {[
                {
                  q: "Do mothers automatically get primary custody in Maryland?",
                  a: "No. Maryland law does not give either parent a presumption of custody based on gender. Courts apply the 'best interests of the child' standard equally to both parents. This means mothers — like fathers — must present a compelling case for the custody arrangement they seek.",
                },
                {
                  q: "What if my child's father has a history of abuse?",
                  a: "Documented domestic violence is one of the most significant factors in Maryland custody determinations. Courts take a very protective view toward children's safety. We can help you obtain protective orders, present evidence of abuse, and build a custody arrangement that prioritizes your child's safety.",
                },
                {
                  q: "Can the father take my kids out of Maryland without my permission?",
                  a: "If there is no custody order in place, this can create an emergency situation. If a custody order exists, taking children out of state in violation of it can constitute parental abduction. We can seek emergency custody orders and file with authorities to protect your children.",
                },
                {
                  q: "What is parental alienation and how do I handle it?",
                  a: "Parental alienation occurs when one parent deliberately undermines the child's relationship with the other parent. As a mother, you may face alienation attempts, or in some cases, you may be accused of alienation yourself. We help identify, document, and legally address alienation behaviors in court.",
                },
                {
                  q: "Can I relocate with my children after a custody order is issued?",
                  a: "Relocating with children subject to a custody order typically requires either the other parent's written consent or a court order. Maryland courts evaluate relocation requests carefully, weighing the reasons for the move against the impact on the child's relationship with the other parent.",
                },
              ].map((faq) => (
                <div class="faq-item">
                  <div class="p-5 bg-teal-50 border-l-4 border-teal-600">
                    <h4 class="font-semibold text-teal-800 text-sm mb-2">{faq.q}</h4>
                    <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-teal-900 text-white rounded-2xl p-7 sticky top-24">
            <h3 class="font-serif font-bold text-xl mb-3">You Deserve Fierce Advocacy</h3>
            <p class="text-teal-200 text-sm mb-5">Maryland mothers trust us to protect their children and their parental rights. Start with a free consultation.</p>
            <a href="/free-consultation" class="btn-primary w-full justify-center mb-3 block text-center">Free Consultation</a>
            <a href="tel:3012898917" class="block text-center border border-teal-600 text-white hover:bg-teal-800 py-3 rounded-lg text-sm font-semibold transition-colors">(301) 289-8917</a>
          </div>

          <div class="bg-white border border-gray-200 rounded-xl p-6">
            <h4 class="font-semibold text-teal-800 mb-4">Our Commitment to Mothers</h4>
            <ul class="space-y-3">
              {[
                "Confidential, non-judgmental consultation",
                "Safety planning when needed",
                "Empathy combined with strategy",
                "Extended hours for working mothers",
                "Community-centered representation",
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <div class="w-5 h-5 bg-teal-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-3 h-3 text-teal-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-white border border-gray-200 rounded-xl p-6">
            <h4 class="font-semibold text-teal-800 mb-4">Related Services</h4>
            <ul class="space-y-2">
              {[
                { label: "Emergency Custody", href: "/emergency-custody" },
                { label: "Custody Modifications", href: "/custody-modifications" },
                { label: "Visitation Rights", href: "/visitation-rights" },
                { label: "All Services", href: "/services" },
              ].map((link) => (
                <li>
                  <a href={link.href} class="flex items-center gap-2 text-teal-600 hover:text-teal-800 text-sm transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ConsultationCTA heading="Stand Up for Your Children" subtext="You deserve an attorney who is as committed to your children's safety and wellbeing as you are. Our Maryland mother's rights attorneys are ready to fight for you." />
</BaseLayout>
