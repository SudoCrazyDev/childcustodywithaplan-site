---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const resources = [
  {
    category: 'Child Custody',
    title: 'The Maryland Parent\'s Complete Guide to Child Custody',
    desc: 'Everything Maryland parents need to know about legal and physical custody, parenting plans, the best interests standard, and how to prepare for custody proceedings.',
    href: '#',
    readTime: '12 min read',
    icon: '👨‍👩‍👧',
  },
  {
    category: 'Child Custody',
    title: '50/50 Custody in Maryland: When Courts Award Equal Shared Custody',
    desc: 'Maryland courts don\'t automatically order 50/50 custody — but they will when the evidence supports it. Here\'s what you need to know about equal shared custody in Maryland.',
    href: '#',
    readTime: '8 min read',
    icon: '⚖️',
  },
  {
    category: 'Custody Modification',
    title: 'How to Modify a Child Custody Order in Maryland: A Step-by-Step Guide',
    desc: 'Maryland requires a material change in circumstances to modify a custody order. This guide explains the legal standard, common grounds for modification, and the court process.',
    href: '#',
    readTime: '10 min read',
    icon: '📋',
  },
  {
    category: 'Divorce',
    title: 'Maryland Divorce Timeline: How Long Does Divorce Take in Maryland?',
    desc: 'From filing to final decree — a realistic look at how long Maryland divorces take, what factors affect the timeline, and how to keep your case moving forward.',
    href: '#',
    readTime: '7 min read',
    icon: '📅',
  },
  {
    category: 'Asset Division',
    title: 'Marital Property vs. Separate Property in Maryland Divorce',
    desc: 'Understanding the distinction between marital and non-marital property is the foundation of asset division in Maryland. Here\'s what qualifies as each under Maryland law.',
    href: '#',
    readTime: '9 min read',
    icon: '🏠',
  },
  {
    category: 'Spousal Support',
    title: 'Maryland Alimony Guide: Types of Spousal Support and How They\'re Calculated',
    desc: 'Maryland recognizes pendente lite, rehabilitative, and indefinite alimony. This guide explains each type, the factors courts consider, and what to expect in your alimony case.',
    href: '#',
    readTime: '11 min read',
    icon: '💰',
  },
  {
    category: 'High Net Worth',
    title: 'Protecting Your Business in a Maryland Divorce',
    desc: 'If you own a business, your divorce will be more complex. This guide covers business valuation, the marital/non-marital classification, buyout strategies, and how to protect your business interests.',
    href: '#',
    readTime: '13 min read',
    icon: '🏢',
  },
  {
    category: 'Child Support',
    title: 'Maryland Child Support Guidelines: How Support is Calculated',
    desc: 'Maryland uses an Income Shares model to calculate child support. This guide explains the guidelines, how income is defined, what expenses are included, and how to request a modification.',
    href: '#',
    readTime: '9 min read',
    icon: '👶',
  },
  {
    category: 'Safety',
    title: 'Domestic Violence Resources for Maryland Survivors',
    desc: 'If you are experiencing domestic violence, you have legal options. This resource provides information on Maryland protective orders, emergency custody provisions, and local support resources.',
    href: '#',
    readTime: '6 min read',
    icon: '🛡️',
  },
];

const checklists = [
  {
    title: 'Free Maryland Divorce Checklist',
    desc: 'A comprehensive checklist of documents to gather, decisions to make, and steps to take as you prepare for your Maryland divorce proceeding.',
    icon: '📝',
    color: 'bg-teal-500',
  },
  {
    title: 'Free Child Custody Plan Checklist',
    desc: 'Everything you need to consider when developing a comprehensive parenting plan for your Maryland child custody case.',
    icon: '👨‍👩‍👧',
    color: 'bg-gold-400',
  },
  {
    title: 'Maryland Child Support Guide & Checklist',
    desc: 'Understand how Maryland calculates child support and prepare the documentation you\'ll need for your child support proceeding.',
    icon: '👶',
    color: 'bg-teal-600',
  },
  {
    title: 'Spousal Support Guide & Checklist',
    desc: 'A practical guide to Maryland alimony — including the factors courts consider and the evidence you need to support your case.',
    icon: '💰',
    color: 'bg-gold-500',
  },
  {
    title: 'Maryland Protective Order Guide',
    desc: 'Step-by-step guide to obtaining a protective order in Maryland, including what qualifies and what the process involves.',
    icon: '🛡️',
    color: 'bg-teal-500',
  },
];
---

<BaseLayout
  title="Family Law Resources & Blog | Maryland Divorce & Custody Guides | Child Custody with a Plan"
  description="Free Maryland family law resources from Child Custody with a Plan: guides, checklists, and expert articles on child custody, divorce, spousal support, asset division, and more."
>
  <!-- Hero -->
  <section class="teal-gradient text-white py-16 md:py-24 relative overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold-400 rounded-full opacity-10 blur-3xl"></div>
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <div class="max-w-3xl">
        <p class="text-gold-400 font-semibold text-sm uppercase tracking-widest mb-3">Resources & Education</p>
        <h1 class="font-serif font-bold text-4xl md:text-5xl text-white leading-tight mb-6">
          Maryland Family Law Resources, Guides & Blog
        </h1>
        <p class="text-teal-100 text-xl leading-relaxed">
          Free educational resources from the attorneys at Child Custody with a Plan — designed to help Maryland families navigate divorce, child custody, and family law with confidence.
        </p>
      </div>
    </div>
  </section>

  <!-- Free Checklists -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-gold-500 font-semibold text-sm uppercase tracking-widest mb-3">Free Downloads</p>
        <h2 class="section-heading">Free Guides & Checklists</h2>
        <p class="section-subheading">
          Download our free Maryland family law guides and checklists — created by our attorneys to help you prepare for every stage of your case.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {checklists.map((c) => (
          <div class="bg-white rounded-xl shadow-md hover:shadow-xl transition-shadow p-6 border border-gray-100">
            <div class={`w-14 h-14 ${c.color} rounded-xl flex items-center justify-center text-2xl mb-4 shadow-md`}>
              {c.icon}
            </div>
            <h3 class="font-serif font-bold text-teal-700 text-lg mb-2">{c.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{c.desc}</p>
            <a href="/free-consultation" class="text-teal-600 font-semibold text-sm hover:text-teal-700 flex items-center gap-1">
              Request Free Download
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Articles -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-gold-500 font-semibold text-sm uppercase tracking-widest mb-3">Educational Content</p>
        <h2 class="section-heading">Articles & Guides</h2>
        <p class="section-subheading">
          In-depth articles on Maryland family law topics — written by our attorneys to give you the knowledge you need to make informed decisions.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {resources.map((r) => (
          <article class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 overflow-hidden group">
            <div class="teal-gradient p-6 text-center">
              <span class="text-4xl">{r.icon}</span>
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between mb-3">
                <span class="bg-teal-100 text-teal-700 text-xs font-semibold px-3 py-1 rounded-full">{r.category}</span>
                <span class="text-gray-400 text-xs">{r.readTime}</span>
              </div>
              <h3 class="font-serif font-bold text-teal-700 text-lg mb-3 group-hover:text-teal-500 transition-colors leading-snug">{r.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{r.desc}</p>
              <a href="/free-consultation" class="text-gold-500 font-semibold text-sm hover:text-gold-600 flex items-center gap-1 group-hover:gap-2 transition-all">
                Read Article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 bg-teal-50">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-gold-500 font-semibold text-sm uppercase tracking-widest mb-3">Common Questions</p>
        <h2 class="section-heading">Frequently Asked Questions</h2>
      </div>
      <div class="space-y-4">
        {[
          {
            q: 'How long does it take to get a custody order in Maryland?',
            a: 'The timeline varies significantly. Uncontested matters or consent agreements can be finalized in weeks. Contested custody cases may take 6–18 months or longer, depending on court scheduling and case complexity.',
          },
          {
            q: 'Does Maryland favor mothers in custody cases?',
            a: 'No. Maryland law prohibits courts from considering gender in custody determinations. Both parents are evaluated equally based on the best interests of the child standard.',
          },
          {
            q: 'Can I modify a custody order if my ex moved without telling me?',
            a: 'Yes. Unauthorized relocation by a custodial parent can constitute a material change in circumstances supporting a modification petition. Courts take parental relocation without notice very seriously.',
          },
          {
            q: 'What is the difference between legal and physical custody?',
            a: 'Legal custody is the right to make major decisions about your child\'s life (education, healthcare, religion). Physical custody is where the child lives and who provides day-to-day care.',
          },
          {
            q: 'How is spousal support calculated in Maryland?',
            a: 'Maryland has no fixed formula for spousal support. Courts weigh multiple statutory factors including the length of marriage, each spouse\'s earning capacity, contributions to the family, and the established standard of living.',
          },
          {
            q: 'What happens to our house in a Maryland divorce?',
            a: 'The marital home is typically marital property subject to equitable distribution. Options include one spouse buying out the other, selling and dividing proceeds, or a deferred sale arrangement. Our attorneys help you evaluate the best strategy.',
          },
        ].map((faq) => (
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-teal-700 hover:text-teal-500 transition-colors list-none">
              <span>{faq.q}</span>
              <svg class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
