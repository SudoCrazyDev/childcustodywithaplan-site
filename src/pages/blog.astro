---
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = [
  {
    slug: "maryland-divorce-law-changes-2023",
    title: "Maryland's 2023 Divorce Law Changes: What You Need to Know",
    date: "March 15, 2024",
    category: "Divorce Law",
    excerpt: "Maryland dramatically simplified divorce in October 2023, eliminating the old limited divorce and creating new no-fault grounds. Here's what changed and how it affects your case.",
    readTime: "5 min read"
  },
  {
    slug: "equitable-distribution-maryland",
    title: "Equitable Distribution in Maryland: Fair Doesn't Mean Equal",
    date: "February 28, 2024",
    category: "Asset Division",
    excerpt: "Maryland divides marital property equitably — not equally. Understanding the factors courts consider can make a major difference in your divorce outcome.",
    readTime: "7 min read"
  },
  {
    slug: "child-custody-best-interests",
    title: "How Maryland Courts Determine Child Custody: The Best Interests Standard Explained",
    date: "February 10, 2024",
    category: "Child Custody",
    excerpt: "Maryland judges evaluate a comprehensive list of factors when deciding custody. Here's what they look for and how to present your strongest case.",
    readTime: "8 min read"
  },
  {
    slug: "high-asset-divorce-mistakes",
    title: "5 Costly Mistakes in High-Asset Maryland Divorces (And How to Avoid Them)",
    date: "January 22, 2024",
    category: "High-Net-Worth Divorce",
    excerpt: "When significant assets are at stake, even small legal missteps can cost you hundreds of thousands of dollars. Our attorneys share the most common mistakes they see — and how to avoid them.",
    readTime: "9 min read"
  },
  {
    slug: "spousal-support-maryland-guide",
    title: "The Complete Guide to Spousal Support in Maryland",
    date: "January 8, 2024",
    category: "Spousal Support",
    excerpt: "From pendente lite to indefinite alimony — everything you need to know about how Maryland courts determine if spousal support is awarded and how much.",
    readTime: "10 min read"
  },
  {
    slug: "business-valuation-divorce",
    title: "Business Valuation in Maryland Divorce: What Business Owners Must Know",
    date: "December 18, 2023",
    category: "Business Divorce",
    excerpt: "If you or your spouse owns a business, it may be the most valuable — and most contested — asset in your divorce. Here's how business valuation works in Maryland.",
    readTime: "8 min read"
  },
  {
    slug: "custody-modification-material-change",
    title: "When Can You Modify a Custody Order in Maryland?",
    date: "December 5, 2023",
    category: "Child Custody",
    excerpt: "Life changes — and sometimes custody orders need to change with it. Learn what constitutes a 'material change in circumstances' under Maryland law.",
    readTime: "6 min read"
  },
  {
    slug: "divorce-for-doctors-maryland",
    title: "Divorce for Maryland Physicians: Protecting Your Practice and Income",
    date: "November 20, 2023",
    category: "Professional Divorce",
    excerpt: "Medical professionals face unique divorce challenges: practice valuation, professional goodwill, complex income structures. Here's what every Maryland physician needs to know.",
    readTime: "7 min read"
  },
  {
    slug: "what-to-expect-first-consultation",
    title: "What to Expect at Your First Divorce Attorney Consultation in Maryland",
    date: "November 7, 2023",
    category: "Getting Started",
    excerpt: "Your first meeting with a divorce attorney can feel overwhelming. We walk you through exactly what to bring, what to ask, and what to expect.",
    readTime: "5 min read"
  }
];

const categories = ["All", "Divorce Law", "Asset Division", "Child Custody", "High-Net-Worth Divorce", "Spousal Support", "Business Divorce", "Professional Divorce", "Getting Started"];
---

<BaseLayout
  title="Maryland Divorce & Family Law Blog | Divorce With A Plan"
  description="Expert insights on Maryland divorce law, child custody, asset division, spousal support, and high-asset divorce from the attorneys at Divorce With A Plan in Rockville, MD."
  ogTitle="Maryland Divorce & Family Law Blog | Divorce With A Plan"
  ogDescription="Practical legal guidance on Maryland divorce and family law from experienced attorneys. Read articles on custody, asset division, spousal support, and more."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 to-slate-700 text-white py-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-amber-400 uppercase tracking-widest text-sm font-semibold mb-3">Maryland Family Law Insights</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Divorce & Family Law Blog</h1>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto">
        Practical legal guidance from Maryland's experienced divorce attorneys. Stay informed about the laws that affect your case.
      </p>
    </div>
  </section>

  <!-- Categories -->
  <section class="bg-white border-b border-slate-200 py-4 px-4 sticky top-0 z-10">
    <div class="max-w-5xl mx-auto">
      <div class="flex gap-2 overflow-x-auto pb-1 scrollbar-hide">
        {categories.map(cat => (
          <span class={`flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium cursor-pointer transition-colors ${cat === 'All' ? 'bg-amber-500 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}`}>
            {cat}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="py-16 px-4 bg-slate-50">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <article class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition-shadow">
            <div class="p-6">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-amber-600 bg-amber-50 px-3 py-1 rounded-full">{post.category}</span>
                <span class="text-xs text-slate-400">{post.readTime}</span>
              </div>
              <h2 class="text-lg font-bold text-slate-900 mb-3 leading-snug hover:text-amber-600 transition-colors">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="text-slate-600 text-sm mb-4 leading-relaxed">{post.excerpt}</p>
              <div class="flex items-center justify-between">
                <span class="text-xs text-slate-400">{post.date}</span>
                <a href={`/blog/${post.slug}`} class="text-amber-600 hover:text-amber-700 text-sm font-semibold">
                  Read More →
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter / CTA -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="bg-slate-900 rounded-2xl p-8 md:p-12 text-center text-white">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">Have Questions About Your Specific Situation?</h2>
        <p class="text-slate-300 mb-8">
          Our blog covers general Maryland family law topics, but every case is unique. Schedule a free consultation to discuss your specific circumstances with one of our attorneys.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/free-consultation" class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 px-8 rounded-lg transition-colors">
            Book Free Consultation
          </a>
          <a href="tel:2402693592" class="border-2 border-white text-white hover:bg-white hover:text-slate-900 font-bold py-3 px-8 rounded-lg transition-colors">
            Call (240) 269-3592
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Topics -->
  <section class="py-12 px-4 bg-slate-50 border-t border-slate-200">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-xl font-bold text-slate-900 mb-6 text-center">Explore by Practice Area</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          { label: "Divorce", href: "/divorce" },
          { label: "Asset Division", href: "/asset-division" },
          { label: "Child Custody", href: "/child-custody" },
          { label: "Child Custody Modification", href: "/child-custody-modification" },
          { label: "Spousal Support", href: "/spousal-support" },
          { label: "High-Net-Worth Divorce", href: "/high-net-worth-divorce" },
          { label: "Business Divorce", href: "/divorces-involving-businesses" },
          { label: "Divorce for Professionals", href: "/divorce-lawyer-for-professionals" }
        ].map(topic => (
          <a href={topic.href} class="bg-white border border-slate-200 text-slate-700 hover:border-amber-400 hover:text-amber-600 px-4 py-2 rounded-full text-sm transition-colors shadow-sm">
            {topic.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
