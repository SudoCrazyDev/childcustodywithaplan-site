---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';

const posts = [
  {
    title: 'Understanding the Best Interests of the Child Standard in Maryland',
    date: 'January 15, 2025',
    category: 'Child Custody',
    description: 'Maryland courts use the "best interests of the child" standard to determine all custody matters. Learn what factors judges consider and how to position your case effectively.',
    href: '#',
    readTime: '6 min read',
  },
  {
    title: 'Equitable Distribution in Maryland: What Does "Fair" Really Mean?',
    date: 'January 8, 2025',
    category: 'Asset Division',
    description: 'Maryland is an equitable distribution state — but "equitable" doesn\'t always mean equal. This guide explains how courts divide marital property and what you can do to protect your financial interests.',
    href: '#',
    readTime: '7 min read',
  },
  {
    title: 'How to Modify a Child Custody Order in Maryland',
    date: 'December 22, 2024',
    category: 'Custody Modification',
    description: 'Life changes — and your custody order may need to as well. Learn about the material change in circumstances standard and when courts will consider modifying existing custody arrangements.',
    href: '#',
    readTime: '5 min read',
  },
  {
    title: 'The Three Types of Alimony in Maryland Divorce',
    date: 'December 10, 2024',
    category: 'Spousal Support',
    description: 'Pendente lite, rehabilitative, and indefinite alimony — each serves a different purpose in Maryland divorce law. This guide breaks down the differences and the factors courts consider in awarding support.',
    href: '#',
    readTime: '6 min read',
  },
  {
    title: 'High Net Worth Divorce in Maryland: 5 Critical Issues to Address',
    date: 'November 28, 2024',
    category: 'High Net Worth Divorce',
    description: 'Complex asset divorce requires specialized expertise. From hidden assets to business valuation and prenuptial agreement challenges, here\'s what high-net-worth divorcing spouses in Maryland need to know.',
    href: '#',
    readTime: '8 min read',
  },
  {
    title: 'Joint vs. Sole Custody: Making the Right Choice for Your Maryland Family',
    date: 'November 15, 2024',
    category: 'Child Custody',
    description: 'Understanding the difference between joint and sole custody — both legal and physical — is essential for any Maryland parent navigating a custody dispute. This guide explains your options.',
    href: '#',
    readTime: '5 min read',
  },
  {
    title: 'Protecting Your Business in a Maryland Divorce',
    date: 'November 5, 2024',
    category: 'Business Divorce',
    description: 'If you own a business and are facing divorce, understanding how Maryland treats business interests in equitable distribution is critical. Learn how to protect what you\'ve built.',
    href: '#',
    readTime: '7 min read',
  },
  {
    title: 'What Maryland Professionals Need to Know Before Filing for Divorce',
    date: 'October 25, 2024',
    category: 'Professional Divorce',
    description: 'Doctors, executives, and attorneys face unique challenges in divorce — from stock options and partnership interests to reputation management and custody schedules. Here\'s your guide.',
    href: '#',
    readTime: '7 min read',
  },
  {
    title: 'Creating an Effective Parenting Plan: A Maryland Parent\'s Guide',
    date: 'October 10, 2024',
    category: 'Child Custody',
    description: 'A comprehensive parenting plan is the foundation of successful co-parenting. Learn what to include in your Maryland parenting plan to minimize conflict and serve your children\'s best interests.',
    href: '#',
    readTime: '6 min read',
  },
];

const categories = ['All', 'Child Custody', 'Divorce', 'Asset Division', 'Spousal Support', 'High Net Worth Divorce', 'Custody Modification', 'Business Divorce', 'Professional Divorce'];
---

<BaseLayout
  title="Family Law Blog | Maryland Child Custody & Divorce Resources | Child Custody with a Plan"
  description="Maryland family law insights, child custody guides, and divorce resources from the attorneys at Child Custody with a Plan. Serving Rockville, Baltimore & statewide."
>
  <Hero
    variant="interior"
    subtitle="Family Law Resources"
    title="Maryland Family Law Blog"
    description="Expert insights, legal guides, and practical resources for Maryland families navigating custody, divorce, and family law matters."
    ctaText="Free Consultation"
    ctaHref="/free-consultation"
  />

  <!-- Blog content -->
  <section class="bg-offwhite py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Posts -->
        <div class="lg:col-span-2">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-serif font-bold text-charcoal">Recent Articles</h2>
            <span class="text-gray-500 text-sm">{posts.length} articles</span>
          </div>

          <div class="space-y-6">
            {posts.map((post) => (
              <article class="bg-white rounded-2xl p-6 shadow-card hover:shadow-card-hover transition-shadow">
                <div class="flex items-center gap-3 mb-3">
                  <span class="bg-teal-50 text-teal text-xs font-semibold px-3 py-1 rounded-full">{post.category}</span>
                  <span class="text-gray-400 text-xs">{post.date}</span>
                  <span class="text-gray-400 text-xs">· {post.readTime}</span>
                </div>
                <h3 class="text-xl font-serif font-bold text-charcoal mb-2 hover:text-teal transition-colors">
                  <a href={post.href}>{post.title}</a>
                </h3>
                <p class="text-gray-600 text-sm leading-relaxed mb-4">{post.description}</p>
                <a href={post.href} class="text-teal font-semibold text-sm flex items-center gap-1 hover:text-teal-600 transition-colors">
                  Read Article
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </article>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <!-- Categories -->
          <div class="bg-white rounded-2xl p-6 shadow-card">
            <h3 class="text-lg font-serif font-bold text-teal mb-4">Categories</h3>
            <ul class="space-y-2">
              {categories.map((cat) => (
                <li>
                  <a href="#" class={`text-sm flex items-center justify-between py-1.5 px-3 rounded-lg transition-colors ${cat === 'All' ? 'bg-teal text-white' : 'text-gray-600 hover:bg-teal-50 hover:text-teal'}`}>
                    <span>{cat}</span>
                    {cat === 'All' && <span class="text-xs opacity-80">{posts.length}</span>}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- CTA -->
          <div class="bg-teal rounded-2xl p-6 text-white">
            <h3 class="text-xl font-serif font-bold mb-2">Have Questions?</h3>
            <p class="text-teal-100 text-sm mb-5 leading-relaxed">
              Our attorneys are ready to provide personalized guidance for your specific situation.
            </p>
            <a href="/free-consultation" class="block text-center bg-gold text-white font-semibold py-3 rounded-lg hover:bg-gold-500 transition-colors text-sm mb-3">
              Free Consultation
            </a>
            <a href="tel:+13012898917" class="flex items-center justify-center gap-2 text-teal-100 hover:text-white text-sm transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
              (301) 289-8917
            </a>
          </div>

          <!-- Practice Areas quick links -->
          <div class="bg-white rounded-2xl p-6 shadow-card">
            <h3 class="text-lg font-serif font-bold text-teal mb-4">Practice Areas</h3>
            <ul class="space-y-2">
              {[
                { label: 'Child Custody', href: '/child-custody' },
                { label: 'Divorce', href: '/divorce' },
                { label: 'Asset Division', href: '/asset-division' },
                { label: 'Spousal Support', href: '/spousal-support' },
                { label: 'High Net Worth Divorce', href: '/high-net-worth-divorce' },
                { label: 'Custody Modification', href: '/child-custody-modification' },
              ].map((link) => (
                <li>
                  <a href={link.href} class="flex items-center gap-2 text-sm text-gray-600 hover:text-teal transition-colors py-1">
                    <svg class="w-3 h-3 text-gold" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <CTASection
    title="Need Legal Guidance? We're Here to Help."
    description="The information in our blog is general — your situation is unique. Schedule a free consultation to get personalized guidance from one of our Maryland family law attorneys."
  />
</BaseLayout>
