---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="About Our Firm | Child Custody with a Plan | Maryland Family Law"
  description="Learn about Child Custody with a Plan — a Maryland family law firm established in 2013. Our dedicated team of attorneys provides strategic, compassionate representation in child custody, divorce, and family law throughout Maryland."
>

  <Hero
    subtitle="About Our Firm"
    title="A Law Firm Built Around Your Family's Future"
    description="Founded in 2013, our firm has been helping Maryland families navigate the complexities of child custody, divorce, and family law — with strategy, clarity, and compassion."
    primaryCta={{ label: "Schedule a Consultation", href: "/contact" }}
    secondaryCta={{ label: "Meet Our Attorneys", href: "/attorneys" }}
    variant="compact"
  />

  <!-- Our Story -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-3">Our Story</p>
          <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-6">Established in 2013 with a Clear Mission</h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>
              Our founding team established this firm in 2013 with a singular belief: that people facing family law challenges deserve more than reactive legal advice. They deserve a plan.
            </p>
            <p>
              What began as a focused Maryland family law practice has grown into a trusted firm serving clients throughout Montgomery County, Howard County, Baltimore, and across the state — handling everything from contested custody disputes to complex high-asset divorces.
            </p>
            <p>
              Our approach has always been rooted in the idea that the best legal outcomes come from thorough preparation, strategic thinking, and genuine advocacy. We don't just handle your case — we build a comprehensive plan designed around your goals, your children's wellbeing, and your future.
            </p>
            <p>
              Today, our firm operates from offices in Rockville and Baltimore, serving clients throughout Maryland and Washington D.C. with the same commitment to excellence and compassion that has defined us since day one.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-5">
          {[
            { number: '2013', label: 'Year Founded' },
            { number: '100%', label: 'Family Law Focus' },
            { number: '2', label: 'Maryland Offices' },
            { number: '5+', label: 'Counties Served' },
          ].map(stat => (
            <div class="bg-[#0D6E6E] text-white rounded-2xl p-8 text-center">
              <div class="text-4xl font-serif font-bold text-[#D4A843] mb-2">{stat.number}</div>
              <div class="text-white/80 text-sm font-medium">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Our Mission & Values -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">What Drives Us</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">Our Mission & Core Values</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          Every decision we make — from how we take calls to how we argue in court — flows from these foundational principles.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            icon: '🎯',
            title: 'Mission',
            description: 'To provide every client with a clear, strategic legal plan that protects their rights, their children\'s wellbeing, and their future — delivered with honesty and genuine care.',
          },
          {
            icon: '⚖️',
            title: 'Values',
            description: 'Integrity, strategic advocacy, compassionate counsel, and an unwavering commitment to the families we serve. We believe every client deserves to feel heard, informed, and empowered.',
          },
          {
            icon: '🌟',
            title: 'Vision',
            description: 'To be Maryland\'s most trusted family law firm — known not just for winning cases, but for transforming how clients experience the legal process during life\'s hardest moments.',
          },
        ].map(item => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 text-center">
            <div class="text-5xl mb-5">{item.icon}</div>
            <h3 class="text-xl font-serif font-bold text-[#0D6E6E] mb-3">{item.title}</h3>
            <p class="text-gray-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The PROMISE Framework -->
  <section class="py-20 bg-[#0D6E6E]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-3">Our Methodology</p>
        <h2 class="text-4xl font-serif font-bold text-white mb-5">The PROMISE Framework</h2>
        <p class="text-white/80 max-w-2xl mx-auto text-lg leading-relaxed">
          We designed the PROMISE Framework to give every client a structured, transparent roadmap — so you always know where you stand and where you're headed.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { letter: 'P', word: 'Protect', description: 'We begin by understanding your most urgent priorities and taking immediate steps to protect your rights and your children\'s stability.' },
          { letter: 'R', word: 'Represent', description: 'Our attorneys provide fierce, skilled representation in negotiations, mediation, and courtroom proceedings.' },
          { letter: 'O', word: 'Organize', description: 'We gather, organize, and analyze all evidence, financial records, and documentation to build the strongest possible case.' },
          { letter: 'M', word: 'Mediate', description: 'Where appropriate, we pursue mediation and settlement options that achieve your goals while minimizing conflict and cost.' },
          { letter: 'I', word: 'Implement', description: 'We execute your legal strategy with precision — filing, arguing, negotiating, and advocating at every critical juncture.' },
          { letter: 'S', word: 'Support', description: 'Throughout the process, our team provides consistent communication, emotional support, and honest updates on your case.' },
          { letter: 'E', word: 'Empower', description: 'We close every case by ensuring our clients understand their rights, their orders, and how to move forward with confidence.' },
        ].map(step => (
          <div class="bg-white/10 border border-white/20 rounded-xl p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-[#D4A843] rounded-lg flex items-center justify-center flex-shrink-0">
                <span class="text-white font-bold font-serif text-lg">{step.letter}</span>
              </div>
              <h3 class="text-white font-serif font-bold text-lg">{step.word}</h3>
            </div>
            <p class="text-white/70 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/process" class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded hover:bg-white hover:text-[#0D6E6E] transition-colors">
          See Our Full Process
        </a>
      </div>
    </div>
  </section>

  <!-- Our Team Preview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">The Team</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">Attorneys Who Care</h2>
        <p class="text-gray-600 max-w-xl mx-auto text-lg">
          Our attorneys bring diverse experience, deep Maryland knowledge, and a shared dedication to our clients.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        {[
          {
            name: 'Monique Nettleford-Bruce',
            title: 'Associate Attorney',
            initials: 'MN',
            tags: ['Maryland', 'Virginia', 'American University WCL'],
          },
          {
            name: 'Aysia Stockton',
            title: 'Associate Attorney',
            initials: 'AS',
            tags: ['Maryland', 'Washington D.C.', 'Appalachian School of Law'],
          },
        ].map(attorney => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-7 flex flex-col items-center text-center">
            <div class="w-20 h-20 rounded-full bg-[#0D6E6E] flex items-center justify-center mb-5">
              <span class="text-white font-serif font-bold text-2xl">{attorney.initials}</span>
            </div>
            <h3 class="text-xl font-serif font-bold text-[#0D6E6E] mb-1">{attorney.name}</h3>
            <p class="text-[#D4A843] font-semibold text-sm mb-4">{attorney.title}</p>
            <div class="flex flex-wrap justify-center gap-2">
              {attorney.tags.map(tag => (
                <span class="bg-[#0D6E6E]/10 text-[#0D6E6E] text-xs px-3 py-1 rounded-full font-medium">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/attorneys" class="inline-block bg-[#D4A843] text-white font-semibold px-8 py-3 rounded hover:bg-[#B8902E] transition-colors">
          Meet Our Full Team
        </a>
      </div>
    </div>
  </section>

  <!-- Office Locations -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">Find Us</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">Our Offices</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
          <div class="w-12 h-12 bg-[#0D6E6E] rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-serif font-bold text-[#0D6E6E] mb-3">Rockville Office</h3>
          <p class="text-gray-600 mb-4">100 Park Ave, Suite 205<br/>Rockville, MD 20850</p>
          <a href="tel:2402693592" class="text-[#D4A843] font-semibold hover:text-[#B8902E] transition-colors">(240) 269-3592</a>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
          <div class="w-12 h-12 bg-[#0D6E6E] rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-serif font-bold text-[#0D6E6E] mb-3">Baltimore Office</h3>
          <p class="text-gray-600 mb-4">Baltimore, MD<br/>Serving Baltimore City &amp; County</p>
          <a href="tel:2403267712" class="text-[#D4A843] font-semibold hover:text-[#B8902E] transition-colors">(240) 326-7712</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[#D4A843]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-serif font-bold text-white mb-4">Let's Talk About Your Case</h2>
      <p class="text-white/90 text-lg mb-8">Your first consultation is complimentary. We're ready to listen and ready to help.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-[#D4A843] font-bold px-10 py-4 rounded hover:bg-gray-100 transition-colors">
          Book Free Consultation
        </a>
        <a href="/attorneys" class="border-2 border-white text-white font-semibold px-10 py-4 rounded hover:bg-white hover:text-[#D4A843] transition-colors">
          Meet Our Attorneys
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
