---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';

const values = [
  {
    title: 'Strategy Over Reaction',
    desc: 'We never play defense. Every step of your case is guided by a clear, forward-thinking plan designed to achieve your goals.',
    icon: '♟️',
  },
  {
    title: 'Empathy in Every Interaction',
    desc: 'Family law is deeply personal. We listen first, advocate always, and treat every client with dignity and compassion.',
    icon: '❤️',
  },
  {
    title: 'Transparency & Trust',
    desc: 'No surprises. We communicate clearly, explain every option, and ensure you\'re never left wondering what comes next.',
    icon: '🔍',
  },
  {
    title: 'Community Commitment',
    desc: 'We believe in access to quality legal representation for all Maryland families, regardless of background or circumstance.',
    icon: '🌍',
  },
  {
    title: 'Excellence in Practice',
    desc: 'Our attorneys bring top academic credentials, diverse experience, and relentless preparation to every case.',
    icon: '⭐',
  },
  {
    title: 'Child-Centered Advocacy',
    desc: 'In every custody matter, the wellbeing of children remains our North Star — always above all else.',
    icon: '👶',
  },
];

const promiseSteps = [
  { letter: 'P', title: 'Plan', desc: 'We craft a personalized legal strategy built around your specific goals, circumstances, and family dynamics.' },
  { letter: 'R', title: 'Research', desc: 'Deep dive into applicable Maryland law, case precedents, and all relevant facts to build the strongest possible case.' },
  { letter: 'O', title: 'Organize', desc: 'Meticulous organization of all evidence, documentation, timelines, and procedural requirements.' },
  { letter: 'M', title: 'Mediate', desc: 'When appropriate and beneficial, we pursue mediation and negotiated resolutions to minimize conflict and costs.' },
  { letter: 'I', title: 'Implement', desc: 'Precise execution of your legal strategy — whether in settlement negotiations or before the court.' },
  { letter: 'S', title: 'Secure', desc: 'We work to secure outcomes that protect your rights, your assets, and — most importantly — your children.' },
  { letter: 'E', title: 'Evaluate', desc: 'Ongoing assessment ensures your plan adapts as your case evolves and new information emerges.' },
];
---

<BaseLayout
  title="About Child Custody with a Plan | Maryland Family Law Firm Founded 2013"
  description="Learn about Child Custody with a Plan — Maryland's strategic family law firm founded in 2013. Our PROMISE Framework™, our values, and our commitment to Maryland families in Rockville and Baltimore."
>
  <Hero
    variant="interior"
    subtitle="About Our Firm"
    title="Maryland's Strategic Family Law Firm"
    description="Founded in 2013 with a singular mission: to give every Maryland family a clear, strategic path forward through life's most challenging legal moments."
    ctaText="Meet Our Attorneys"
    ctaHref="/attorneys"
    ctaSecondaryText="Free Consultation"
    ctaSecondaryHref="/free-consultation"
  />

  <!-- Our Story -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-gold font-semibold text-sm uppercase tracking-widest mb-3">Our Story</p>
          <h2 class="text-3xl font-serif font-bold text-teal mb-4">Built on Purpose, Driven by Results</h2>
          <div class="w-16 h-1 bg-gold rounded-full mb-6"></div>
          <p class="text-gray-700 leading-relaxed mb-5">
            Child Custody with a Plan was founded in 2013 with a clear purpose: to transform the way Maryland families navigate the legal challenges of divorce and child custody. Our founding team recognized that too many families were entering the family court system without a real plan — reactive, overwhelmed, and ill-prepared for what lay ahead.
          </p>
          <p class="text-gray-700 leading-relaxed mb-5">
            We built this firm on the belief that <strong>every family deserves a strategic legal partner</strong>, not just representation. From our first day in practice, we've combined intellectual rigor with genuine empathy — understanding that behind every legal matter is a real family, real children, and a future worth fighting for.
          </p>
          <p class="text-gray-700 leading-relaxed mb-5">
            Today, we serve clients from two Maryland offices — Rockville and Baltimore — covering Montgomery County, Baltimore City, Howard County, Prince George's County, Anne Arundel County, and surrounding areas. We are licensed in Maryland, Virginia, and Washington D.C., giving our clients seamless representation across the region.
          </p>
          <p class="text-gray-700 leading-relaxed">
            Whether you're facing a contested custody battle, a complex high-net-worth divorce, or a post-divorce modification, our attorneys bring the same commitment: <em>a plan, not just an opinion</em>.
          </p>
        </div>

        <div class="space-y-6">
          <div class="bg-teal rounded-2xl p-8 text-white">
            <h3 class="text-2xl font-serif font-bold mb-6">By the Numbers</h3>
            <div class="grid grid-cols-2 gap-6">
              {[
                { num: '2013', label: 'Year Founded' },
                { num: '2', label: 'Office Locations' },
                { num: '3', label: 'Jurisdictions' },
                { num: '8', label: 'Practice Areas' },
              ].map((item) => (
                <div class="text-center">
                  <div class="text-3xl font-bold text-gold mb-1">{item.num}</div>
                  <div class="text-sm text-teal-100">{item.label}</div>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-offwhite rounded-2xl p-6 border border-gray-200">
            <h3 class="font-serif font-bold text-charcoal text-lg mb-4">Our Office Locations</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-teal mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <div class="font-semibold text-charcoal text-sm">Rockville Office</div>
                  <div class="text-gray-600 text-sm">100 Park Ave, Suite 205<br/>Rockville, MD 20850</div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-teal mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <div class="font-semibold text-charcoal text-sm">Baltimore Office</div>
                  <div class="text-gray-600 text-sm">1537 Light St, #100<br/>Baltimore, MD 21230</div>
                </div>
              </div>
              <div class="flex items-center gap-3 pt-2 border-t border-gray-200">
                <svg class="w-5 h-5 text-teal shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                </svg>
                <div>
                  <a href="tel:+13012898917" class="font-semibold text-charcoal text-sm hover:text-teal transition-colors">(301) 289-8917</a>
                  <div class="text-gray-500 text-xs">Mon–Fri, 9AM–9PM</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-offwhite py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-gold font-semibold text-sm uppercase tracking-widest mb-3">What We Stand For</p>
        <h2 class="section-heading">Our Core Values</h2>
        <div class="gold-bar mx-auto"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {values.map((val) => (
          <div class="card">
            <div class="text-3xl mb-4">{val.icon}</div>
            <h3 class="font-serif font-bold text-charcoal text-lg mb-2">{val.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{val.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROMISE Framework -->
  <section id="promise" class="bg-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-gold font-semibold text-sm uppercase tracking-widest mb-3">Our Proprietary Process</p>
        <h2 class="section-heading">The PROMISE Framework™</h2>
        <div class="gold-bar mx-auto"></div>
        <p class="section-subheading mx-auto text-center">
          Our exclusive 7-step legal methodology ensures every client receives a structured, strategic approach to their family law matter — from the first consultation to final resolution.
        </p>
      </div>

      <div class="relative">
        <!-- Connector line (desktop) -->
        <div class="hidden lg:block absolute top-8 left-8 right-8 h-0.5 bg-teal-100 z-0"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-7 gap-5 relative z-10">
          {promiseSteps.map((step, i) => (
            <div class="text-center">
              <div class="w-16 h-16 bg-teal text-white rounded-2xl flex items-center justify-center font-serif font-bold text-2xl mx-auto mb-4 shadow-lg">
                {step.letter}
              </div>
              <h3 class="font-serif font-bold text-charcoal text-base mb-2">{step.title}</h3>
              <p class="text-xs text-gray-600 leading-relaxed">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-12 bg-teal-50 border border-teal-100 rounded-2xl p-8 text-center">
        <h3 class="font-serif font-bold text-teal text-xl mb-3">Experience the PROMISE Difference</h3>
        <p class="text-gray-600 leading-relaxed mb-6 max-w-2xl mx-auto">
          When you work with Child Custody with a Plan, you don't just get an attorney — you get a strategic partner who's invested in your outcome every step of the way. The PROMISE Framework™ ensures nothing falls through the cracks.
        </p>
        <a href="/free-consultation" class="btn-primary">Start With a Free Consultation</a>
      </div>
    </div>
  </section>

  <!-- Mission statement -->
  <section class="bg-teal py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <svg class="w-12 h-12 text-gold mx-auto mb-6 opacity-70" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
      </svg>
      <blockquote class="text-2xl sm:text-3xl font-serif font-semibold leading-relaxed mb-6">
        "Our mission is simple: to ensure every Maryland family we serve has a clear, strategic plan that protects their rights, their assets, and — above all — their children."
      </blockquote>
      <p class="text-gold font-semibold text-sm uppercase tracking-widest">The Founding Team, Child Custody with a Plan — Est. 2013</p>
    </div>
  </section>

  <!-- Areas served -->
  <section class="bg-offwhite py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-gold font-semibold text-sm uppercase tracking-widest mb-3">Where We Practice</p>
        <h2 class="section-heading">Serving Maryland, Virginia & D.C.</h2>
        <div class="gold-bar mx-auto"></div>
        <p class="section-subheading mx-auto text-center">
          From our offices in Rockville and Baltimore, we represent clients across Maryland and the greater DMV region.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 max-w-5xl mx-auto">
        {[
          'Montgomery County', 'Baltimore City', 'Baltimore County', 'Howard County',
          "Prince George's County", 'Anne Arundel County', 'Frederick County',
          'Carroll County', 'Harford County', 'Charles County', 'Calvert County',
          'St. Mary\'s County', 'Washington D.C.', 'Northern Virginia', 'Fairfax County',
        ].map((area) => (
          <div class="bg-white rounded-lg px-3 py-2.5 text-sm text-center text-gray-700 border border-gray-200 hover:border-teal hover:text-teal transition-colors">
            {area}
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Ready to Build Your Plan?"
    description="Schedule a free, confidential consultation with one of our experienced Maryland family law attorneys today."
  />
</BaseLayout>
