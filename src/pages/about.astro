---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const promiseSteps = [
  {
    letter: 'P',
    title: 'Plan',
    color: 'bg-teal-500',
    desc: 'We begin every engagement with a thorough case assessment. We evaluate your family circumstances, your goals, and the legal landscape specific to your Maryland jurisdiction. No two plans are alike.',
  },
  {
    letter: 'R',
    title: 'Research',
    color: 'bg-teal-600',
    desc: 'Our team conducts meticulous legal research — analyzing applicable Maryland statutes, relevant case law, and your specific situation to identify the strongest possible path forward.',
  },
  {
    letter: 'O',
    title: 'Organize',
    color: 'bg-teal-500',
    desc: 'We systematically compile your documentation, financial records, parenting history, and supporting evidence, ensuring everything is in order before any court filings or negotiations begin.',
  },
  {
    letter: 'M',
    title: 'Mobilize',
    color: 'bg-teal-600',
    desc: 'We take decisive, strategic legal action — filing motions, initiating negotiations, and advocating powerfully on your behalf in every courtroom appearance and settlement conference.',
  },
  {
    letter: 'I',
    title: 'Implement',
    color: 'bg-teal-500',
    desc: 'Your customized strategy is executed with precision at every stage of proceedings. We monitor developments, adapt to opposing arguments, and maintain a consistent forward momentum.',
  },
  {
    letter: 'S',
    title: 'Stabilize',
    color: 'bg-teal-600',
    desc: 'We work toward a durable outcome that brings stability to your family — for you and your children — both in the immediate term and for the years ahead.',
  },
  {
    letter: 'E',
    title: 'Evolve',
    color: 'bg-teal-500',
    desc: 'Families change. We help you adapt your legal arrangements as circumstances evolve — whether that means modifications, enforcement actions, or new challenges that arise post-judgment.',
  },
];

const values = [
  {
    icon: '⚖️',
    title: 'Strategic Excellence',
    desc: 'We approach every case as a strategist, not just a litigator. We plan every move with your long-term goals in mind.',
  },
  {
    icon: '💗',
    title: 'Compassionate Advocacy',
    desc: 'We understand the emotional weight of family law matters. We combine empathy with expertise to guide you through with dignity.',
  },
  {
    icon: '🌱',
    title: 'Community-Centered',
    desc: 'We are deeply invested in the Maryland communities we serve — uplifting families and changing how communities navigate family transitions.',
  },
  {
    icon: '🔒',
    title: 'Confidential & Discreet',
    desc: 'Your family\'s privacy is paramount. We handle every case with the discretion it deserves, protecting your personal and professional reputation.',
  },
  {
    icon: '✊',
    title: 'Women Empowering Women',
    desc: 'Our women-led team provides a safe space for clients — especially women — to tell their full story and receive the fierce representation they deserve.',
  },
  {
    icon: '🎯',
    title: 'Child-First Philosophy',
    desc: 'Every strategy we build places the best interests of your children at the center. Their well-being drives every legal decision we make.',
  },
];
---

<BaseLayout
  title="About Us | Child Custody with a Plan — Maryland Women-Led Family Law Firm"
  description="Learn about Child Custody with a Plan — a Maryland women-led family law firm founded by Josephia Rouse (2025 Elite Lawyer Award). Discover our PROMISE Framework, mission, and community-centered approach."
>
  <!-- Hero -->
  <section class="teal-gradient text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold-400 rounded-full opacity-10 blur-3xl"></div>
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <div class="max-w-3xl">
        <p class="text-gold-400 font-semibold text-sm uppercase tracking-widest mb-3">Our Story</p>
        <h1 class="font-serif font-bold text-4xl md:text-5xl text-white leading-tight mb-6">
          Where Strategy Meets Compassion in Maryland Family Law
        </h1>
        <p class="text-teal-100 text-xl leading-relaxed">
          Child Custody with a Plan was built on a simple but powerful belief: families deserve more than legal representation. They deserve a plan.
        </p>
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-gold-500 font-semibold text-sm uppercase tracking-widest mb-3">Our Foundation</p>
          <h2 class="font-serif font-bold text-3xl md:text-4xl text-teal-700 mb-6">A Firm Built for Maryland Families</h2>
          <div class="prose-custom">
            <p>
              <strong>Child Custody with a Plan</strong> is the sister site and practice arm of <em>Divorce with a Plan</em>, Maryland's premier women-led family law firm. Together, these practices represent the vision of founder <strong>Josephia Rouse, Esq.</strong> — to transform how Maryland families navigate divorce, child custody, and family transitions.
            </p>
            <p>
              Josephia launched her practice after observing a troubling pattern: too many Maryland families were coming to family court unprepared, overwhelmed, and without a real strategy for the road ahead. She believed that the families who struggled most weren't lacking good attorneys — they were lacking a <em>plan</em>.
            </p>
            <p>
              That insight became the foundation of a firm — and a methodology. The PROMISE Framework™ was born from Josephia's commitment to transforming client preparation from an afterthought into the centerpiece of every legal representation.
            </p>
            <p>
              Today, with offices in <strong>Rockville</strong> and <strong>Baltimore</strong>, Child Custody with a Plan serves families across Maryland with the same unwavering belief: strategic preparation, compassionate advocacy, and a community-centered mission.
            </p>
          </div>
        </div>
        <div class="space-y-6">
          <!-- Award callout -->
          <div class="bg-teal-50 rounded-2xl p-8 border border-teal-200">
            <div class="flex items-start gap-4">
              <div class="w-16 h-16 bg-gold-400 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-serif font-bold text-teal-700 text-xl mb-2">2025 Elite Lawyer Award</h3>
                <p class="text-gray-600">Josephia Rouse has been recognized with the prestigious <strong>2025 Elite Lawyer Award</strong>, reflecting her commitment to exceptional client representation, legal excellence, and her transformative impact on Maryland families.</p>
              </div>
            </div>
          </div>

          <!-- Sister site callout -->
          <div class="bg-white rounded-2xl p-8 shadow-md border border-gray-100">
            <h3 class="font-serif font-bold text-teal-700 text-xl mb-3">Sister Firm: Divorce with a Plan</h3>
            <p class="text-gray-600 mb-4">Child Custody with a Plan operates as the sister practice to <strong>Divorce with a Plan</strong> (divorcewithaplan.com) — both led by Josephia Rouse and sharing the same strategic methodology, attorney team, and community-centered mission.</p>
            <a href="https://divorcewithaplan.com" target="_blank" rel="noopener" class="text-teal-600 font-semibold hover:text-teal-700 text-sm flex items-center gap-1">
              Visit Divorce with a Plan
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Values -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-gold-500 font-semibold text-sm uppercase tracking-widest mb-3">What We Stand For</p>
        <h2 class="section-heading">Our Mission & Core Values</h2>
        <p class="section-subheading">
          Our mission is to empower Maryland families with strategic legal representation — and to change how our communities navigate the most difficult family transitions.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {values.map((v) => (
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow border border-gray-100">
            <div class="text-3xl mb-4">{v.icon}</div>
            <h3 class="font-serif font-bold text-teal-700 text-xl mb-3">{v.title}</h3>
            <p class="text-gray-600 leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROMISE Framework -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-gold-500 font-semibold text-sm uppercase tracking-widest mb-3">Our Proprietary Process</p>
        <h2 class="section-heading">The PROMISE Framework™</h2>
        <p class="section-subheading max-w-3xl mx-auto">
          The PROMISE Framework is our proprietary 7-step client strategy process — developed by Josephia Rouse to ensure every client receives not just representation, but a comprehensive, strategic plan tailored to their unique situation.
        </p>
      </div>

      <div class="space-y-4 max-w-4xl mx-auto">
        {promiseSteps.map((step, i) => (
          <div class="flex items-start gap-6 bg-teal-50 rounded-xl p-6 border border-teal-100 hover:border-teal-300 transition-colors">
            <div class={`w-14 h-14 ${step.color} text-white font-serif font-bold text-2xl rounded-full flex items-center justify-center flex-shrink-0 shadow-md`}>
              {step.letter}
            </div>
            <div>
              <h3 class="font-serif font-bold text-teal-700 text-xl mb-2">{step.title}</h3>
              <p class="text-gray-600 leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Community Section -->
  <section class="py-16 md:py-20 teal-gradient text-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-gold-400 font-semibold text-sm uppercase tracking-widest mb-3">Community First</p>
        <h2 class="font-serif font-bold text-3xl md:text-4xl text-white mb-6">Rooted in the Maryland Community</h2>
        <p class="text-teal-100 text-lg leading-relaxed mb-6">
          Child Custody with a Plan isn't just a law firm — it's a community resource. We're dedicated to changing the narrative around divorce and child custody in Maryland, turning these difficult transitions into opportunities for clarity, healing, and new beginnings.
        </p>
        <p class="text-teal-100 text-lg leading-relaxed mb-8">
          We're especially committed to serving underrepresented communities across Baltimore and Montgomery County, ensuring that every family — regardless of background — has access to strategic, compassionate legal counsel.
        </p>
        <a href="/free-consultation" class="btn-primary text-base !py-4 !px-8">
          Start Your Journey Today
        </a>
      </div>
    </div>
  </section>

  <CTASection variant="light" />
</BaseLayout>
