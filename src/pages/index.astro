---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const services = [
  { title: 'Child Custody', desc: 'Strategic custody representation for mothers and fathers. We fight for parenting plans that serve your children\'s best interests and protect your parental rights.', href: '/child-custody', icon: '👨‍👧' },
  { title: 'Child Custody Modification', desc: 'Life changes. When circumstances shift, we help you modify existing custody orders to reflect your family\'s new reality and your children\'s evolving needs.', href: '/child-custody-modification', icon: '🔄' },
  { title: 'Divorce', desc: 'Strategic divorce representation from filing through final judgment. We protect your rights in both contested and uncontested matters throughout Maryland.', href: '/divorce', icon: '⚖️' },
  { title: 'Asset Division', desc: 'Maryland\'s equitable distribution law is not a 50/50 guarantee. Our attorneys fight to ensure the division of marital property is truly fair to you.', href: '/asset-division', icon: '🏠' },
  { title: 'High Net Worth Divorce', desc: 'Complex, high-stakes divorces demand specialized expertise. We protect your wealth, investments, business interests, and financial legacy with absolute discretion.', href: '/high-net-worth-divorce', icon: '💼' },
  { title: 'Spousal Support', desc: 'Whether seeking alimony or defending against an unjust award, we build strategic, evidence-backed cases that advocate powerfully for your financial future.', href: '/spousal-support', icon: '📋' },
  { title: 'Divorce for Professionals', desc: 'Doctors, executives, and professionals face unique divorce challenges. Our team understands your career, income structures, licensing risks, and professional reputation.', href: '/divorce-lawyer-for-professionals', icon: '🎓' },
  { title: 'Business Divorce', desc: 'Business ownership in a marriage creates complex legal issues. We untangle ownership, valuation, goodwill, and distribution challenges to protect what you built.', href: '/divorces-involving-businesses', icon: '🏢' },
];

const promiseSteps = [
  { letter: 'P', word: 'Prepare', desc: 'We thoroughly analyze your situation before any court appearance or negotiation.' },
  { letter: 'R', word: 'Research', desc: 'Every case is backed by rigorous legal research and Maryland family law precedent.' },
  { letter: 'O', word: 'Organize', desc: 'We build a coherent, persuasive narrative around your facts and goals.' },
  { letter: 'M', word: 'Manage', desc: 'Proactive case management keeps your matter moving toward resolution.' },
  { letter: 'I', word: 'Innovate', desc: 'Creative legal strategies give our clients a decisive advantage.' },
  { letter: 'S', word: 'Strategize', desc: 'Every decision is made within a deliberate, long-term strategic framework.' },
  { letter: 'E', word: 'Execute', desc: 'Flawless execution in court and negotiation delivers results that matter.' },
];

const stats = [
  { value: '2013', label: 'Year Founded' },
  { value: '4', label: 'Experienced Attorneys' },
  { value: '2', label: 'Office Locations' },
  { value: 'Free', label: 'Initial Consultation' },
];

const testimonials = [
  {
    quote: 'Having a plan from day one made all the difference. My attorney was strategic, prepared, and always one step ahead. I felt confident throughout the entire process.',
    name: 'Client — Montgomery County',
    matter: 'Child Custody Case',
  },
  {
    quote: 'I was going through a high-asset divorce and needed someone who understood the complexities. The firm\'s knowledge of business valuation and property division was exceptional.',
    name: 'Client — Baltimore',
    matter: 'High Net Worth Divorce',
  },
  {
    quote: 'As a professional, I was worried about my reputation and career. My attorney handled everything with complete discretion and achieved an outcome I could not have imagined.',
    name: 'Client — Rockville',
    matter: 'Divorce for Professionals',
  },
];

const homeSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://childcustodywithaplan.com/#webpage",
  "url": "https://childcustodywithaplan.com/",
  "name": "Child Custody Attorney Maryland | Family Law Firm Rockville & Baltimore",
  "description": "Child Custody with a Plan — top-rated Maryland child custody attorneys and family law firm serving Rockville and Baltimore. Free consultations. Call (240) 326-7712.",
  "isPartOf": { "@id": "https://childcustodywithaplan.com/#website" },
  "about": { "@id": "https://childcustodywithaplan.com/#legalservice" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://childcustodywithaplan.com/" }
    ]
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", "h2"]
  }
});
---

<BaseLayout
  title="Child Custody Attorney Maryland | Family Law Firm Rockville &amp; Baltimore"
  description="Child Custody with a Plan — Maryland's strategic family law attorneys for child custody, divorce &amp; more. Offices in Rockville &amp; Baltimore. Free consultation. Call (240) 326-7712."
  canonicalURL="https://childcustodywithaplan.com/"
  ogImage="/images/hero-landing.webp"
  schema={homeSchema}
>
  <!-- Hero Section -->
  <section
    class="relative overflow-hidden"
    style="background-image: url('/images/hero-landing.webp'); background-size: cover; background-position: center; min-height: 80vh;"
    aria-label="Maryland Child Custody and Family Law Attorneys Hero"
  >
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-black/60"></div>

    <div class="relative z-10 flex flex-col items-center justify-center text-center min-h-[80vh] px-4 sm:px-6 py-24 md:py-36 max-w-7xl mx-auto w-full">
      <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-4">Maryland Family Law Attorneys</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Where Child Custody<br/>
        <span class="text-gold">Meets Strategy</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-200 leading-relaxed mb-8 max-w-2xl">
        Child Custody with a Plan is a Maryland family law firm dedicated to empowering parents with legal strategy, compassionate counsel, and decisive representation. We serve Rockville, Baltimore, and all of Maryland.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/free-consultation" class="btn-primary">Schedule Free Consultation</a>
        <a href="tel:+12403267712" class="inline-flex items-center gap-2 bg-white/10 border border-white text-white px-6 py-3 font-semibold text-sm uppercase tracking-wide hover:bg-white hover:text-teal transition-all rounded-sm">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          (240) 326-7712
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-sm text-gray-300">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Free Consultation
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          MD, VA &amp; DC Barred
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Founded 2013
        </span>
      </div>
    </div>
  </section>

  <!-- Trust Stats Bar -->
  <section class="bg-gray-900 py-8" aria-label="Firm Statistics and Trust Signals">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {stats.map((stat) => (
          <div class="flex flex-col items-center">
            <span class="text-3xl md:text-4xl font-serif font-bold text-gold">{stat.value}</span>
            <span class="text-gray-400 text-sm mt-1 uppercase tracking-wide">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="bg-gray-800 py-5 border-t border-gray-700" aria-label="Credentials and Service Areas">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gold rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0">MD</div>
          <span class="text-gray-300 text-sm">Licensed in<br/><strong class="text-white">Maryland</strong></span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gold rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0">VA</div>
          <span class="text-gray-300 text-sm">Licensed in<br/><strong class="text-white">Virginia</strong></span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gold rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0">DC</div>
          <span class="text-gray-300 text-sm">Licensed in<br/><strong class="text-white">Washington D.C.</strong></span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-teal rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <span class="text-gray-300 text-sm">Free Initial<br/><strong class="text-white">Consultation</strong></span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-teal rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
          </div>
          <span class="text-gray-300 text-sm">Mon–Fri<br/><strong class="text-white">9AM–9PM</strong></span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 bg-gray-50" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">What We Do</p>
        <h2 id="services-heading" class="section-heading mb-4">Comprehensive Family Law Representation</h2>
        <p class="text-gray-600 max-w-2xl mx-auto leading-relaxed">
          From contested custody battles to complex high-asset divorces, our Maryland attorneys provide the strategic advocacy your family deserves across all 8 practice areas.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((svc) => (
          <a href={svc.href} class="group bg-white border-b-4 border-transparent hover:border-gold p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
            <div class="text-3xl mb-4">{svc.icon}</div>
            <h3 class="font-serif text-lg font-bold text-teal mb-2 group-hover:text-gold transition-colors">{svc.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{svc.desc}</p>
            <span class="inline-block mt-4 text-teal text-sm font-semibold group-hover:text-gold transition-colors">Learn more &rarr;</span>
          </a>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/services" class="btn-outline-teal">View All Practice Areas</a>
      </div>
    </div>
  </section>

  <!-- PROMISE Framework -->
  <section class="py-20 bg-white" aria-labelledby="promise-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Our Proprietary Process</p>
          <h2 id="promise-heading" class="section-heading mb-6">The PROMISE Framework</h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Every client at Child Custody with a Plan benefits from our proprietary PROMISE Framework — a structured, seven-step process that transforms your legal challenge into a clear, executable strategy.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            Unlike firms that take a reactive, wait-and-see approach, we build your case from day one with purpose, precision, and a plan. Because when your family is on the line, improvisation is not an option.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Founded in 2013 by Josephia Rouse, the firm was built on the conviction that clients deserve more than legal representation — they deserve a lawyer who brings strategy, structure, and genuine commitment to every case.
          </p>
          <a href="/about" class="btn-outline-teal">Learn How We Work</a>
        </div>
        <div class="space-y-3">
          {promiseSteps.map((step) => (
            <div class="flex gap-4 items-start p-4 bg-gray-50 hover:bg-teal-50 transition-colors rounded-sm">
              <div class="w-12 h-12 bg-teal text-white font-serif font-bold text-xl flex items-center justify-center flex-shrink-0 rounded-sm">
                {step.letter}
              </div>
              <div>
                <h3 class="font-semibold text-teal mb-1">{step.word}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="py-20 bg-teal" aria-labelledby="why-us-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Why Choose Us</p>
        <h2 id="why-us-heading" class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">A Different Kind of Family Law Firm</h2>
        <p class="text-teal-100 max-w-2xl mx-auto leading-relaxed">We combine legal excellence with genuine empathy, because we understand that every case is a family's life.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Strategy-First Approach</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Every representation begins with a comprehensive strategy session. We do not react to circumstances — we shape them. Our PROMISE Framework ensures every case is handled with intention.</p>
        </div>
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">4 Experienced Attorneys</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Our team of four licensed attorneys — including two Certified Best Interest Attorneys — brings diverse expertise across family law, civil litigation, corporate law, and legal aid representation.</p>
        </div>
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Compassionate Advocacy</h3>
          <p class="text-teal-100 text-sm leading-relaxed">We fight hard in the courtroom while treating clients with the dignity, respect, and empathy their situation demands. Your family is not a case number to us.</p>
        </div>
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Deep Legal Expertise</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Our attorneys bring backgrounds in legal aid, government service, corporate law, and private practice — a rare combination that gives our clients a comprehensive legal advantage.</p>
        </div>
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Two Convenient Offices</h3>
          <p class="text-teal-100 text-sm leading-relaxed">With offices in Rockville (Montgomery County) and Baltimore, we are accessible to clients throughout Maryland's most populated and served corridors. Virtual consultations also available.</p>
        </div>
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Certified Best Interest Attorneys</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Two of our attorneys hold the prestigious Maryland Certified Best Interest Attorney (BIA) credential — a specialized certification to represent children's interests in contested custody proceedings.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Attorneys Preview -->
  <section class="py-20 bg-gray-50" aria-labelledby="attorneys-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Our Legal Team</p>
        <h2 id="attorneys-heading" class="section-heading mb-4">Experienced Maryland Family Law Attorneys</h2>
        <p class="text-gray-600 max-w-2xl mx-auto leading-relaxed">Meet the dedicated legal professionals who will stand beside you every step of the way. Founded in 2013, our team has grown to four experienced Maryland attorneys.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        <div class="bg-white shadow-md p-6 border-t-4 border-gold text-center">
          <div class="w-16 h-16 bg-teal rounded-full flex items-center justify-center mb-4 text-white font-serif text-xl font-bold mx-auto">JR</div>
          <h3 class="font-serif text-lg font-bold text-teal mb-1">Josephia Rouse</h3>
          <p class="text-gold font-semibold text-xs mb-2 uppercase tracking-wide">Founder &amp; Owner</p>
          <p class="text-gray-500 text-xs leading-relaxed mb-3">Maryland's leading divorce attorney. Certified Mediator &amp; Best Interest Attorney. Practicing since 2013. 2025 Elite Lawyer Award.</p>
          <a href="/attorneys" class="text-teal font-semibold text-xs hover:text-gold transition-colors">Full Bio &rarr;</a>
        </div>
        <div class="bg-white shadow-md p-6 border-t-4 border-teal text-center">
          <div class="w-16 h-16 bg-teal rounded-full flex items-center justify-center mb-4 text-white font-serif text-xl font-bold mx-auto">MM</div>
          <h3 class="font-serif text-lg font-bold text-teal mb-1">Massa Massaquoi-King</h3>
          <p class="text-gold font-semibold text-xs mb-2 uppercase tracking-wide">Managing Attorney</p>
          <p class="text-gray-500 text-xs leading-relaxed mb-3">Certified Best Interest Attorney. Successfully tried high-asset divorce cases exceeding $2M. Massachusetts School of Law, J.D.</p>
          <a href="/attorneys" class="text-teal font-semibold text-xs hover:text-gold transition-colors">Full Bio &rarr;</a>
        </div>
        <div class="bg-white shadow-md p-6 border-t-4 border-teal text-center">
          <div class="w-16 h-16 bg-teal rounded-full flex items-center justify-center mb-4 text-white font-serif text-xl font-bold mx-auto">MN</div>
          <h3 class="font-serif text-lg font-bold text-teal mb-1">Monique Nettleford-Bruce</h3>
          <p class="text-gold font-semibold text-xs mb-2 uppercase tracking-wide">Associate Attorney</p>
