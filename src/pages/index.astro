---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const services = [
  { title: 'Child Custody', desc: 'Comprehensive custody representation focused on your children\'s best interests. We fight for parenting plans that work.', href: '/child-custody', icon: '👨‍👧' },
  { title: 'Child Custody Modification', desc: 'Life changes. When circumstances shift, we help you modify existing custody orders to reflect your family\'s new reality.', href: '/child-custody-modification', icon: '🔄' },
  { title: 'Divorce', desc: 'Strategic divorce representation in Maryland and beyond. We protect your rights from filing through final judgment.', href: '/divorce', icon: '⚖️' },
  { title: 'Asset Division', desc: 'Equitable distribution of marital assets handled with precision. We ensure you receive a fair share of what you have built.', href: '/asset-division', icon: '🏠' },
  { title: 'High Net Worth Divorce', desc: 'Complex, high-stakes divorces demand specialized expertise. We protect your wealth, investments, and business interests.', href: '/high-net-worth-divorce', icon: '💼' },
  { title: 'Spousal Support', desc: 'Whether seeking alimony or defending against an unjust award, we advocate powerfully for your financial future.', href: '/spousal-support', icon: '📋' },
  { title: 'Divorce for Professionals', desc: 'Doctors, executives, and professionals face unique divorce challenges. Our team understands your career, income, and licensing risks.', href: '/divorce-lawyer-for-professionals', icon: '🎓' },
  { title: 'Business Divorce', desc: 'Business ownership in a marriage creates complex legal issues. We untangle ownership, valuation, and distribution challenges.', href: '/divorces-involving-businesses', icon: '🏢' },
];

const promiseSteps = [
  { letter: 'P', word: 'Prepare', desc: 'We thoroughly analyze your situation before any court appearance or negotiation.' },
  { letter: 'R', word: 'Research', desc: 'Every case is backed by rigorous legal research and Maryland family law precedent.' },
  { letter: 'O', word: 'Organize', desc: 'We build a coherent, persuasive narrative around your facts and goals.' },
  { letter: 'M', word: 'Manage', desc: 'Proactive case management keeps your matter moving toward resolution.' },
  { letter: 'I', word: 'Innovate', desc: 'Creative legal strategies give our clients a decisive advantage.' },
  { letter: 'S', word: 'Strategize', desc: 'Every decision is made within a deliberate, long-term strategic framework.' },
  { letter: 'E', word: 'Execute', desc: 'Flawless execution in court and negotiation delivers results that matter.' },
];

const stats = [
  { value: '2013', label: 'Year Founded' },
  { value: '2', label: 'Office Locations' },
  { value: '8', label: 'Practice Areas' },
  { value: 'Free', label: 'Initial Consultation' },
];
---

<BaseLayout
  title="Maryland Child Custody &amp; Divorce Attorneys | Child Custody with a Plan"
  description="Child Custody with a Plan — Maryland family law attorneys serving Rockville and Baltimore. Strategic child custody, divorce, and family law representation. Free consultations available. Call (301) 289-8917."
>
  <!-- Hero Section -->
  <section class="bg-teal relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,0.05) 35px, rgba(255,255,255,0.05) 70px);"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-24 md:py-36 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-4">Maryland Family Law Attorneys</p>
          <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            Where Child Custody<br/>
            <span class="text-gold">Meets Strategy</span>
          </h1>
          <p class="text-lg md:text-xl text-teal-100 leading-relaxed mb-8">
            Child Custody with a Plan is a Maryland family law firm dedicated to empowering parents with legal strategy, compassionate counsel, and decisive representation. We serve Rockville, Baltimore, and all of Maryland.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/free-consultation" class="btn-primary">Schedule Free Consultation</a>
            <a href="/about" class="btn-secondary">Learn About the Firm</a>
          </div>
          <div class="mt-8 flex items-center gap-6 text-sm text-teal-200">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              Free Consultation
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              MD, VA &amp; DC Barred
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              Founded 2013
            </span>
          </div>
        </div>
        <!-- Stats card -->
        <div class="hidden lg:block">
          <div class="bg-white bg-opacity-10 backdrop-blur-sm rounded-sm p-8 border border-white border-opacity-20">
            <h2 class="font-serif text-2xl font-bold text-white mb-6">Protecting Maryland Families Since 2013</h2>
            <div class="grid grid-cols-2 gap-6 mb-8">
              {stats.map((s) => (
                <div class="text-center">
                  <p class="font-serif text-4xl font-bold text-gold mb-1">{s.value}</p>
                  <p class="text-teal-200 text-sm">{s.label}</p>
                </div>
              ))}
            </div>
            <div class="border-t border-white border-opacity-20 pt-6">
              <p class="text-teal-100 text-sm leading-relaxed">Our PROMISE Framework guides every case — from first consultation through final resolution, ensuring each client receives a custom-built legal strategy.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="bg-gray-900 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gold rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0">MD</div>
          <span class="text-gray-300 text-sm">Licensed in<br/><strong class="text-white">Maryland</strong></span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gold rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0">VA</div>
          <span class="text-gray-300 text-sm">Licensed in<br/><strong class="text-white">Virginia</strong></span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gold rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0">DC</div>
          <span class="text-gray-300 text-sm">Licensed in<br/><strong class="text-white">Washington D.C.</strong></span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-teal rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <span class="text-gray-300 text-sm">Free Initial<br/><strong class="text-white">Consultation</strong></span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-teal rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
          </div>
          <span class="text-gray-300 text-sm">Mon–Fri<br/><strong class="text-white">9AM–9PM</strong></span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">What We Do</p>
        <h2 class="section-heading mb-4">Comprehensive Family Law Representation</h2>
        <p class="text-gray-600 max-w-2xl mx-auto leading-relaxed">
          From contested custody battles to complex high-asset divorces, our Maryland attorneys provide the strategic advocacy your family deserves.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((svc) => (
          <a href={svc.href} class="group bg-white border-b-4 border-transparent hover:border-gold p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
            <div class="text-3xl mb-4">{svc.icon}</div>
            <h3 class="font-serif text-lg font-bold text-teal mb-2 group-hover:text-gold transition-colors">{svc.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{svc.desc}</p>
            <span class="inline-block mt-4 text-teal text-sm font-semibold group-hover:text-gold transition-colors">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROMISE Framework -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Our Proprietary Process</p>
          <h2 class="section-heading mb-6">The PROMISE Framework</h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Every client at Child Custody with a Plan benefits from our proprietary PROMISE Framework — a structured, seven-step process that transforms your legal challenge into a clear, executable strategy.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Unlike firms that take a reactive, wait-and-see approach, we build your case from day one with purpose, precision, and a plan. Because when your family is on the line, improvisation is not an option.
          </p>
          <a href="/about" class="btn-outline-teal">Learn How We Work</a>
        </div>
        <div class="space-y-3">
          {promiseSteps.map((step) => (
            <div class="flex gap-4 items-start p-4 bg-gray-50 hover:bg-teal-50 transition-colors rounded-sm">
              <div class="w-12 h-12 bg-teal text-white font-serif font-bold text-xl flex items-center justify-center flex-shrink-0 rounded-sm">
                {step.letter}
              </div>
              <div>
                <h3 class="font-semibold text-teal mb-1">{step.word}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="py-20 bg-teal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Why Choose Us</p>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">A Different Kind of Family Law Firm</h2>
        <p class="text-teal-100 max-w-2xl mx-auto leading-relaxed">We combine legal excellence with genuine empathy, because we understand that every case is a family's life.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Strategy-First Approach</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Every representation begins with a comprehensive strategy session. We do not react to circumstances — we shape them.</p>
        </div>
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Community-Centered</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Founded in and for Maryland communities. We understand the courts, the judges, and the local landscape that shapes your case.</p>
        </div>
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Compassionate Advocacy</h3>
          <p class="text-teal-100 text-sm leading-relaxed">We fight hard in the courtroom while treating clients with the dignity, respect, and empathy their situation demands.</p>
        </div>
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Deep Legal Expertise</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Our attorneys bring backgrounds in legal aid, government service, and private practice — a rare combination of perspectives.</p>
        </div>
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Two Convenient Offices</h3>
          <p class="text-teal-100 text-sm leading-relaxed">With offices in Rockville and Baltimore, we are accessible to clients throughout Maryland's most populated corridors.</p>
        </div>
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 bg-gold rounded-sm flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Transparent Communication</h3>
          <p class="text-teal-100 text-sm leading-relaxed">You will always know where your case stands. We communicate proactively and respond promptly to your questions and concerns.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Attorneys Preview -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Our Legal Team</p>
        <h2 class="section-heading mb-4">Experienced Maryland Family Law Attorneys</h2>
        <p class="text-gray-600 max-w-2xl mx-auto leading-relaxed">Meet the dedicated legal professionals who will stand beside you every step of the way.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white shadow-md p-8 border-t-4 border-teal">
          <div class="w-16 h-16 bg-teal rounded-full flex items-center justify-center mb-4 text-white font-serif text-2xl font-bold">MN</div>
          <h3 class="font-serif text-xl font-bold text-teal mb-1">Monique Nettleford-Bruce</h3>
          <p class="text-gold font-semibold text-sm mb-3 uppercase tracking-wide">Associate Attorney</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">J.D., American University Washington College of Law. Former Maryland Legal Aid staff attorney. Editor-in-Chief, The Modern American Law Brief. Barred in MD and VA.</p>
          <a href="/attorneys" class="text-teal font-semibold text-sm hover:text-gold transition-colors">Full Bio &rarr;</a>
        </div>
        <div class="bg-white shadow-md p-8 border-t-4 border-teal">
          <div class="w-16 h-16 bg-teal rounded-full flex items-center justify-center mb-4 text-white font-serif text-2xl font-bold">AS</div>
          <h3 class="font-serif text-xl font-bold text-teal mb-1">Aysia Stockton</h3>
          <p class="text-gold font-semibold text-sm mb-3 uppercase tracking-wide">Associate Attorney</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">J.D., Appalachian School of Law (2020). B.S. Criminal Justice, Clark Atlanta University. Former Deputy Clerk, Richmond General District Court. Barred in MD and DC.</p>
          <a href="/attorneys" class="text-teal font-semibold text-sm hover:text-gold transition-colors">Full Bio &rarr;</a>
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/attorneys" class="btn-outline-teal">Meet Our Full Team</a>
      </div>
    </div>
  </section>

  <!-- Office Locations -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Find Us</p>
        <h2 class="section-heading mb-4">Two Offices Serving All of Maryland</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-teal text-white p-8 rounded-sm">
          <h3 class="font-serif text-2xl font-bold mb-2">Rockville Office</h3>
          <p class="text-gold font-semibold text-sm uppercase tracking-wide mb-4">Montgomery County</p>
          <address class="not-italic text-teal-100 leading-relaxed mb-6">
            100 Park Ave Suite 205<br />
            Rockville, MD 20850
          </address>
          <div class="space-y-2 text-sm text-teal-100 mb-6">
            <p class="flex items-center gap-2"><svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg> (301) 289-8917</p>
            <p class="flex items-center gap-2"><svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg> Mon–Fri: 9AM–9PM</p>
          </div>
          <a href="/free-consultation" class="inline-block bg-gold text-white px-6 py-2.5 text-sm font-semibold uppercase tracking-wide hover:bg-gold-600 transition-colors rounded-sm">Schedule Visit</a>
        </div>
        <div class="bg-gray-900 text-white p-8 rounded-sm">
          <h3 class="font-serif text-2xl font-bold mb-2">Baltimore Office</h3>
          <p class="text-gold font-semibold text-sm uppercase tracking-wide mb-4">Baltimore City</p>
          <address class="not-italic text-gray-300 leading-relaxed mb-6">
            1537 Light St #100<br />
            Baltimore, MD 21230
          </address>
          <div class="space-y-2 text-sm text-gray-300 mb-6">
            <p class="flex items-center gap-2"><svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg> (301) 289-8917</p>
            <p class="flex items-center gap-2"><svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg> Mon–Fri: 9AM–9PM</p>
          </div>
          <a href="/free-consultation" class="inline-block bg-gold text-white px-6 py-2.5 text-sm font-semibold uppercase tracking-wide hover:bg-gold-600 transition-colors rounded-sm">Schedule Visit</a>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
