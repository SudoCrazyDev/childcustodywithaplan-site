---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Child Custody with a Plan | Maryland Family Law Attorneys | Rockville & Baltimore"
  description="Maryland's trusted child custody and family law firm. Strategic, compassionate legal representation for custody, divorce, and high-asset family law cases throughout Maryland. Serving Rockville, Baltimore, Montgomery County & beyond."
>

  <!-- Hero -->
  <Hero
    subtitle="Maryland Family Law — Established 2013"
    title="Your Children Deserve a Plan. So Do You."
    description="We provide strategic, compassionate legal representation for child custody, divorce, and complex family law matters throughout Maryland. When your family's future is on the line, you need attorneys who fight for what matters most."
    primaryCta={{ label: "Schedule a Free Consultation", href: "/contact" }}
    secondaryCta={{ label: "Meet Our Attorneys", href: "/attorneys" }}
    badges={["Child Custody", "Divorce", "High-Asset Cases", "Spousal Support", "Custody Modification"]}
    variant="full"
  />

  <!-- Trust Indicators Bar -->
  <div class="bg-white border-b border-gray-100 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-bold text-[#0D6E6E] font-serif">2013</div>
          <div class="text-sm text-gray-500 mt-1">Established</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[#0D6E6E] font-serif">5+</div>
          <div class="text-sm text-gray-500 mt-1">Maryland Counties Served</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[#0D6E6E] font-serif">2</div>
          <div class="text-sm text-gray-500 mt-1">Dedicated Attorneys</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[#0D6E6E] font-serif">100%</div>
          <div class="text-sm text-gray-500 mt-1">Family Law Focus</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Why Choose Us -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">Why Clients Choose Us</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">Family Law That Starts With a Plan</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg leading-relaxed">
          We don't just react to your case — we build a strategic roadmap tailored to your goals, your family, and your future.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            icon: '⚖️',
            title: 'Strategic Advocacy',
            description: 'Every case begins with a deep dive into your situation. We craft a personalized legal strategy designed to achieve your specific custody, support, and asset goals.',
          },
          {
            icon: '❤️',
            title: 'Compassionate Counsel',
            description: 'Family law is deeply personal. Our attorneys bring both intellectual rigor and genuine empathy to every client relationship — because you deserve both.',
          },
          {
            icon: '🏆',
            title: 'Proven Experience',
            description: 'From contested high-asset divorces to complex custody disputes, our team brings real courtroom experience and a record of fighting hard for our clients.',
          },
          {
            icon: '🗺️',
            title: 'The PROMISE Framework',
            description: 'Our proprietary PROMISE approach ensures every client has a clear, structured plan from day one — protecting, representing, and empowering you at every step.',
          },
          {
            icon: '👩‍⚖️',
            title: 'Children\'s Best Interests',
            description: 'Protecting children is at the core of everything we do. We advocate fiercely for parenting arrangements that prioritize stability, safety, and wellbeing.',
          },
          {
            icon: '📍',
            title: 'Maryland-Focused',
            description: 'We practice exclusively in Maryland and D.C. — giving you the benefit of deep local knowledge across Montgomery, Howard, Baltimore, and surrounding counties.',
          },
        ].map(card => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-7 hover:shadow-md transition-shadow">
            <div class="text-4xl mb-4">{card.icon}</div>
            <h3 class="text-xl font-serif font-bold text-[#0D6E6E] mb-3">{card.title}</h3>
            <p class="text-gray-600 leading-relaxed text-sm">{card.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Practice Areas -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">What We Handle</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">Our Practice Areas</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          Comprehensive family law representation across Maryland and Washington D.C.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Child Custody & Visitation', desc: 'Legal and physical custody arrangements, parenting plans, and visitation schedules tailored to your children\'s needs.', icon: '👨‍👧‍👦' },
          { title: 'Divorce', desc: 'Contested and uncontested divorce representation — protecting your rights through every phase of the process.', icon: '📋' },
          { title: 'High-Asset Divorce', desc: 'Complex property division involving businesses, investments, real estate, and retirement accounts.', icon: '🏛️' },
          { title: 'Spousal Support', desc: 'Negotiating and litigating alimony and spousal support arrangements that reflect your contributions and needs.', icon: '🤝' },
          { title: 'Asset Division', desc: 'Equitable distribution of marital property, including homes, businesses, pensions, and financial accounts.', icon: '⚖️' },
          { title: 'Custody Modification', desc: 'Petitioning to modify existing custody or support orders when circumstances have substantially changed.', icon: '🔄' },
        ].map(area => (
          <a href="/services" class="group bg-[#0D6E6E] text-white rounded-xl p-6 hover:bg-[#095555] transition-colors">
            <div class="text-3xl mb-3">{area.icon}</div>
            <h3 class="text-lg font-serif font-bold mb-2 group-hover:text-[#D4A843] transition-colors">{area.title}</h3>
            <p class="text-white/80 text-sm leading-relaxed">{area.desc}</p>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/services" class="inline-block bg-[#D4A843] text-white font-semibold px-8 py-3 rounded hover:bg-[#B8902E] transition-colors">
          View All Practice Areas
        </a>
      </div>
    </div>
  </section>

  <!-- Meet Our Attorneys (only Monique & Aysia) -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">The People in Your Corner</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">Meet Our Associate Attorneys</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          Skilled, dedicated attorneys who bring both courtroom experience and genuine care to every family law matter.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-4xl mx-auto">

        <!-- Monique Nettleford-Bruce -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100">
          <div class="bg-[#0D6E6E] h-3"></div>
          <div class="p-8">
            <div class="w-16 h-16 rounded-full bg-[#0D6E6E]/10 flex items-center justify-center mb-5">
              <span class="text-2xl font-serif font-bold text-[#0D6E6E]">MN</span>
            </div>
            <h3 class="text-2xl font-serif font-bold text-[#0D6E6E] mb-1">Monique Nettleford-Bruce</h3>
            <p class="text-[#D4A843] font-semibold text-sm mb-4">Associate Attorney</p>
            <p class="text-gray-600 text-sm leading-relaxed mb-5">
              A compassionate and strategic family law attorney who brings both intellect and empathy to every case. Former Staff Attorney at Maryland Legal Aid, representing clients in housing, custody, divorce, and public benefits matters.
            </p>
            <div class="space-y-2 text-sm text-gray-500">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[#D4A843]"></span>
                J.D. — American University Washington College of Law
              </div>
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[#D4A843]"></span>
                B.A. Political Science — University of Arizona (magna cum laude)
              </div>
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[#D4A843]"></span>
                Barred: Maryland &amp; Virginia
              </div>
            </div>
          </div>
        </div>

        <!-- Aysia Stockton -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100">
          <div class="bg-[#0D6E6E] h-3"></div>
          <div class="p-8">
            <div class="w-16 h-16 rounded-full bg-[#0D6E6E]/10 flex items-center justify-center mb-5">
              <span class="text-2xl font-serif font-bold text-[#0D6E6E]">AS</span>
            </div>
            <h3 class="text-2xl font-serif font-bold text-[#0D6E6E] mb-1">Aysia Stockton</h3>
            <p class="text-[#D4A843] font-semibold text-sm mb-4">Associate Attorney</p>
            <p class="text-gray-600 text-sm leading-relaxed mb-5">
              Originally from Richmond, Virginia. Recognized for compassionate and thorough divorce and custody representation. Brings hands-on courtroom perspective from her time as a Deputy Clerk at Richmond General District Court.
            </p>
            <div class="space-y-2 text-sm text-gray-500">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[#D4A843]"></span>
                J.D. (2020) — Appalachian School of Law
              </div>
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[#D4A843]"></span>
                B.S. Criminal Justice — Clark Atlanta University
              </div>
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[#D4A843]"></span>
                Barred: Maryland &amp; Washington D.C.
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-10">
        <a href="/attorneys" class="inline-block bg-[#D4A843] text-white font-semibold px-8 py-3 rounded hover:bg-[#B8902E] transition-colors">
          View Full Attorney Profiles
        </a>
      </div>
    </div>
  </section>

  <!-- PROMISE Framework Teaser -->
  <section class="py-20 bg-[#0D6E6E]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-3">Our Proven Approach</p>
      <h2 class="text-4xl font-serif font-bold text-white mb-5">The PROMISE Framework</h2>
      <p class="text-white/80 max-w-2xl mx-auto text-lg mb-10 leading-relaxed">
        Our structured, client-first methodology ensures you're never left wondering what comes next. Every step is intentional, every decision is strategic.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4 max-w-5xl mx-auto mb-10">
        {['Protect', 'Represent', 'Organize', 'Mediate', 'Implement', 'Support', 'Empower'].map((step, i) => (
          <div class="bg-white/10 border border-white/20 rounded-xl p-4 text-center">
            <div class="text-[#D4A843] font-bold text-2xl font-serif mb-1">{step[0]}</div>
            <div class="text-white/80 text-xs">{step}</div>
          </div>
        ))}
      </div>
      <a href="/process" class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded hover:bg-white hover:text-[#0D6E6E] transition-colors">
        Learn Our Process
      </a>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">Where We Practice</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">Serving Maryland Families</h2>
        <p class="text-gray-600 max-w-xl mx-auto">
          With offices in Rockville and Baltimore, we represent clients throughout Maryland and Washington D.C.
        </p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
        {[
          'Rockville / Montgomery County',
          'Baltimore City & County',
          'Howard County',
          "Prince George's County",
          'Anne Arundel County',
          'Frederick County',
        ].map(area => (
          <div class="text-center py-4 px-3 bg-gray-50 rounded-lg border border-gray-100">
            <div class="w-8 h-8 bg-[#0D6E6E] rounded-full flex items-center justify-center mx-auto mb-2">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
              </svg>
            </div>
            <p class="text-gray-700 text-xs font-medium leading-tight">{area}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-[#D4A843]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl font-serif font-bold text-white mb-4">Ready to Build Your Plan?</h2>
      <p class="text-white/90 text-xl mb-8 leading-relaxed">
        Your first consultation is free. Let's talk about your situation, your goals, and how we can help protect what matters most.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-[#D4A843] font-bold px-10 py-4 rounded hover:bg-gray-100 transition-colors text-lg">
          Schedule Free Consultation
        </a>
        <a href="tel:2402693592" class="border-2 border-white text-white font-semibold px-10 py-4 rounded hover:bg-white hover:text-[#D4A843] transition-colors text-lg">
          Call (240) 269-3592
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
