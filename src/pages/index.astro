---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Maryland Child Custody Attorney | Family Law Firm Rockville and Baltimore"
  description="Child Custody with a Plan — Maryland strategic family law attorneys for child custody, divorce, and more. Offices in Rockville and Baltimore. Call (240) 326-7712."
  canonicalURL="https://childcustodywithaplan.com/"
  ogImage="/images/hero-landing.webp"
>

  <!-- ===================== 1. HERO ===================== -->
  <section
    class="relative overflow-hidden"
    style="background-image: url('/images/hero-landing.webp'); background-size: cover; background-position: center; min-height: 82vh;"
    aria-label="Maryland Child Custody Attorney Hero"
  >
    <div class="absolute inset-0 bg-black" style="opacity: 0.62;"></div>

    <div class="relative z-10 flex flex-col items-center justify-center text-center min-h-[82vh] px-4 sm:px-6 py-24 max-w-5xl mx-auto w-full">
      <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-4">Maryland Family Law Attorneys</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Maryland Child Custody Attorney<br />
        <span class="text-gold">Protecting Your Familys Future</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-200 leading-relaxed mb-8 max-w-2xl">
        Child Custody with a Plan is a Maryland family law firm dedicated to empowering parents with legal strategy, compassionate counsel, and decisive representation. We serve Rockville, Baltimore, and all of Maryland.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/contact" class="btn-primary">Contact Our Attorneys</a>
        <a href="tel:+12403267712" class="inline-flex items-center gap-2 bg-white/10 border border-white text-white px-6 py-3 font-semibold text-sm uppercase tracking-wide hover:bg-white hover:text-teal transition-all rounded-sm">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          (240) 326-7712
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-sm text-gray-300">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          MD, VA and DC Barred
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Founded 2013
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Certified Best Interest Attorneys
        </span>
      </div>
    </div>
  </section>

  <!-- ===================== 2. AFFILIATIONS ===================== -->
  <section class="bg-gray-900 py-10" aria-label="Our Affiliations">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="text-center text-gray-400 text-xs font-semibold uppercase tracking-widest mb-8">Proud Member Of</p>
      <div class="flex flex-wrap items-center justify-center gap-10 md:gap-16">
        <img
          src="https://divorcewithaplan.com/wp-content/uploads/2025/04/Divorce-With-A-Plan-Maryland-Family-Law-Attorneys_Alliance-of-Black-Women-Attorneyswhite.png"
          alt="Alliance of Black Women Attorneys"
          class="h-16 object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        />
        <img
          src="https://divorcewithaplan.com/wp-content/uploads/2025/04/Divorce-With-A-Plan-Maryland-Family-Law-Attorneys_Maryland-State-Bar-Associationwhite.png"
          alt="Maryland State Bar Association"
          class="h-16 object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        />
        <img
          src="https://divorcewithaplan.com/wp-content/uploads/2025/04/Divorce-With-A-Plan-Maryland-Family-Law-Attorneys_Bar-Associations-of-Baltimore-Citywhite.png"
          alt="Bar Association of Baltimore City"
          class="h-16 object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        />
        <img
          src="https://divorcewithaplan.com/wp-content/uploads/2025/04/Divorce-With-A-Plan-Maryland-Family-Law-Attorneys_Anne-Arundel-County-Bar-Associationwhite.png"
          alt="Anne Arundel County Bar Association"
          class="h-16 object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        />
      </div>
    </div>
  </section>

  <!-- ===================== 3. WHAT WE DO — 8 SERVICE CARDS ===================== -->
  <section class="py-20 bg-gray-50" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">What We Do</p>
        <h2 id="services-heading" class="section-heading mb-4">Comprehensive Family Law Representation</h2>
        <p class="text-gray-600 max-w-2xl mx-auto leading-relaxed">
          From contested custody battles to complex high-asset divorces, our Maryland attorneys provide the strategic advocacy your family deserves across all eight practice areas.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <!-- Card 1: Child Custody -->
        <a href="/child-custody" class="group bg-white border-b-4 border-transparent hover:border-gold p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
          <div class="mb-4">
            <img src="/images/icon-child-custody.png" alt="Child Custody" class="w-16 h-16" />
          </div>
          <h3 class="font-serif text-lg font-bold text-teal mb-2 group-hover:text-gold transition-colors">Child Custody</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Strategic custody representation for mothers and fathers. We fight for parenting plans that serve your children and protect your parental rights.</p>
          <span class="inline-block mt-4 text-teal text-sm font-semibold group-hover:text-gold transition-colors">Learn more &rarr;</span>
        </a>

        <!-- Card 2: Child Custody Modification -->
        <a href="/child-custody-modification" class="group bg-white border-b-4 border-transparent hover:border-gold p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
          <div class="mb-4">
            <img src="/images/icon-custody-modification.png" alt="Custody Modification" class="w-16 h-16" />
          </div>
          <h3 class="font-serif text-lg font-bold text-teal mb-2 group-hover:text-gold transition-colors">Child Custody Modification</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Life changes. When circumstances shift, we help you modify existing custody orders to reflect your family's new reality and your children's evolving needs.</p>
          <span class="inline-block mt-4 text-teal text-sm font-semibold group-hover:text-gold transition-colors">Learn more &rarr;</span>
        </a>

        <!-- Card 3: Divorce -->
        <a href="/divorce" class="group bg-white border-b-4 border-transparent hover:border-gold p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
          <div class="mb-4">
            <img src="/images/icon-divorce.png" alt="Divorce" class="w-16 h-16" />
          </div>
          <h3 class="font-serif text-lg font-bold text-teal mb-2 group-hover:text-gold transition-colors">Divorce</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Strategic divorce representation from filing through final judgment. We protect your rights in both contested and uncontested matters throughout Maryland.</p>
          <span class="inline-block mt-4 text-teal text-sm font-semibold group-hover:text-gold transition-colors">Learn more &rarr;</span>
        </a>

        <!-- Card 4: Asset Division -->
        <a href="/asset-division" class="group bg-white border-b-4 border-transparent hover:border-gold p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
          <div class="mb-4">
            <img src="/images/icon-asset-division.png" alt="Asset Division" class="w-16 h-16" />
          </div>
          <h3 class="font-serif text-lg font-bold text-teal mb-2 group-hover:text-gold transition-colors">Asset Division</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Maryland equitable distribution law is not a 50/50 guarantee. Our attorneys fight to ensure the division of marital property is truly fair to you.</p>
          <span class="inline-block mt-4 text-teal text-sm font-semibold group-hover:text-gold transition-colors">Learn more &rarr;</span>
        </a>

        <!-- Card 5: High Net Worth Divorce -->
        <a href="/high-net-worth-divorce" class="group bg-white border-b-4 border-transparent hover:border-gold p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
          <div class="mb-4">
            <img src="/images/icon-high-net-worth.png" alt="High Net Worth Divorce" class="w-16 h-16" />
          </div>
          <h3 class="font-serif text-lg font-bold text-teal mb-2 group-hover:text-gold transition-colors">High Net Worth Divorce</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Complex, high-stakes divorces demand specialized expertise. We protect your wealth, investments, business interests, and financial legacy with absolute discretion.</p>
          <span class="inline-block mt-4 text-teal text-sm font-semibold group-hover:text-gold transition-colors">Learn more &rarr;</span>
        </a>

        <!-- Card 6: Spousal Support -->
        <a href="/spousal-support" class="group bg-white border-b-4 border-transparent hover:border-gold p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
          <div class="mb-4">
            <img src="/images/icon-spousal-support.png" alt="Spousal Support" class="w-16 h-16" />
          </div>
          <h3 class="font-serif text-lg font-bold text-teal mb-2 group-hover:text-gold transition-colors">Spousal Support</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Whether seeking alimony or defending against an unjust award, we build strategic, evidence-backed cases that advocate powerfully for your financial future.</p>
          <span class="inline-block mt-4 text-teal text-sm font-semibold group-hover:text-gold transition-colors">Learn more &rarr;</span>
        </a>

        <!-- Card 7: Divorce for Professionals -->
        <a href="/divorce-lawyer-for-professionals" class="group bg-white border-b-4 border-transparent hover:border-gold p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
          <div class="mb-4">
            <img src="/images/icon-professionals-divorce.png" alt="Divorce for Professionals" class="w-16 h-16" />
          </div>
          <h3 class="font-serif text-lg font-bold text-teal mb-2 group-hover:text-gold transition-colors">Divorce for Professionals</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Doctors, executives, and professionals face unique divorce challenges. Our team understands your career, income structures, licensing risks, and professional reputation.</p>
          <span class="inline-block mt-4 text-teal text-sm font-semibold group-hover:text-gold transition-colors">Learn more &rarr;</span>
        </a>

        <!-- Card 8: Business Divorce -->
        <a href="/divorces-involving-businesses" class="group bg-white border-b-4 border-transparent hover:border-gold p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
          <div class="mb-4">
            <img src="/images/icon-business-divorce.png" alt="Business Divorce" class="w-16 h-16" />
          </div>
          <h3 class="font-serif text-lg font-bold text-teal mb-2 group-hover:text-gold transition-colors">Business Divorce</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Business ownership in a marriage creates complex legal issues. We untangle ownership, valuation, goodwill, and distribution challenges to protect what you built.</p>
          <span class="inline-block mt-4 text-teal text-sm font-semibold group-hover:text-gold transition-colors">Learn more &rarr;</span>
        </a>

      </div>
      <div class="text-center mt-10">
        <a href="/services" class="btn-outline-teal">View All Practice Areas</a>
      </div>
    </div>
  </section>

  <!-- ===================== 4. WHY CHOOSE US — 6 FEATURE CARDS ===================== -->
  <section class="py-20 bg-teal" aria-labelledby="why-us-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Why Choose Us</p>
        <h2 id="why-us-heading" class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">A Different Kind of Family Law Firm</h2>
        <p class="text-teal-100 max-w-2xl mx-auto leading-relaxed">We combine legal excellence with genuine empathy, because we understand that every case is a family life.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">

        <!-- Feature 1: Experienced -->
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 mb-4">
            <img src="/images/icon-experienced.png" alt="Experienced" class="w-12 h-12" />
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Strategy-First Approach</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Every representation begins with a comprehensive strategy session. We do not react to circumstances, we shape them. Our PROMISE Framework ensures every case is handled with intention.</p>
        </div>

        <!-- Feature 2: Strategic -->
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 mb-4">
            <img src="/images/icon-strategic.png" alt="Strategic" class="w-12 h-12" />
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">4 Experienced Attorneys</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Our team of four licensed attorneys, including two Certified Best Interest Attorneys, brings diverse expertise across family law, civil litigation, corporate law, and legal aid representation.</p>
        </div>

        <!-- Feature 3: Compassionate -->
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 mb-4">
            <img src="/images/icon-compassionate.png" alt="Compassionate" class="w-12 h-12" />
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Compassionate Advocacy</h3>
          <p class="text-teal-100 text-sm leading-relaxed">We fight hard in the courtroom while treating clients with the dignity, respect, and empathy their situation demands. Your family is not a case number to us.</p>
        </div>

        <!-- Feature 4: Results -->
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 mb-4">
            <img src="/images/icon-results.png" alt="Results" class="w-12 h-12" />
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Deep Legal Expertise</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Our attorneys bring backgrounds in legal aid, government service, corporate law, and private practice, a rare combination that gives our clients a comprehensive legal advantage.</p>
        </div>

        <!-- Feature 5: Available -->
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 mb-4">
            <img src="/images/icon-available.png" alt="Available" class="w-12 h-12" />
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Two Convenient Offices</h3>
          <p class="text-teal-100 text-sm leading-relaxed">With offices in Rockville and Baltimore, we are accessible to clients throughout Maryland's most populated corridors. Virtual consultations are also available.</p>
        </div>

        <!-- Feature 6: Affordable -->
        <div class="bg-white bg-opacity-10 p-6 rounded-sm border border-white border-opacity-20">
          <div class="w-12 h-12 mb-4">
            <img src="/images/icon-affordable.png" alt="Affordable" class="w-12 h-12" />
          </div>
          <h3 class="font-serif text-xl font-bold text-white mb-2">Certified Best Interest Attorneys</h3>
          <p class="text-teal-100 text-sm leading-relaxed">Two of our attorneys hold the Maryland Certified Best Interest Attorney credential, a specialized certification to represent children in contested custody proceedings.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== 5. OUR LEGAL TEAM ===================== -->
  <section class="py-20 bg-gray-50" aria-labelledby="attorneys-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Our Legal Team</p>
        <h2 id="attorneys-heading" class="section-heading mb-4">Experienced Maryland Family Law Attorneys</h2>
        <p class="text-gray-600 max-w-2xl mx-auto leading-relaxed">Meet the dedicated legal professionals who will stand beside you every step of the way. Founded in 2013, our team brings compassionate, strategic representation to every case.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">

        <!-- Monique Nettleford-Bruce -->
        <div class="bg-white shadow-md p-6 border-t-4 border-teal text-center">
          <div class="w-16 h-16 bg-teal rounded-full flex items-center justify-center mb-4 text-white font-serif text-xl font-bold mx-auto">MN</div>
          <h3 class="font-serif text-lg font-bold text-teal mb-1">Monique Nettleford-Bruce</h3>
          <p class="text-gold font-semibold text-xs mb-3 uppercase tracking-wide">Senior Attorney</p>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">J.D., American University Washington College of Law. Former Maryland Legal Aid staff attorney representing clients in housing, custody, divorce, and public benefits matters. Barred in MD and VA.</p>
          <a href="/attorneys" class="text-teal font-semibold text-sm hover:text-gold transition-colors">Full Bio &rarr;</a>
        </div>

        <!-- Aysia Stockton -->
        <div class="bg-white shadow-md p-6 border-t-4 border-teal text-center">
          <div class="w-16 h-16 bg-teal rounded-full flex items-center justify-center mb-4 text-white font-serif text-xl font-bold mx-auto">AS</div>
          <h3 class="font-serif text-lg font-bold text-teal mb-1">Aysia Stockton</h3>
          <p class="text-gold font-semibold text-xs mb-3 uppercase tracking-wide">Senior Attorney</p>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">J.D., Appalachian School of Law (2020). B.S. in Criminal Justice, Clark Atlanta University. Former Deputy Clerk, Richmond General District Court. Barred in MD and DC.</p>
          <a href="/attorneys" class="text-teal font-semibold text-sm hover:text-gold transition-colors">Full Bio &rarr;</a>
        </div>

        <!-- Stephen Lincoln -->
        <div class="bg-white shadow-md p-6 border-t-4 border-teal text-center">
          <div class="w-16 h-16 bg-teal rounded-full flex items-center justify-center mb-4 text-white font-serif text-xl font-bold mx-auto">SL</div>
          <h3 class="font-serif text-lg font-bold text-teal mb-1">Stephen Lincoln</h3>
          <p class="text-gold font-semibold text-xs mb-3 uppercase tracking-wide">Associate Attorney</p>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">J.D., DePaul University College of Law. B.A., University of Wisconsin-Madison. Admitted to Practice Law in Maryland &amp; Illinois.</p>
          <a href="/attorneys" class="text-teal font-semibold text-sm hover:text-gold transition-colors">Full Bio &rarr;</a>
        </div>

        <!-- Paola Rodriguez -->
        <div class="bg-white shadow-md p-6 border-t-4 border-teal text-center">
          <div class="w-16 h-16 bg-teal rounded-full flex items-center justify-center mb-4 text-white font-serif text-xl font-bold mx-auto">PR</div>
          <h3 class="font-serif text-lg font-bold text-teal mb-1">Paola Rodriguez</h3>
          <p class="text-gold font-semibold text-xs mb-3 uppercase tracking-wide">Attorney</p>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">J.D., University of the District of Columbia, David A. Clarke School of Law. Dedicated advocate bringing skilled family law representation to clients throughout Maryland.</p>
          <a href="/attorneys" class="text-teal font-semibold text-sm hover:text-gold transition-colors">Full Bio &rarr;</a>
        </div>

      </div>
      <div class="text-center mt-10">
        <a href="/attorneys" class="btn-outline-teal">Meet Our Full Team</a>
      </div>
    </div>
  </section>

  <!-- ===================== 6. OFFICE LOCATIONS ===================== -->
  <section class="py-20 bg-white" aria-labelledby="locations-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Find Us</p>
        <h2 id="locations-heading" class="section-heading mb-4">Two Offices Serving All of Maryland</h2>
        <p class="text-gray-600 max-w-2xl mx-auto leading-relaxed">Visit us at our Rockville or Baltimore office, or schedule a virtual consultation. Our attorneys serve clients throughout Montgomery County, Baltimore, Howard County, and all of Maryland.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-10">

        <!-- Rockville Office -->
        <div class="bg-white shadow-md rounded-sm overflow-hidden">
          <div class="bg-teal text-white p-6">
            <h3 class="font-serif text-2xl font-bold mb-1">Rockville Office</h3>
            <p class="text-gold font-semibold text-sm uppercase tracking-wide mb-4">Montgomery County</p>
            <address class="not-italic text-teal-100 leading-relaxed mb-4">
              100 Park Ave Suite 205<br />
              Rockville, MD 20850
            </address>
            <div class="space-y-2 text-sm text-teal-100 mb-5">
              <p class="flex items-center gap-2">
                <svg class="w-4 h-4 text-gold flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                </svg>
                <a href="tel:+12403267712" class="hover:text-white transition-colors">(240) 326-7712</a>
              </p>
              <p class="flex items-center gap-2">
                <svg class="w-4 h-4 text-gold flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                </svg>
                Mon - Fri: 9AM - 9PM
              </p>
            </div>
            <div class="flex gap-3">
              <a href="/contact" class="inline-block bg-gold text-white px-5 py-2.5 text-sm font-semibold uppercase tracking-wide hover:bg-yellow-600 transition-colors rounded-sm">Schedule Visit</a>
