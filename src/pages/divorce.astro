---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Maryland Divorce Attorneys | Divorce With A Plan"
  description="Experienced Maryland divorce attorneys serving Rockville, Baltimore, Howard County, and Montgomery County. Strategic, plan-based divorce representation since 2013. Call (240) 269-3592."
  ogTitle="Maryland Divorce Attorneys | Divorce With A Plan"
  ogDescription="Strategic divorce representation in Maryland since 2013. Serving Rockville, Baltimore, and surrounding counties. Call today for a free consultation."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 to-slate-700 text-white py-20 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-amber-400 uppercase tracking-widest text-sm font-semibold mb-3">Maryland Divorce Attorneys</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        Divorce Doesn't Have to Mean Disorder.<br class="hidden md:block" />
        We Give You a Plan.
      </h1>
      <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto mb-8">
        Since 2013, Divorce With A Plan has helped Maryland residents navigate divorce with clarity, strategy, and confidence. Our attorneys combine legal expertise with genuine compassion — so you know exactly what to expect, every step of the way.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-consultation" class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 px-8 rounded-lg transition-colors">
          Schedule Free Consultation
        </a>
        <a href="tel:2402693592" class="border-2 border-white hover:bg-white hover:text-slate-900 text-white font-bold py-3 px-8 rounded-lg transition-colors">
          Call (240) 269-3592
        </a>
      </div>
    </div>
  </section>

  <!-- What Is Divorce in Maryland -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-slate-900 mb-5">Understanding Divorce in Maryland</h2>
          <p class="text-slate-600 mb-4">
            Maryland law has undergone significant changes in recent years. As of October 2023, Maryland now offers <strong>absolute divorce</strong> based on a 6-month separation or mutual consent — eliminating many of the old fault-based hurdles that complicated the process.
          </p>
          <p class="text-slate-600 mb-4">
            However, even with simplified grounds, divorce still involves critical decisions about <strong>property division, spousal support, child custody, and child support</strong>. Getting these decisions wrong can have lasting financial and personal consequences.
          </p>
          <p class="text-slate-600">
            That's why having an experienced Maryland divorce attorney isn't just helpful — it's essential. Our team at Divorce With A Plan has handled hundreds of cases across Montgomery County, Howard County, Baltimore, and surrounding areas.
          </p>
        </div>
        <div class="bg-slate-50 rounded-2xl p-8">
          <h3 class="text-xl font-bold text-slate-900 mb-4">Divorce Grounds in Maryland</h3>
          <ul class="space-y-3">
            {[
              "6-month separation (no-fault)",
              "Mutual consent (no-fault)",
              "Adultery",
              "Cruelty or excessively vicious conduct",
              "Constructive desertion",
              "Conviction of a crime"
            ].map(ground => (
              <li class="flex items-start gap-3">
                <span class="text-amber-500 font-bold mt-0.5">✓</span>
                <span class="text-slate-700">{ground}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Divorce Services -->
  <section class="py-16 px-4 bg-slate-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">Our Divorce Legal Services</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">From straightforward uncontested divorces to complex, high-asset litigation — we handle it all with precision and discretion.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            title: "Uncontested Divorce",
            desc: "When both spouses agree on all major terms, we help you finalize your divorce efficiently, correctly, and without unnecessary delay.",
            icon: "📋"
          },
          {
            title: "Contested Divorce",
            desc: "When disagreements arise over property, custody, or support, our trial-ready attorneys advocate fiercely for your interests in court.",
            icon: "⚖️"
          },
          {
            title: "High-Asset Divorce",
            desc: "Protecting complex portfolios, business interests, retirement accounts, and real estate requires specialized legal strategy.",
            icon: "🏛️"
          },
          {
            title: "Divorce for Professionals",
            desc: "Doctors, executives, and business owners face unique divorce challenges. We understand how professional income and assets are treated.",
            icon: "💼"
          },
          {
            title: "Child Custody & Support",
            desc: "We help parents develop parenting plans that protect their children's best interests and secure appropriate support arrangements.",
            icon: "👨‍👧"
          },
          {
            title: "Spousal Support",
            desc: "Whether seeking or contesting alimony, our attorneys build evidence-based arguments grounded in Maryland law.",
            icon: "💰"
          }
        ].map(service => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100">
            <div class="text-3xl mb-3">{service.icon}</div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{service.title}</h3>
            <p class="text-slate-600 text-sm">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Divorce Process -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">The Maryland Divorce Process</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">We walk you through every stage — no surprises, no confusion.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { step: "01", title: "Initial Consultation", desc: "We assess your situation, explain your options, and begin forming your strategy." },
          { step: "02", title: "Filing & Service", desc: "We prepare and file your divorce complaint and properly serve your spouse." },
          { step: "03", title: "Discovery & Negotiation", desc: "We gather financial records and negotiate a fair settlement on your behalf." },
          { step: "04", title: "Resolution", desc: "We finalize your divorce through settlement agreement or trial representation." }
        ].map(item => (
          <div class="text-center">
            <div class="w-16 h-16 bg-amber-500 text-white text-xl font-bold rounded-full flex items-center justify-center mx-auto mb-4">{item.step}</div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{item.title}</h3>
            <p class="text-slate-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 px-4 bg-slate-900 text-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4">Why Maryland Clients Choose Divorce With A Plan</h2>
        <p class="text-slate-300 max-w-2xl mx-auto">We've built a reputation for strategic, client-centered divorce representation across Maryland.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {[
          { title: "Founded in 2013", desc: "Over a decade of Maryland family law experience, with hundreds of cases resolved for clients across the state." },
          { title: "Certified Best Interest Attorneys", desc: "Josephia Rouse and Massa Massaquoi-King hold BIA certifications — a rare credential demonstrating deep expertise in family court." },
          { title: "High-Asset Case Experience", desc: "Massa Massaquoi-King has successfully tried contested divorce cases exceeding $2 million in marital assets." },
          { title: "Statewide Maryland Representation", desc: "We serve Montgomery County, Baltimore City & County, Howard County, Prince George's County, Anne Arundel County, and beyond." }
        ].map(item => (
          <div class="flex gap-4">
            <div class="text-amber-400 text-2xl mt-1">★</div>
            <div>
              <h3 class="text-lg font-bold mb-2">{item.title}</h3>
              <p class="text-slate-300 text-sm">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Counties Served -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-slate-900 mb-6">Serving Clients Across Maryland</h2>
      <p class="text-slate-600 mb-8 max-w-2xl mx-auto">Our Rockville and Baltimore offices allow us to conveniently serve clients throughout the greater Maryland area.</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          "Montgomery County", "Baltimore City", "Baltimore County", "Howard County",
          "Prince George's County", "Anne Arundel County", "Frederick County",
          "Carroll County", "Harford County", "Charles County"
        ].map(county => (
          <span class="bg-slate-100 text-slate-700 px-4 py-2 rounded-full text-sm font-medium">{county}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4 bg-amber-500">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Start Your Divorce With A Plan?</h2>
      <p class="text-amber-100 mb-8 text-lg">Your first consultation is free. Let's talk through your situation and build a strategy together.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-consultation" class="bg-white text-amber-600 hover:bg-amber-50 font-bold py-3 px-8 rounded-lg transition-colors">
          Book Free Consultation
        </a>
        <a href="tel:2402693592" class="border-2 border-white text-white hover:bg-amber-600 font-bold py-3 px-8 rounded-lg transition-colors">
          (240) 269-3592
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
