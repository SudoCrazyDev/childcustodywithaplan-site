---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const promiseSteps = [
  {
    letter: 'P',
    word: 'Protect',
    color: 'bg-[#0D6E6E]',
    description: 'Your immediate wellbeing and rights are our first priority. From the moment you become a client, we take swift action to protect your interests, stabilize your situation, and prevent adverse developments.',
    actions: [
      'Emergency filing and protective orders when necessary',
      'Securing access to financial accounts and marital assets',
      'Establishing interim custody and support arrangements',
      'Advising on immediate steps to preserve your legal position',
    ],
  },
  {
    letter: 'R',
    word: 'Represent',
    color: 'bg-[#0F8080]',
    description: 'Skilled, fierce advocacy is at the heart of what we do. Whether in the courtroom, at the negotiating table, or in mediation, our attorneys represent you with tenacity, preparation, and strategic thinking.',
    actions: [
      'Courtroom litigation and trial preparation',
      'Negotiations with opposing counsel',
      'Representation in mediation and collaborative proceedings',
      'Motion practice and evidentiary hearings',
    ],
  },
  {
    letter: 'O',
    word: 'Organize',
    color: 'bg-[#D4A843]',
    description: 'Winning family law cases requires meticulous preparation. We systematically gather, organize, and analyze all relevant evidence, financial records, communications, and documentation.',
    actions: [
      'Financial disclosure review and analysis',
      'Document discovery and production',
      'Witness identification and preparation',
      'Expert coordination (forensic accountants, custody evaluators)',
    ],
  },
  {
    letter: 'M',
    word: 'Mediate',
    color: 'bg-[#B8902E]',
    description: 'When resolution outside the courtroom serves your interests, we pursue it strategically. Our attorneys are skilled negotiators who understand when settlement is the right move — and how to achieve it on favorable terms.',
    actions: [
      'Settlement negotiation strategy',
      'Formal mediation preparation and representation',
      'Drafting comprehensive settlement agreements',
      'Collaborative divorce options when appropriate',
    ],
  },
  {
    letter: 'I',
    word: 'Implement',
    color: 'bg-[#095555]',
    description: 'Strategy means nothing without precise execution. We implement your legal plan with the highest level of professionalism — filing the right motions, meeting every deadline, and presenting compelling arguments.',
    actions: [
      'Court filing and procedural compliance',
      'Discovery requests and responses',
      'Deposition preparation and coordination',
      'Trial presentation and evidence submission',
    ],
  },
  {
    letter: 'S',
    word: 'Support',
    color: 'bg-[#0D6E6E]',
    description: 'Family law cases can be emotionally exhausting. We provide consistent communication, honest case updates, and genuine emotional support throughout — because you deserve to feel informed and supported at every turn.',
    actions: [
      'Regular case status updates',
      'Prompt responses to your questions and concerns',
      'Clear explanations of legal developments',
      'Referrals to counseling and support resources as needed',
    ],
  },
  {
    letter: 'E',
    word: 'Empower',
    color: 'bg-[#0F8080]',
    description: 'The end of your case is the beginning of your next chapter. We close every matter by ensuring you fully understand your rights, your obligations, and how to protect your family\'s wellbeing going forward.',
    actions: [
      'Plain-language explanation of all court orders',
      'Guidance on compliance and enforcement',
      'Advice on future modification rights',
      'Post-judgment support and follow-up representation',
    ],
  },
];

const processSteps = [
  {
    step: '01',
    title: 'Free Initial Consultation',
    description: 'We begin with a confidential consultation where we learn about your situation, your goals, and the specific challenges you\'re facing. This allows us to assess your case and explain your legal options clearly.',
  },
  {
    step: '02',
    title: 'Case Assessment & Strategy',
    description: 'Based on your consultation, we develop a tailored legal strategy aligned with your goals. We identify strengths and challenges in your case and map out the most effective path forward.',
  },
  {
    step: '03',
    title: 'Engagement & Case Preparation',
    description: 'Once retained, we move quickly to gather documents, file necessary motions, and take any immediate protective steps. You\'ll receive a clear explanation of the process timeline and what to expect.',
  },
  {
    step: '04',
    title: 'Active Advocacy',
    description: 'We represent you through every phase — negotiations, hearings, mediation, and if necessary, trial. You\'ll be informed and prepared at every step, with consistent communication from our team.',
  },
  {
    step: '05',
    title: 'Resolution & Implementation',
    description: 'When your case resolves — through settlement, consent order, or court judgment — we ensure the agreement is properly documented, understood, and enforceable.',
  },
  {
    step: '06',
    title: 'Post-Resolution Support',
    description: 'Our relationship doesn\'t end when your case does. We\'re here for modifications, enforcement matters, and any future family law needs that arise.',
  },
];
---

<BaseLayout
  title="Our Process | The PROMISE Framework | Child Custody with a Plan"
  description="Learn about our client-first PROMISE Framework and step-by-step legal process. Child Custody with a Plan provides structured, transparent family law representation throughout Maryland."
>

  <Hero
    subtitle="How We Work"
    title="A Plan for Every Step of Your Case"
    description="We believe the best legal outcomes come from careful preparation, strategic thinking, and consistent communication. Our PROMISE Framework gives you a clear roadmap from day one."
    primaryCta={{ label: "Start with a Free Consultation", href: "/contact" }}
    secondaryCta={{ label: "Meet Our Attorneys", href: "/attorneys" }}
    variant="compact"
  />

  <!-- PROMISE Overview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">Our Methodology</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">The PROMISE Framework</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg leading-relaxed">
          Every client who comes to us deserves more than legal advice — they deserve a plan. The PROMISE Framework is our structured, 7-step approach to delivering consistent, transparent, client-first legal representation.
        </p>
      </div>

      <!-- Letter Blocks -->
      <div class="flex flex-wrap justify-center gap-3 mb-16">
        {promiseSteps.map(step => (
          <div class={`${step.color} text-white rounded-xl w-16 h-16 flex flex-col items-center justify-center shadow-md`}>
            <span class="font-serif font-bold text-2xl leading-none">{step.letter}</span>
            <span class="text-xs mt-0.5 opacity-80">{step.word}</span>
          </div>
        ))}
      </div>

      <!-- Detailed Steps -->
      <div class="space-y-10">
        {promiseSteps.map((step, index) => (
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <div class="lg:col-span-1 flex justify-center lg:justify-start pt-1">
              <div class={`${step.color} text-white rounded-xl w-14 h-14 flex flex-col items-center justify-center flex-shrink-0`}>
                <span class="font-serif font-bold text-xl leading-none">{step.letter}</span>
              </div>
            </div>
            <div class="lg:col-span-11">
              <h3 class="text-2xl font-serif font-bold text-[#0D6E6E] mb-3">{step.word}</h3>
              <p class="text-gray-600 leading-relaxed mb-4 text-lg">{step.description}</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {step.actions.map(action => (
                  <div class="flex items-start gap-3 text-sm text-gray-700">
                    <span class="w-2 h-2 rounded-full bg-[#D4A843] flex-shrink-0 mt-1.5"></span>
                    {action}
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Step-by-Step Process -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">From Start to Finish</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">Your Case, Step by Step</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          Here's what you can expect when you work with our firm — from your first call to final resolution.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {processSteps.map(item => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
            <div class="text-5xl font-serif font-bold text-[#0D6E6E]/20 mb-4 leading-none">{item.step}</div>
            <h3 class="text-xl font-serif font-bold text-[#0D6E6E] mb-3">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Client Commitments -->
  <section class="py-20 bg-[#0D6E6E]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">Our Commitments to You</p>
        <h2 class="text-4xl font-serif font-bold text-white mb-4">What You Can Always Expect From Us</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '📞', title: 'Responsive Communication', desc: 'We return calls and emails promptly. You\'ll never feel out of the loop on your own case.' },
          { icon: '🎯', title: 'Strategic Thinking', desc: 'Every decision we make is intentional and aligned with your specific goals and circumstances.' },
          { icon: '🔍', title: 'Complete Transparency', desc: 'No surprises. We explain your options, the risks, and the costs clearly and honestly.' },
          { icon: '💪', title: 'Fierce Advocacy', desc: 'In the courtroom and at the negotiating table, we fight hard for the outcomes you deserve.' },
        ].map(item => (
          <div class="bg-white/10 border border-white/20 rounded-xl p-6 text-center">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="text-white font-serif font-bold text-lg mb-2">{item.title}</h3>
            <p class="text-white/70 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-serif font-bold text-[#0D6E6E] mb-4">Ready to Build Your Plan?</h2>
      <p class="text-gray-600 text-lg mb-8">
        Your first consultation is free. Let's start building a strategy tailored to your family's needs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-[#D4A843] text-white font-bold px-10 py-4 rounded hover:bg-[#B8902E] transition-colors">
          Schedule Free Consultation
        </a>
        <a href="/services" class="border-2 border-[#0D6E6E] text-[#0D6E6E] font-semibold px-10 py-4 rounded hover:bg-[#0D6E6E] hover:text-white transition-colors">
          View Practice Areas
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
