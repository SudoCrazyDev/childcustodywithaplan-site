---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const attorneys = [
  {
    name: 'Josephia Rouse, Esq.',
    initials: 'JR',
    role: 'Founding Attorney & Managing Partner',
    award: '2025 Elite Lawyer Award',
    bio: [
      'Josephia Rouse is the founder and managing partner of both Child Custody with a Plan and Divorce with a Plan — sister practices serving families across Maryland from offices in Rockville and Baltimore.',
      "Josephia built her practice on a conviction that changed her entire approach to family law: families don't just need lawyers — they need strategists. This insight led to the creation of the PROMISE Framework™, a proprietary 7-step methodology that guides every client engagement from initial intake through final resolution.",
      "A recipient of the prestigious 2025 Elite Lawyer Award, Josephia has been recognized for her exceptional client service, legal acumen, and transformative approach to Maryland family law. Her reputation for strategic thinking and compassionate advocacy has made her one of Maryland's most trusted names in child custody and divorce representation.",
      "Josephia is deeply committed to her community, working to change how Maryland families view and navigate divorce and custody transitions — from sources of shame and fear into opportunities for strategic new beginnings.",
    ],
    specialties: ['Child Custody Strategy', 'High Net Worth Divorce', 'PROMISE Framework™', 'Spousal Support', 'Divorce for Professionals', 'Business Divorce'],
    officeLocation: 'Rockville & Baltimore',
  },
  {
    name: 'Massa Massaquoi-King, Esq.',
    initials: 'MM',
    role: 'Associate Attorney',
    award: 'Child Custody Specialist',
    bio: [
      'Massa Massaquoi-King is a dedicated family law attorney with a particular focus on child custody disputes and parenting plan development in Maryland. She brings a thoughtful, methodical approach to every case, applying the PROMISE Framework™ with precision to help parents navigate difficult custody situations.',
      'Massa understands that child custody proceedings are among the most emotionally charged legal matters a parent will ever face. She combines legal expertise with genuine empathy, ensuring clients feel heard, supported, and strategically represented at every stage.',
      "Her practice spans the full range of child custody matters — from initial determinations and parenting plan negotiations to contested custody trials and post-divorce modifications. Massa is particularly skilled at presenting compelling evidence of a client's parental fitness and advocating for arrangements that truly serve children's best interests.",
    ],
    specialties: ['Child Custody', 'Parenting Plans', 'Contested Custody', 'Custody Modification', 'Mediation', 'Best Interests Advocacy'],
    officeLocation: 'Baltimore & Rockville',
  },
  {
    name: 'Monique Nettleford-Bruce, Esq.',
    initials: 'MN',
    role: 'Associate Attorney',
    award: 'Family Law Advocate',
    bio: [
      'Monique Nettleford-Bruce is a passionate family law advocate whose practice encompasses the full spectrum of divorce and family law matters in Maryland. She brings a strategic, solutions-oriented approach to every case, with particular strength in asset division, spousal support, and complex contested divorce proceedings.',
      "Monique's commitment to her clients goes beyond the courtroom. She works tirelessly to ensure that clients understand not just their legal options, but the strategic implications of each path — empowering them to make informed, confident decisions during one of life's most challenging transitions.",
      'As part of the Child Custody with a Plan and Divorce with a Plan team, Monique upholds the firm\'s core belief that every Maryland family deserves more than reactive legal representation — they deserve a comprehensive plan built around their goals and their children\'s futures.',
    ],
    specialties: ['Divorce', 'Asset Division', 'Spousal Support', 'Contested Divorce', 'Property Division', 'Equitable Distribution'],
    officeLocation: 'Baltimore & Rockville',
  },
  {
    name: 'Aysia Stockton, Esq.',
    initials: 'AS',
    role: 'Associate Attorney',
    award: 'Strategic Planner',
    bio: [
      "Aysia Stockton brings a sharp analytical mind and a collaborative approach to family law that has made her an integral member of the Child Custody with a Plan and Divorce with a Plan team. Her practice focuses on developing strategic legal solutions for clients navigating divorce, child custody, and post-judgment matters.",
      'Aysia is particularly adept at navigating complex financial aspects of divorce — including business interests, professional income analysis, and high-asset estate division. Her meticulous preparation and research-driven approach reflect the PROMISE Framework™ at its core.',
      "Committed to client empowerment, Aysia takes time to ensure every client she represents understands the legal process, their rights under Maryland law, and the strategic options available to them. She is a firm believer that an informed client is a stronger client — and that preparation is the foundation of every successful legal outcome.",
    ],
    specialties: ['High Net Worth Divorce', 'Divorce for Professionals', 'Child Custody', 'Business Valuation', 'Post-Judgment Matters', 'Asset Analysis'],
    officeLocation: 'Rockville & Baltimore',
  },
];
---

<BaseLayout
  title="Our Attorneys | Child Custody with a Plan — Maryland Family Law Team"
  description="Meet the women-led attorney team at Child Custody with a Plan: Josephia Rouse (2025 Elite Lawyer Award), Massa Massaquoi-King, Monique Nettleford-Bruce, and Aysia Stockton. Maryland family law specialists."
>
  <!-- Hero -->
  <section class="teal-gradient text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold-400 rounded-full opacity-10 blur-3xl"></div>
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <div class="max-w-3xl">
        <p class="text-gold-400 font-semibold text-sm uppercase tracking-widest mb-3">The Team</p>
        <h1 class="font-serif font-bold text-4xl md:text-5xl text-white leading-tight mb-6">
          Meet Our Women-Led Team of Maryland Family Law Attorneys
        </h1>
        <p class="text-teal-100 text-xl leading-relaxed">
          Four dedicated attorneys. One strategic mission. We're here to protect your parental rights and build a plan for your family's future.
        </p>
      </div>
    </div>
  </section>

  <!-- Attorneys -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="space-y-16">
        {attorneys.map((attorney, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-3 gap-10 items-start ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
            <!-- Attorney Card -->
            <div class="lg:col-span-1">
              <div class="bg-teal-50 rounded-2xl p-8 text-center border border-teal-100 sticky top-28">
                <!-- Avatar -->
                <div class="w-28 h-28 bg-teal-500 rounded-full flex items-center justify-center mx-auto mb-5 border-4 border-gold-400 shadow-lg">
                  <span class="font-serif font-bold text-4xl text-gold-400">{attorney.initials}</span>
                </div>
                <h2 class="font-serif font-bold text-teal-700 text-xl mb-1">{attorney.name}</h2>
                <p class="text-gold-500 font-medium text-sm mb-3">{attorney.role}</p>
                <span class="inline-block bg-teal-500 text-white text-xs font-semibold px-3 py-1 rounded-full mb-5">
                  {attorney.award}
                </span>

                <div class="border-t border-teal-200 pt-4 mt-1">
                  <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-3">Office Locations</p>
                  <p class="text-teal-700 font-medium text-sm">{attorney.officeLocation}</p>
                </div>

                <a href="/free-consultation" class="mt-5 block w-full bg-gold-400 hover:bg-gold-500 text-white font-semibold py-3 rounded-lg text-sm transition-colors text-center">
                  Schedule a Consultation
                </a>
              </div>
            </div>

            <!-- Bio & Specialties -->
            <div class="lg:col-span-2">
              <div class="prose-custom">
                {attorney.bio.map((para) => (
                  <p>{para}</p>
                ))}
              </div>

              <div class="mt-8">
                <h3 class="font-serif font-bold text-teal-700 text-lg mb-4">Areas of Focus</h3>
                <div class="flex flex-wrap gap-2">
                  {attorney.specialties.map((s) => (
                    <span class="bg-teal-50 text-teal-700 text-sm px-4 py-1.5 rounded-full border border-teal-200 font-medium">
                      {s}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team CTA -->
  <section class="py-12 bg-teal-50 border-t border-teal-100">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h2 class="font-serif font-bold text-2xl text-teal-700 mb-4">Ready to Work with Our Team?</h2>
      <p class="text-gray-600 mb-6 max-w-xl mx-auto">Schedule a free consultation and meet the attorney best suited to your case. Available Mon–Fri 9AM–9PM.</p>
      <a href="/free-consultation" class="btn-primary">Schedule Free Consultation</a>
    </div>
  </section>

  <CTASection />
</BaseLayout>
