---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const attorneys = [
  {
    name: 'Monique Nettleford-Bruce',
    title: 'Associate Attorney',
    initials: 'MN',
    tagline: 'Compassionate and strategic — intellect and empathy in every case.',
    bio: [
      'Monique Nettleford-Bruce is a compassionate and strategic family law attorney who brings both intellect and empathy to every case she handles. Originally from Arizona, her life and education have spanned the U.S. and abroad.',
      'Monique earned her J.D. from American University Washington College of Law, where she served as Editor-in-Chief of The Modern American Law Brief — a distinction that speaks to her analytical precision and commitment to legal scholarship.',
      'Prior to joining the firm, Monique served as a Staff Attorney at Maryland Legal Aid, where she represented individuals navigating housing, custody, divorce, and public benefits disputes. This experience gave her an exceptional understanding of the challenges real Maryland families face — and how to fight for them effectively.',
      'Monique graduated magna cum laude with a B.A. in Political Science from the University of Arizona. She is barred in Maryland and Virginia.',
    ],
    credentials: [
      'J.D. — American University Washington College of Law',
      'B.A. in Political Science — University of Arizona (magna cum laude)',
      'Editor-in-Chief, The Modern American Law Brief',
    ],
    barAdmissions: ['Maryland', 'Virginia'],
    priorExperience: ['Staff Attorney — Maryland Legal Aid (housing, custody, divorce, public benefits)'],
    practiceAreas: ['Child Custody', 'Divorce', 'Spousal Support', 'Asset Division', 'Housing Law', 'Public Benefits'],
  },
  {
    name: 'Aysia Stockton',
    title: 'Associate Attorney',
    initials: 'AS',
    tagline: 'Thorough, compassionate advocacy for divorce and custody clients.',
    bio: [
      'Aysia Stockton is originally from Richmond, Virginia. She earned her B.S. in Criminal Justice from Clark Atlanta University, then served as a Deputy Clerk for the Richmond General District Court for two years — gaining valuable firsthand insight into courtroom procedures and the judicial process before ever setting foot in law school.',
      'Aysia attended Appalachian School of Law in Grundy, Virginia, where she earned both a Juris Master\'s degree (M.J., 2018) and her Juris Doctor (J.D., 2020). During law school, she served on the Executive Board of the Black Law Students Association and as a Senior Editor of the Law Journal — reflecting her leadership, scholarly commitment, and advocacy for underrepresented voices in the legal profession.',
      'Shortly after graduating, Aysia passed both the Washington D.C. bar and was admitted to the Maryland bar. She previously practiced at Rusz Legal Services in Edgewater, Maryland, where she was recognized for her compassionate and thorough representation in divorce and custody matters.',
      'Aysia brings a distinctive combination of courtroom familiarity, scholarly rigor, and genuine care to every client she serves.',
    ],
    credentials: [
      'J.D. (2020) — Appalachian School of Law, Grundy, Virginia',
      'Juris Master (M.J., 2018) — Appalachian School of Law',
      'B.S. in Criminal Justice — Clark Atlanta University',
      'Executive Board Member — Black Law Students Association',
      'Senior Editor — Law Journal, Appalachian School of Law',
    ],
    barAdmissions: ['Maryland', 'Washington D.C.'],
    priorExperience: [
      'Associate Attorney — Rusz Legal Services, Edgewater, MD (divorce, custody, child support)',
      'Deputy Clerk — Richmond General District Court, Virginia',
    ],
    practiceAreas: ['Child Custody', 'Divorce', 'Child Support', 'Custody Modification', 'Family Law'],
  },
];
---

<BaseLayout
  title="Our Attorneys | Child Custody with a Plan | Maryland Family Law Team"
  description="Meet the associate attorneys at Child Custody with a Plan — Monique Nettleford-Bruce and Aysia Stockton. Skilled, compassionate Maryland family law attorneys serving clients in custody, divorce, and family law matters."
>

  <Hero
    subtitle="Our Legal Team"
    title="Attorneys Who Fight for Maryland Families"
    description="Our associate attorneys bring diverse legal backgrounds, real courtroom experience, and a shared commitment to strategic, compassionate family law representation throughout Maryland."
    primaryCta={{ label: "Schedule a Consultation", href: "/contact" }}
    secondaryCta={{ label: "View Practice Areas", href: "/services" }}
    variant="compact"
  />

  <!-- Attorney Profiles -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">The Team</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">Meet Our Associate Attorneys</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          Every attorney at our firm is committed to the PROMISE Framework — providing structured, transparent, client-first family law representation.
        </p>
      </div>

      <div class="space-y-20">
        {attorneys.map((attorney, index) => (
          <article class={`grid grid-cols-1 lg:grid-cols-3 gap-10 ${index % 2 !== 0 ? 'lg:grid-flow-dense' : ''}`}>

            <!-- Sidebar Card -->
            <div class={`lg:col-span-1 ${index % 2 !== 0 ? 'lg:col-start-3' : ''}`}>
              <div class="bg-[#0D6E6E] rounded-2xl p-8 text-white sticky top-28">
                <div class="w-20 h-20 rounded-full bg-white/20 flex items-center justify-center mb-5 mx-auto">
                  <span class="text-3xl font-serif font-bold text-white">{attorney.initials}</span>
                </div>
                <h3 class="text-xl font-serif font-bold text-center mb-1">{attorney.name}</h3>
                <p class="text-[#D4A843] text-sm font-semibold text-center mb-5">{attorney.title}</p>
                <p class="text-white/80 text-sm text-center italic mb-6">"{attorney.tagline}"</p>

                <div class="space-y-4">
                  <!-- Bar Admissions -->
                  <div>
                    <h4 class="text-[#D4A843] font-bold text-xs uppercase tracking-wider mb-2">Bar Admissions</h4>
                    <ul class="space-y-1">
                      {attorney.barAdmissions.map(bar => (
                        <li class="flex items-center gap-2 text-sm text-white/80">
                          <span class="w-1.5 h-1.5 rounded-full bg-[#D4A843] flex-shrink-0"></span>
                          {bar}
                        </li>
                      ))}
                    </ul>
                  </div>

                  <!-- Practice Areas -->
                  <div>
                    <h4 class="text-[#D4A843] font-bold text-xs uppercase tracking-wider mb-2">Practice Areas</h4>
                    <div class="flex flex-wrap gap-2">
                      {attorney.practiceAreas.map(area => (
                        <span class="bg-white/10 text-white/80 text-xs px-2.5 py-1 rounded-full">{area}</span>
                      ))}
                    </div>
                  </div>
                </div>

                <a href="/contact" class="mt-6 block w-full bg-[#D4A843] text-white text-center font-semibold py-3 rounded hover:bg-[#B8902E] transition-colors text-sm">
                  Schedule a Consultation
                </a>
              </div>
            </div>

            <!-- Main Bio Content -->
            <div class="lg:col-span-2">
              <div class="mb-4">
                <h2 class="text-3xl font-serif font-bold text-[#0D6E6E] mb-1">{attorney.name}</h2>
                <p class="text-[#D4A843] font-semibold">{attorney.title}</p>
              </div>

              <div class="space-y-4 text-gray-600 leading-relaxed mb-8">
                {attorney.bio.map(paragraph => (
                  <p>{paragraph}</p>
                ))}
              </div>

              <!-- Education & Credentials -->
              <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 mb-6">
                <h4 class="text-[#0D6E6E] font-bold text-sm uppercase tracking-wider mb-4 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                  </svg>
                  Education &amp; Credentials
                </h4>
                <ul class="space-y-2">
                  {attorney.credentials.map(cred => (
                    <li class="flex items-start gap-3 text-sm text-gray-700">
                      <span class="w-2 h-2 rounded-full bg-[#D4A843] flex-shrink-0 mt-1.5"></span>
                      {cred}
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Prior Experience -->
              <div class="bg-gray-50 rounded-xl border border-gray-200 p-6">
                <h4 class="text-[#0D6E6E] font-bold text-sm uppercase tracking-wider mb-4 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                  Prior Experience
                </h4>
                <ul class="space-y-2">
                  {attorney.priorExperience.map(exp => (
                    <li class="flex items-start gap-3 text-sm text-gray-700">
                      <span class="w-2 h-2 rounded-full bg-[#D4A843] flex-shrink-0 mt-1.5"></span>
                      {exp}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Our Team -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">Our Difference</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">What Sets Our Attorneys Apart</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            icon: '🎓',
            title: 'Top-Tier Education',
            description: 'Our attorneys hold degrees from nationally recognized law schools and have distinguished themselves through academic achievement, leadership, and legal scholarship.',
          },
          {
            icon: '🏛️',
            title: 'Real Courtroom Experience',
            description: 'From Maryland Legal Aid to Richmond\'s courts, our attorneys have handled real cases for real clients — bringing that hands-on experience directly to your matter.',
          },
          {
            icon: '❤️',
            title: 'Genuine Compassion',
            description: 'Family law isn\'t just legal work — it\'s personal. Our attorneys were drawn to family law because they care deeply about families, children, and the communities they serve.',
          },
        ].map(item => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 text-center">
            <div class="text-5xl mb-5">{item.icon}</div>
            <h3 class="text-xl font-serif font-bold text-[#0D6E6E] mb-3">{item.title}</h3>
            <p class="text-gray-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[#0D6E6E]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-serif font-bold text-white mb-4">Ready to Work with Our Team?</h2>
      <p class="text-white/80 text-lg mb-8">
        Your case deserves dedicated, strategic legal advocacy. Contact us today for a free initial consultation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-[#D4A843] text-white font-bold px-10 py-4 rounded hover:bg-[#B8902E] transition-colors">
          Book Free Consultation
        </a>
        <a href="tel:2402693592" class="border-2 border-white text-white font-semibold px-10 py-4 rounded hover:bg-white hover:text-[#0D6E6E] transition-colors">
          Call (240) 269-3592
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
