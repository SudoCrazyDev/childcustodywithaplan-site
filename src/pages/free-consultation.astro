---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free Consultation | Maryland Divorce & Custody Attorneys | Child Custody with a Plan"
  description="Book your free consultation with Maryland family law attorneys. Serving Rockville and Baltimore. Discuss your divorce, custody, or alimony case — no obligation. Call (301) 289-8917."
  ogTitle="Book a Free Consultation | Child Custody with a Plan"
  ogDescription="Schedule your free consultation with experienced Maryland divorce and custody attorneys. Rockville and Baltimore offices. Mon–Fri 9AM–9PM."
>

  <!-- Hero -->
  <section class="relative bg-[#0D6E6E] text-white py-16 md:py-20">
    <div class="absolute inset-0 opacity-10 bg-[url('/grid.svg')] bg-repeat"></div>
    <div class="relative max-w-5xl mx-auto px-6 text-center">
      <p class="text-[#D4A843] font-semibold uppercase tracking-widest text-sm mb-3">No Obligation · Completely Confidential</p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-5">
        Book Your Free<br class="hidden md:block" /> Consultation
      </h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        Take the first step toward a clear plan. Our Maryland family law attorneys will review your situation, answer your questions, and outline your options — completely free of charge.
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-5xl mx-auto px-6 py-3">
      <nav class="text-sm text-gray-500">
        <a href="/" class="hover:text-[#0D6E6E]">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-800 font-medium">Free Consultation</span>
      </nav>
    </div>
  </div>

  <!-- 3-Step Process -->
  <section class="py-14 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900">How It Works</h2>
        <p class="text-gray-600 mt-2">Three simple steps to get started</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            step: "01",
            title: "Schedule Your Call",
            desc: "Fill out the form below or call us directly at (301) 289-8917. Choose a time that works for your schedule — we offer appointments Monday through Friday, 9AM to 9PM.",
            icon: "📅"
          },
          {
            step: "02",
            title: "Share Your Situation",
            desc: "Speak one-on-one with a Maryland attorney. You'll have 30–45 minutes to explain your circumstances in complete confidence. We listen carefully and ask the right questions.",
            icon: "🗣️"
          },
          {
            step: "03",
            title: "Get a Clear Plan",
            desc: "Walk away with a clear understanding of your legal options, realistic outcomes, and the next steps you should take — whether you hire us or not.",
            icon: "📋"
          }
        ].map(step => (
          <div class="text-center">
            <div class="w-16 h-16 bg-[#0D6E6E] rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
              {step.icon}
            </div>
            <p class="text-4xl font-bold text-[#D4A843] mb-2">{step.step}</p>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{step.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Form + Contact -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid lg:grid-cols-5 gap-10">

        <!-- Form -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Request Your Free Consultation</h2>
            <p class="text-gray-500 text-sm mb-6">All information is kept strictly confidential. We typically respond within one business day.</p>

            <form name="free-consultation" method="POST" data-netlify="true" class="space-y-5" netlify-honeypot="bot-field">
              <input type="hidden" name="form-name" value="free-consultation" />
              <p class="hidden">
                <label>Don't fill this out: <input name="bot-field" /></label>
              </p>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="first-name" class="block text-sm font-medium text-gray-700 mb-1.5">First Name <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    id="first-name"
                    name="first-name"
                    required
                    placeholder="Your first name"
                    class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent placeholder-gray-400 text-sm"
                  />
                </div>
                <div>
                  <label for="last-name" class="block text-sm font-medium text-gray-700 mb-1.5">Last Name <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    id="last-name"
                    name="last-name"
                    required
                    placeholder="Your last name"
                    class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent placeholder-gray-400 text-sm"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email Address <span class="text-red-500">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="your@email.com"
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent placeholder-gray-400 text-sm"
                />
              </div>

              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone Number <span class="text-red-500">*</span></label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  placeholder="(301) 555-0100"
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent placeholder-gray-400 text-sm"
                />
              </div>

              <div>
                <label for="county" class="block text-sm font-medium text-gray-700 mb-1.5">Maryland County</label>
                <select
                  id="county"
                  name="county"
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent text-sm bg-white"
                >
                  <option value="">Select your county</option>
                  <option>Montgomery County</option>
                  <option>Baltimore City</option>
                  <option>Baltimore County</option>
                  <option>Howard County</option>
                  <option>Prince George's County</option>
                  <option>Anne Arundel County</option>
                  <option>Frederick County</option>
                  <option>Other Maryland County</option>
                </select>
              </div>

              <div>
                <label for="practice-area" class="block text-sm font-medium text-gray-700 mb-1.5">What Do You Need Help With? <span class="text-red-500">*</span></label>
                <select
                  id="practice-area"
                  name="practice-area"
                  required
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent text-sm bg-white"
                >
                  <option value="">Select a practice area</option>
                  <option>Divorce (Uncontested)</option>
                  <option>Divorce (Contested)</option>
                  <option>High-Net-Worth Divorce</option>
                  <option>Divorce Involving a Business</option>
                  <option>Divorce for Professionals</option>
                  <option>Child Custody</option>
                  <option>Child Custody Modification</option>
                  <option>Spousal Support / Alimony</option>
                  <option>Asset Division</option>
                  <option>Other Family Law Matter</option>
                </select>
              </div>

              <div>
                <label for="preferred-contact" class="block text-sm font-medium text-gray-700 mb-1.5">Preferred Contact Method</label>
                <div class="flex gap-4">
                  {["Phone Call", "Email", "Either"].map(method => (
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="preferred-contact" value={method} class="accent-[#0D6E6E]" />
                      <span class="text-sm text-gray-700">{method}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Brief Summary of Your Situation</label>
                <textarea
                  id="message"
                  name="message"
                  rows={4}
                  placeholder="Share as much or as little as you're comfortable with. All information is confidential."
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent placeholder-gray-400 text-sm resize-none"
                ></textarea>
              </div>

              <div class="bg-gray-50 rounded-lg p-3 border border-gray-200">
                <p class="text-xs text-gray-500">
                  By submitting this form, you agree to be contacted by Child Custody with a Plan. Submitting this form does not create an attorney-client relationship. Do not include confidential information until a formal engagement is established.
                </p>
              </div>

              <button
                type="submit"
                class="w-full bg-[#0D6E6E] hover:bg-[#0a5a5a] text-white font-bold py-4 px-6 rounded-lg transition-colors text-lg"
              >
                Request Free Consultation
              </button>
            </form>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 space-y-6">

          <!-- Call CTA -->
          <div class="bg-[#0D6E6E] rounded-2xl p-6 text-white">
            <h3 class="text-xl font-bold mb-2">Prefer to Call?</h3>
            <p class="text-white/75 text-sm mb-4">Speak directly with our team — no waiting, no runaround.</p>
            <a href="tel:3012898917" class="block text-center bg-[#D4A843] hover:bg-[#b8902f] text-white font-bold py-3 px-6 rounded-lg transition-colors text-xl">
              (301) 289-8917
            </a>
            <p class="text-center text-white/60 text-xs mt-2">Mon–Fri · 9AM–9PM</p>
          </div>

          <!-- Offices -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Our Offices</h3>
            <div class="space-y-5">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-[#D4A843]">📍</span>
                  <p class="font-bold text-gray-900">Rockville Office</p>
                </div>
                <p class="text-gray-600 text-sm pl-6">100 Park Ave, Suite 205<br />Rockville, MD 20850</p>
                <p class="text-gray-500 text-xs pl-6 mt-1">Near Rockville Metro Station</p>
              </div>
              <div class="border-t border-gray-100 pt-4">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-[#D4A843]">📍</span>
                  <p class="font-bold text-gray-900">Baltimore Office</p>
                </div>
                <p class="text-gray-600 text-sm pl-6">1537 Light St, Suite 100<br />Baltimore, MD 21230</p>
                <p class="text-gray-500 text-xs pl-6 mt-1">Federal Hill neighborhood</p>
              </div>
            </div>
          </div>

          <!-- What to Expect -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-4">What to Expect</h3>
            <ul class="space-y-3 text-sm">
              {[
                { icon: "⏱️", text: "30–45 minute consultation with an attorney (not a paralegal)" },
                { icon: "🔒", text: "Strictly confidential — protected by attorney-client privilege" },
                { icon: "💬", text: "Honest assessment of your situation and realistic options" },
                { icon: "📋", text: "Clear explanation of Maryland law applicable to your case" },
                { icon: "✅", text: "No pressure — decide to hire us on your own terms" }
              ].map(item => (
                <li class="flex items-start gap-3">
                  <span class="text-lg flex-shrink-0">{item.icon}</span>
                  <span class="text-gray-600">{item.text}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Areas Served -->
          <div class="bg-[#D4A843]/10 rounded-2xl border border-[#D4A843]/20 p-5">
            <h3 class="font-bold text-gray-900 mb-3">Areas We Serve</h3>
            <div class="flex flex-wrap gap-2">
              {[
                "Montgomery County",
                "Baltimore City",
                "Baltimore County",
                "Howard County",
                "Prince George's County",
                "Anne Arundel County",
                "Frederick County",
                "All Maryland Counties"
              ].map(area => (
                <span class="text-xs bg-white text-gray-700 border border-[#D4A843]/30 rounded-full px-3 py-1">{area}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-14 bg-white border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">Why Clients Choose Child Custody with a Plan</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: "🏆", title: "Strategy First", desc: "Every case begins with our proprietary PROMISE Framework — a clear plan built before we file a single document." },
          { icon: "⚖️", title: "Proven Results", desc: "Our attorneys have successfully tried contested cases exceeding $2M in marital assets." },
          { icon: "🔒", title: "Complete Discretion", desc: "We treat every case with the confidentiality and sensitivity it deserves — especially for professionals and executives." },
          { icon: "🤝", title: "Compassionate Advocacy", desc: "Legal strategy with genuine empathy. We fight hard for you while keeping your wellbeing front of mind." }
        ].map(trust => (
          <div class="text-center">
            <div class="text-4xl mb-3">{trust.icon}</div>
            <h3 class="font-bold text-gray-900 mb-2">{trust.title}</h3>
            <p class="text-gray-600 text-sm">{trust.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
