---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Free Consultation — Maryland Divorce Attorneys | Divorce With A Plan"
  description="Schedule your free consultation with Divorce With A Plan — Maryland's strategic divorce and family law firm. Rockville office: (240) 269-3592. Baltimore: (240) 326-7712."
  ogTitle="Free Consultation | Divorce With A Plan — Maryland Family Law"
  ogDescription="Book your free consultation with Maryland's strategic divorce attorneys. Serving Rockville, Baltimore, Montgomery County, and beyond. No obligation."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 to-slate-700 text-white py-20 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-amber-400 uppercase tracking-widest text-sm font-semibold mb-3">No Obligation. Fully Confidential.</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        Schedule Your Free<br class="hidden md:block" />
        Consultation Today
      </h1>
      <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto">
        The first step toward a plan is a conversation. Tell us about your situation, and we'll tell you how we can help. No pressure, no obligation — just straightforward legal guidance from experienced Maryland family law attorneys.
      </p>
    </div>
  </section>

  <!-- Contact & Form Section -->
  <section class="py-16 px-4 bg-slate-50">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12">

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Get in Touch</h2>

          <div class="space-y-6 mb-8">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 bg-amber-500 rounded-full flex items-center justify-center flex-shrink-0 text-white">📍</div>
              <div>
                <h3 class="font-bold text-slate-900">Rockville Office (Primary)</h3>
                <p class="text-slate-600">100 Park Ave, Suite 205<br />Rockville, MD 20850</p>
                <p class="text-amber-600 font-semibold mt-1">(240) 269-3592</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 bg-amber-500 rounded-full flex items-center justify-center flex-shrink-0 text-white">📍</div>
              <div>
                <h3 class="font-bold text-slate-900">Baltimore Office</h3>
                <p class="text-slate-600">Serving Baltimore City & County</p>
                <p class="text-amber-600 font-semibold mt-1">(240) 326-7712</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 bg-amber-500 rounded-full flex items-center justify-center flex-shrink-0 text-white">✉️</div>
              <div>
                <h3 class="font-bold text-slate-900">Email</h3>
                <a href="mailto:info@josephialaw.com" class="text-amber-600 hover:text-amber-700">info@josephialaw.com</a>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 border border-slate-200 mb-6">
            <h3 class="font-bold text-slate-900 mb-3">Areas We Serve</h3>
            <div class="flex flex-wrap gap-2">
              {[
                "Montgomery County", "Baltimore City", "Baltimore County",
                "Howard County", "Prince George's County", "Anne Arundel County",
                "Frederick County", "Carroll County", "Harford County"
              ].map(county => (
                <span class="text-xs bg-slate-100 text-slate-600 px-3 py-1 rounded-full">{county}</span>
              ))}
            </div>
          </div>

          <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
            <h3 class="font-bold text-amber-800 mb-2">Your Privacy Is Protected</h3>
            <p class="text-amber-700 text-sm">Everything you share with us is protected by attorney-client privilege. We handle all family law matters with complete discretion and professionalism.</p>
          </div>
        </div>

        <!-- Consultation Form -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Request Your Free Consultation</h2>
          <form action="#" method="POST" class="space-y-5">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="first-name" class="block text-sm font-medium text-slate-700 mb-1">First Name *</label>
                <input
                  type="text"
                  id="first-name"
                  name="first_name"
                  required
                  class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                  placeholder="Jane"
                />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-medium text-slate-700 mb-1">Last Name *</label>
                <input
                  type="text"
                  id="last-name"
                  name="last_name"
                  required
                  class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                  placeholder="Smith"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email Address *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                placeholder="jane@example.com"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">Phone Number *</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                placeholder="(240) 555-0100"
              />
            </div>

            <div>
              <label for="matter-type" class="block text-sm font-medium text-slate-700 mb-1">Type of Legal Matter *</label>
              <select
                id="matter-type"
                name="matter_type"
                required
                class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
              >
                <option value="">Select a practice area...</option>
                <option value="divorce">Divorce</option>
                <option value="high-asset-divorce">High-Asset / High-Net-Worth Divorce</option>
                <option value="business-divorce">Divorce Involving a Business</option>
                <option value="professional-divorce">Divorce for Professionals</option>
                <option value="child-custody">Child Custody</option>
                <option value="custody-modification">Child Custody Modification</option>
                <option value="spousal-support">Spousal Support / Alimony</option>
                <option value="asset-division">Asset Division</option>
                <option value="other">Other Family Law Matter</option>
              </select>
            </div>

            <div>
              <label for="county" class="block text-sm font-medium text-slate-700 mb-1">County Where Your Case Will Be Filed</label>
              <select
                id="county"
                name="county"
                class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
              >
                <option value="">Select a county...</option>
                <option value="montgomery">Montgomery County</option>
                <option value="baltimore-city">Baltimore City</option>
                <option value="baltimore-county">Baltimore County</option>
                <option value="howard">Howard County</option>
                <option value="prince-georges">Prince George's County</option>
                <option value="anne-arundel">Anne Arundel County</option>
                <option value="frederick">Frederick County</option>
                <option value="harford">Harford County</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-1">Brief Description of Your Situation</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                placeholder="Please share a brief overview of your situation. All information is kept strictly confidential."
              ></textarea>
            </div>

            <div>
              <label for="preferred-contact" class="block text-sm font-medium text-slate-700 mb-1">Preferred Contact Method</label>
              <div class="flex gap-4">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="preferred_contact" value="phone" class="accent-amber-500" checked /> Phone
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="preferred_contact" value="email" class="accent-amber-500" /> Email
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="preferred_contact" value="either" class="accent-amber-500" /> Either
                </label>
              </div>
            </div>

            <button
              type="submit"
              class="w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 px-8 rounded-lg transition-colors text-lg"
            >
              Request Free Consultation
            </button>

            <p class="text-xs text-slate-400 text-center">
              By submitting this form, you agree to be contacted by Divorce With A Plan regarding your legal matter. Submission does not create an attorney-client relationship.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">What to Expect at Your Consultation</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">Our consultations are designed to be informative, productive, and completely confidential.</p>
      </div>
      <div class="grid md:grid-cols-4 gap-6">
        {[
          { icon: "📋", title: "Case Overview", desc: "We listen to your situation without judgment and ask clarifying questions to understand the full picture." },
          { icon: "⚖️", title: "Legal Assessment", desc: "We explain how Maryland law applies to your specific circumstances and what options are available to you." },
          { icon: "🗺️", title: "Strategic Roadmap", desc: "We outline a preliminary strategy and give you a realistic picture of the process, timeline, and outcomes." },
          { icon: "💬", title: "Your Questions Answered", desc: "We answer every question you have — so you leave feeling informed and empowered, not overwhelmed." }
        ].map(item => (
          <div class="text-center">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{item.title}</h3>
            <p class="text-slate-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to Bring -->
  <section class="py-16 px-4 bg-slate-50">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">What to Bring to Your Consultation</h2>
      <p class="text-slate-600 mb-8">Don't worry about gathering everything — but if you have these items available, they'll help us have a more productive conversation:</p>
      <div class="grid md:grid-cols-2 gap-4 text-left">
        {[
          "Marriage certificate (if applicable)",
          "Recent tax returns (last 2-3 years)",
          "Recent pay stubs or income documentation",
          "A list of major marital assets (real estate, retirement accounts, investments)",
          "Any existing court orders related to your family law matter",
          "Names and ages of your children (if applicable)",
          "Any prenuptial or postnuptial agreement",
          "Timeline of key events in your marriage"
        ].map(item => (
          <div class="flex items-start gap-3 bg-white p-4 rounded-lg border border-slate-200">
            <span class="text-amber-500 font-bold mt-0.5">✓</span>
            <span class="text-slate-700 text-sm">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
