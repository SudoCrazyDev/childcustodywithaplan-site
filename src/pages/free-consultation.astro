---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free Consultation | Child Custody with a Plan — Maryland Family Law"
  description="Schedule your free consultation with Child Custody with a Plan. Maryland family law attorneys serving Rockville and Baltimore. Call (301) 289-8917 or fill out our online form. Mon–Fri 9AM–9PM."
>
  <!-- Hero -->
  <section class="teal-gradient text-white py-16 md:py-24 relative overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold-400 rounded-full opacity-10 blur-3xl"></div>
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 bg-gold-400/20 border border-gold-400/40 text-gold-300 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          100% Free — No Obligation
        </div>
        <h1 class="font-serif font-bold text-4xl md:text-5xl text-white leading-tight mb-6">
          Schedule Your Free Consultation
        </h1>
        <p class="text-teal-100 text-xl leading-relaxed">
          Take the first step toward protecting your parental rights and building a strategic plan for your family's future. Our consultations are completely free and confidential.
        </p>
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-12 bg-teal-50 border-b border-teal-100">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        {[
          {
            icon: '📞',
            title: 'Step 1: Contact Us',
            desc: 'Call (301) 289-8917 or fill out the form below. We\'ll respond within one business day.',
          },
          {
            icon: '💬',
            title: 'Step 2: Free Consultation',
            desc: 'Meet with one of our attorneys — by phone, video, or in person at our Rockville or Baltimore office.',
          },
          {
            icon: '📋',
            title: 'Step 3: Get Your Plan',
            desc: 'We\'ll assess your situation, explain your options, and begin building your strategic plan.',
          },
        ].map((step) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-teal-100">
            <div class="text-4xl mb-3">{step.icon}</div>
            <h3 class="font-serif font-bold text-teal-700 text-lg mb-2">{step.title}</h3>
            <p class="text-gray-600 text-sm">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

        <!-- Info sidebar -->
        <div class="lg:col-span-2 space-y-6">
          <div>
            <h2 class="font-serif font-bold text-2xl text-teal-700 mb-4">Why Schedule a Free Consultation?</h2>
            <div class="space-y-4">
              {[
                { icon: '✅', text: 'Understand your legal rights and options under Maryland law' },
                { icon: '✅', text: 'Get a realistic assessment of your case' },
                { icon: '✅', text: 'Learn how the PROMISE Framework™ applies to your situation' },
                { icon: '✅', text: 'Ask questions in a confidential, judgment-free environment' },
                { icon: '✅', text: 'Meet the attorney who will handle your case' },
                { icon: '✅', text: 'No obligation — you decide what to do next' },
              ].map((item) => (
                <div class="flex items-start gap-3">
                  <span class="text-lg">{item.icon}</span>
                  <p class="text-gray-700">{item.text}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-teal-800 rounded-2xl p-6 text-white">
            <h3 class="font-serif font-bold text-xl mb-4">Ready to Talk Now?</h3>
            <p class="text-teal-200 mb-4 text-sm">Call us directly. We're available Mon–Fri from 9AM to 9PM.</p>
            <a href="tel:3012898917" class="block w-full bg-gold-400 hover:bg-gold-500 text-white font-bold py-4 px-6 rounded-xl text-center text-xl transition-colors">
              (301) 289-8917
            </a>
          </div>

          <div class="bg-teal-50 rounded-2xl p-6 border border-teal-100">
            <h3 class="font-serif font-bold text-teal-700 text-lg mb-3">Our Offices</h3>
            <div class="space-y-3 text-sm">
              <div>
                <p class="font-semibold text-teal-600">Rockville, MD</p>
                <p class="text-gray-700">100 Park Ave Suite 205</p>
                <p class="text-gray-700">Rockville, MD 20850</p>
              </div>
              <div class="border-t border-teal-100 pt-3">
                <p class="font-semibold text-teal-600">Baltimore, MD</p>
                <p class="text-gray-700">1537 Light St #100</p>
                <p class="text-gray-700">Baltimore, MD 21230</p>
              </div>
            </div>
          </div>

          <!-- Testimonial -->
          <div class="bg-white rounded-2xl p-6 shadow-md border border-gray-100">
            <div class="flex mb-3">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <blockquote class="text-gray-600 italic text-sm leading-relaxed mb-3">
              "I was nervous about calling, but the consultation was warm, informative, and completely changed how I viewed my situation. They gave me a plan when I had none."
            </blockquote>
            <p class="text-teal-600 font-semibold text-sm">— K.M., Montgomery County</p>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8 md:p-10">
            <h2 class="font-serif font-bold text-2xl text-teal-700 mb-2">Request Your Free Consultation</h2>
            <p class="text-gray-500 text-sm mb-8">Fill out the form below and we'll contact you within one business day to schedule your consultation. All information is strictly confidential.</p>

            <form class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">First Name *</label>
                  <input type="text" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-gray-700" placeholder="First name"/>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Last Name *</label>
                  <input type="text" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-gray-700" placeholder="Last name"/>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address *</label>
                  <input type="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-gray-700" placeholder="your@email.com"/>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Phone Number *</label>
                  <input type="tel" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-gray-700" placeholder="(301) 555-0000"/>
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Legal Matter *</label>
                <select required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-gray-700 bg-white">
                  <option value="">What do you need help with?</option>
                  <option value="child-custody">Child Custody</option>
                  <option value="custody-modification">Child Custody Modification</option>
                  <option value="divorce">Divorce (General)</option>
                  <option value="asset-division">Asset Division</option>
                  <option value="business-divorce">Divorce Involving a Business</option>
                  <option value="professional-divorce">Divorce for Professionals</option>
                  <option value="high-net-worth">High Net Worth Divorce</option>
                  <option value="spousal-support">Spousal Support / Alimony</option>
                  <option value="other">Other / Not Sure</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Maryland County</label>
                <select class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-gray-700 bg-white">
                  <option value="">Select your county</option>
                  <option value="baltimore-city">Baltimore City</option>
                  <option value="baltimore-county">Baltimore County</option>
                  <option value="montgomery">Montgomery County</option>
                  <option value="howard">Howard County</option>
                  <option value="anne-arundel">Anne Arundel County</option>
                  <option value="prince-georges">Prince George's County</option>
                  <option value="other">Other Maryland County</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Preferred Consultation Format</label>
                <div class="grid grid-cols-3 gap-3">
                  {['Phone', 'Video Call', 'In Person'].map((f) => (
                    <label class="flex items-center gap-2 p-3 border border-gray-200 rounded-lg cursor-pointer hover:border-teal-400 transition-colors">
                      <input type="radio" name="format" value={f.toLowerCase().replace(' ', '-')} class="accent-teal-500"/>
                      <span class="text-sm text-gray-700">{f}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Brief Description of Your Situation</label>
                <textarea rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-gray-700 resize-none" placeholder="Tell us a little about what's going on and what you hope to achieve..."></textarea>
              </div>

              <div class="bg-teal-50 rounded-xl p-4 border border-teal-100">
                <p class="text-gray-500 text-xs leading-relaxed">
                  <strong class="text-teal-700">🔒 Confidentiality:</strong> All information you share is strictly confidential and protected by attorney-client privilege. We never share your information with third parties.
                </p>
              </div>

              <button type="submit" class="w-full bg-teal-500 hover:bg-teal-600 text-white font-bold py-4 px-8 rounded-xl transition-colors shadow-md hover:shadow-lg text-base">
                Request Free Consultation →
              </button>

              <p class="text-center text-gray-400 text-xs">
                Or call us directly: <a href="tel:3012898917" class="text-teal-600 font-semibold hover:underline">(301) 289-8917</a> · Mon–Fri 9AM–9PM
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
