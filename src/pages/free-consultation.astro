---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free Consultation | Maryland Child Custody & Divorce Attorneys | Child Custody with a Plan"
  description="Schedule your free, confidential consultation with a Maryland child custody or divorce attorney at Child Custody with a Plan. Serving Rockville, Baltimore & statewide. Call (301) 289-8917."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-teal-900 via-teal-700 to-teal-500 text-white py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-teal-600 bg-opacity-60 border border-gold border-opacity-40 rounded-full px-4 py-1.5 text-sm font-medium text-gold mb-6">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        No Obligation · Completely Confidential
      </div>
      <h1 class="text-4xl sm:text-5xl font-serif font-bold mb-5">
        Schedule Your Free Consultation
      </h1>
      <p class="text-xl text-teal-100 mb-4">
        Take the first step toward protecting your family. Our Maryland family law attorneys are ready to listen, evaluate your situation, and help you understand your legal options.
      </p>
      <div class="flex flex-wrap justify-center gap-6 text-sm text-teal-200 mt-6">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          100% Free
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Completely Confidential
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          No Pressure
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          MD, VA & DC
        </div>
      </div>
    </div>
  </section>

  <!-- Form & Info -->
  <section class="bg-offwhite py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-10">

        <!-- Info sidebar -->
        <div class="space-y-6 order-2 lg:order-1">
          <div>
            <h2 class="text-xl font-serif font-bold text-charcoal mb-4">What to Expect</h2>
            <div class="space-y-4">
              {[
                {
                  step: '1',
                  title: 'Submit Your Request',
                  desc: 'Fill out our form or call us directly at (301) 289-8917.',
                },
                {
                  step: '2',
                  title: 'We Contact You',
                  desc: 'A member of our team will reach out within one business day to schedule your consultation.',
                },
                {
                  step: '3',
                  title: 'Meet Your Attorney',
                  desc: 'Speak one-on-one with an attorney who will listen to your situation without judgment.',
                },
                {
                  step: '4',
                  title: 'Understand Your Options',
                  desc: 'Walk away with clear insight into your legal situation and the path forward.',
                },
              ].map((item) => (
                <div class="flex gap-4">
                  <div class="w-8 h-8 bg-teal text-white rounded-full flex items-center justify-center font-bold text-sm shrink-0">
                    {item.step}
                  </div>
                  <div>
                    <div class="font-semibold text-charcoal text-sm">{item.title}</div>
                    <div class="text-gray-500 text-sm leading-relaxed">{item.desc}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Call option -->
          <div class="bg-teal rounded-2xl p-6 text-white">
            <div class="font-semibold mb-1">Prefer to Call?</div>
            <a href="tel:+13012898917" class="text-2xl font-bold text-gold hover:text-gold-300 transition-colors">(301) 289-8917</a>
            <div class="text-teal-200 text-xs mt-1">Mon–Fri, 9AM–9PM</div>
          </div>

          <!-- Offices -->
          <div class="bg-white rounded-2xl p-6 shadow-card">
            <h3 class="font-semibold text-charcoal mb-4">Our Offices</h3>
            <div class="space-y-4 text-sm text-gray-600">
              <div>
                <div class="font-semibold text-charcoal mb-1">Rockville</div>
                <div>100 Park Ave, Suite 205<br/>Rockville, MD 20850</div>
              </div>
              <div class="border-t pt-4">
                <div class="font-semibold text-charcoal mb-1">Baltimore</div>
                <div>1537 Light St, #100<br/>Baltimore, MD 21230</div>
              </div>
            </div>
          </div>

          <!-- Practice areas -->
          <div class="bg-white rounded-2xl p-6 shadow-card">
            <h3 class="font-semibold text-charcoal mb-3">We Can Help With</h3>
            <ul class="space-y-1.5 text-sm text-gray-600">
              {[
                'Child Custody & Parenting Plans',
                'Child Custody Modification',
                'Contested & Uncontested Divorce',
                'High Net Worth Divorce',
                'Asset Division',
                'Spousal Support & Alimony',
                'Divorce Involving Businesses',
                'Divorce for Professionals',
              ].map((item) => (
                <li class="flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 text-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-2 order-1 lg:order-2">
          <div class="bg-white rounded-2xl shadow-card p-8">
            <div class="mb-7">
              <div class="text-gold font-semibold text-xs uppercase tracking-widest mb-2">Free · Confidential · No Obligation</div>
              <h2 class="text-2xl font-serif font-bold text-charcoal mb-2">Request Your Free Consultation</h2>
              <p class="text-gray-500 text-sm">Fill out the form below and we'll be in touch within one business day.</p>
            </div>

            <form class="space-y-5" action="#" method="POST">
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold text-charcoal mb-1.5" for="fc-first-name">First Name *</label>
                  <input
                    type="text"
                    id="fc-first-name"
                    name="first_name"
                    required
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors"
                    placeholder="First name"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-charcoal mb-1.5" for="fc-last-name">Last Name *</label>
                  <input
                    type="text"
                    id="fc-last-name"
                    name="last_name"
                    required
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors"
                    placeholder="Last name"
                  />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold text-charcoal mb-1.5" for="fc-email">Email Address *</label>
                  <input
                    type="email"
                    id="fc-email"
                    name="email"
                    required
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors"
                    placeholder="your@email.com"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-charcoal mb-1.5" for="fc-phone">Phone Number *</label>
                  <input
                    type="tel"
                    id="fc-phone"
                    name="phone"
                    required
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors"
                    placeholder="(___) ___-____"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-charcoal mb-1.5" for="fc-service">Practice Area *</label>
                <select
                  id="fc-service"
                  name="service"
                  required
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors bg-white"
                >
                  <option value="">Select your legal matter...</option>
                  <option>Child Custody</option>
                  <option>Child Custody Modification</option>
                  <option>Divorce (Uncontested)</option>
                  <option>Divorce (Contested)</option>
                  <option>High Net Worth Divorce</option>
                  <option>Asset Division</option>
                  <option>Spousal Support / Alimony</option>
                  <option>Divorce Involving a Business</option>
                  <option>Divorce for Professionals</option>
                  <option>Other / Not Sure</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold text-charcoal mb-1.5" for="fc-urgency">How Soon Do You Need Help?</label>
                <select
                  id="fc-urgency"
                  name="urgency"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors bg-white"
                >
                  <option value="">Select timeframe...</option>
                  <option>Urgently — I have a court date soon</option>
                  <option>Within the next week</option>
                  <option>Within the next month</option>
                  <option>I'm just gathering information</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold text-charcoal mb-1.5" for="fc-message">Briefly Describe Your Situation *</label>
                <textarea
                  id="fc-message"
                  name="message"
                  required
                  rows="5"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors resize-y"
                  placeholder="Tell us a little about your situation. All information is strictly confidential."
                ></textarea>
              </div>

              <div>
                <label class="block text-sm font-semibold text-charcoal mb-2">Best Time to Reach You</label>
                <div class="flex flex-wrap gap-3">
                  {['Morning (9AM–12PM)', 'Afternoon (12–5PM)', 'Evening (5–9PM)', 'Anytime'].map((time) => (
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="checkbox" name="preferred_time" value={time} class="text-teal rounded" />
                      <span class="text-sm text-gray-600">{time}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="bg-teal-50 border border-teal-100 rounded-lg p-4 text-xs text-gray-600 leading-relaxed">
                <strong class="text-teal">Confidentiality Notice:</strong> The information you submit is protected and will remain strictly confidential. Submitting this form does not establish an attorney-client relationship. We will contact you to discuss next steps. Child Custody with a Plan serves clients in Maryland, Virginia, and Washington D.C.
              </div>

              <button
                type="submit"
                class="w-full bg-gold text-white font-bold py-4 rounded-lg text-base hover:bg-gold-500 transition-colors shadow-lg"
              >
                Submit — Request My Free Consultation
              </button>

              <p class="text-center text-xs text-gray-400">
                Or call us directly: <a href="tel:+13012898917" class="text-teal font-semibold">(301) 289-8917</a> — Mon–Fri, 9AM–9PM
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
