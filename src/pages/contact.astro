---
import BaseLayout from '../layouts/BaseLayout.astro';

const offices = [
  {
    city: 'Rockville',
    subtitle: 'Montgomery County',
    address: '100 Park Ave Suite 205',
    cityState: 'Rockville, MD 20850',
    mapUrl: 'https://maps.google.com/?q=100+Park+Ave+Suite+205+Rockville+MD+20850',
    bgClass: 'bg-teal',
  },
  {
    city: 'Baltimore',
    subtitle: 'Baltimore City',
    address: '1537 Light St #100',
    cityState: 'Baltimore, MD 21230',
    mapUrl: 'https://maps.google.com/?q=1537+Light+St+100+Baltimore+MD+21230',
    bgClass: 'bg-gray-900',
  },
];
---

<BaseLayout
  title="Contact Us — Child Custody with a Plan | Maryland Family Law"
  description="Contact Child Custody with a Plan at our Rockville or Baltimore office. Call (301) 289-8917 or submit our online form to request a free consultation with our Maryland family law attorneys."
>
  <section class="bg-teal py-20 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="max-w-2xl">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-4">Get in Touch</p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
          Contact Our Maryland Family Law Team
        </h1>
        <p class="text-lg text-teal-100 leading-relaxed">
          We are here to help. Reach out today to schedule your free consultation or ask a question about your matter.
        </p>
      </div>
    </div>
  </section>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-teal">Home</a>
        <span>/</span>
        <span class="text-gray-800 font-medium">Contact</span>
      </nav>
    </div>
  </div>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-14">
        <!-- Contact Form -->
        <div>
          <h2 class="font-serif text-2xl font-bold text-teal mb-2">Send Us a Message</h2>
          <p class="text-gray-600 text-sm mb-8">Complete the form below and a member of our team will respond within one business day. All inquiries are confidential.</p>

          <form class="space-y-5" action="#" method="POST">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="first-name" class="block text-sm font-medium text-gray-700 mb-1.5">First Name <span class="text-red-500">*</span></label>
                <input type="text" id="first-name" name="first-name" required class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent" placeholder="Jane" />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-medium text-gray-700 mb-1.5">Last Name <span class="text-red-500">*</span></label>
                <input type="text" id="last-name" name="last-name" required class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent" placeholder="Smith" />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email Address <span class="text-red-500">*</span></label>
              <input type="email" id="email" name="email" required class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent" placeholder="jane@example.com" />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone Number</label>
              <input type="tel" id="phone" name="phone" class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent" placeholder="(301) 555-0100" />
            </div>

            <div>
              <label for="matter-type" class="block text-sm font-medium text-gray-700 mb-1.5">Type of Matter <span class="text-red-500">*</span></label>
              <select id="matter-type" name="matter-type" required class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent bg-white">
                <option value="">Select a matter type...</option>
                <option value="child-custody">Child Custody</option>
                <option value="child-custody-modification">Child Custody Modification</option>
                <option value="divorce">Divorce</option>
                <option value="asset-division">Asset Division</option>
                <option value="high-net-worth-divorce">High Net Worth Divorce</option>
                <option value="spousal-support">Spousal Support / Alimony</option>
                <option value="business-divorce">Divorce Involving a Business</option>
                <option value="professional-divorce">Divorce for Professionals</option>
                <option value="other">Other Family Law Matter</option>
              </select>
            </div>

            <div>
              <label for="office" class="block text-sm font-medium text-gray-700 mb-1.5">Preferred Office</label>
              <select id="office" name="office" class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent bg-white">
                <option value="">No preference</option>
                <option value="rockville">Rockville, MD</option>
                <option value="baltimore">Baltimore, MD</option>
                <option value="virtual">Virtual / Phone Consultation</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Tell Us About Your Situation <span class="text-red-500">*</span></label>
              <textarea id="message" name="message" required rows="5" class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent resize-none" placeholder="Briefly describe your situation. All information is kept strictly confidential."></textarea>
            </div>

            <div class="bg-gray-50 p-4 rounded-sm text-xs text-gray-500 leading-relaxed">
              By submitting this form, you acknowledge that this does not create an attorney-client relationship. Do not include any highly sensitive or confidential information in this form. A member of our team will contact you to schedule a formal consultation.
            </div>

            <button type="submit" class="w-full bg-teal text-white font-semibold py-4 px-8 rounded-sm hover:bg-teal-600 transition-colors uppercase tracking-wide text-sm">
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8">
          <div>
            <h2 class="font-serif text-2xl font-bold text-teal mb-6">Contact Information</h2>
            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-teal rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-800 mb-1">Phone</p>
                  <a href="tel:3012898917" class="text-teal hover:text-gold transition-colors font-medium">(301) 289-8917</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-teal rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-800 mb-1">Office Hours</p>
                  <p class="text-gray-600">Monday – Friday: 9:00 AM – 9:00 PM</p>
                  <p class="text-gray-500 text-sm mt-1">After-hours consultations available by appointment</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Office Cards -->
          <div class="space-y-5">
            {offices.map((office) => (
              <div class={office.bgClass + ' text-white p-6 rounded-sm'}>
                <h3 class="font-serif text-xl font-bold mb-1">{office.city} Office</h3>
                <p class="text-gold text-sm font-semibold uppercase tracking-wide mb-4">{office.subtitle}</p>
                <address class="not-italic leading-relaxed mb-4 text-white/90">
                  {office.address}<br />{office.cityState}
                </address>
                <a href={office.mapUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-semibold text-gold hover:text-white transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  Get Directions
                </a>
              </div>
            ))}
          </div>

          <!-- Free Consultation CTA -->
          <div class="bg-gold-50 border-2 border-gold rounded-sm p-6">
            <h3 class="font-serif text-xl font-bold text-teal mb-3">Free Consultation Available</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">
              We offer free initial consultations for all family law matters. This is your opportunity to speak with an experienced Maryland attorney about your situation, understand your options, and determine the best path forward — with no obligation.
            </p>
            <a href="/free-consultation" class="btn-primary text-xs">Schedule Your Free Consultation</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
