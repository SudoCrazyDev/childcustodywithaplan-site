---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us | Child Custody with a Plan — Rockville & Baltimore Maryland"
  description="Contact Child Custody with a Plan — Maryland family law attorneys in Rockville and Baltimore. Call (301) 289-8917 or fill out our contact form. Free consultations Mon–Fri 9AM–9PM."
>
  <!-- Hero -->
  <section class="teal-gradient text-white py-16 md:py-24 relative overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold-400 rounded-full opacity-10 blur-3xl"></div>
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <div class="max-w-3xl">
        <p class="text-gold-400 font-semibold text-sm uppercase tracking-widest mb-3">Get in Touch</p>
        <h1 class="font-serif font-bold text-4xl md:text-5xl text-white leading-tight mb-6">
          Contact Child Custody with a Plan
        </h1>
        <p class="text-teal-100 text-xl leading-relaxed">
          Ready to take the first step? Reach out to our team today. We offer free consultations and extended hours to accommodate your schedule.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Contact Info -->
        <div class="lg:col-span-1 space-y-8">
          <!-- Phone -->
          <div class="bg-teal-50 rounded-2xl p-6 border border-teal-100">
            <div class="w-12 h-12 bg-teal-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
            </div>
            <h3 class="font-serif font-bold text-teal-700 text-lg mb-2">Phone</h3>
            <a href="tel:3012898917" class="text-2xl font-bold text-teal-500 hover:text-teal-600 transition-colors">(301) 289-8917</a>
            <p class="text-gray-500 text-sm mt-1">Mon–Fri, 9AM–9PM</p>
          </div>

          <!-- Rockville Office -->
          <div class="bg-white rounded-2xl p-6 shadow-md border border-gray-100">
            <div class="w-12 h-12 bg-gold-400 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h3 class="font-serif font-bold text-teal-700 text-lg mb-2">Rockville Office</h3>
            <p class="text-gray-700 font-medium">100 Park Ave Suite 205</p>
            <p class="text-gray-700">Rockville, MD 20850</p>
            <p class="text-teal-600 text-sm mt-2">Serving Montgomery County & surrounding areas</p>
            <a
              href="https://maps.google.com/?q=100+Park+Ave+Suite+205+Rockville+MD+20850"
              target="_blank"
              rel="noopener"
              class="mt-3 inline-flex items-center gap-1 text-teal-600 font-semibold text-sm hover:text-teal-700"
            >
              Get Directions
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>

          <!-- Baltimore Office -->
          <div class="bg-white rounded-2xl p-6 shadow-md border border-gray-100">
            <div class="w-12 h-12 bg-gold-400 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h3 class="font-serif font-bold text-teal-700 text-lg mb-2">Baltimore Office</h3>
            <p class="text-gray-700 font-medium">1537 Light St #100</p>
            <p class="text-gray-700">Baltimore, MD 21230</p>
            <p class="text-teal-600 text-sm mt-2">Serving Baltimore City, County & surrounding areas</p>
            <a
              href="https://maps.google.com/?q=1537+Light+St+%23100+Baltimore+MD+21230"
              target="_blank"
              rel="noopener"
              class="mt-3 inline-flex items-center gap-1 text-teal-600 font-semibold text-sm hover:text-teal-700"
            >
              Get Directions
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2L10 14"/>
              </svg>
            </a>
          </div>

          <!-- Hours -->
          <div class="bg-teal-800 rounded-2xl p-6 text-white">
            <h3 class="font-serif font-bold text-xl mb-4">Office Hours</h3>
            <div class="space-y-2 text-teal-200">
              <div class="flex justify-between">
                <span>Monday</span><span class="text-gold-400 font-medium">9AM – 9PM</span>
              </div>
              <div class="flex justify-between">
                <span>Tuesday</span><span class="text-gold-400 font-medium">9AM – 9PM</span>
              </div>
              <div class="flex justify-between">
                <span>Wednesday</span><span class="text-gold-400 font-medium">9AM – 9PM</span>
              </div>
              <div class="flex justify-between">
                <span>Thursday</span><span class="text-gold-400 font-medium">9AM – 9PM</span>
              </div>
              <div class="flex justify-between">
                <span>Friday</span><span class="text-gold-400 font-medium">9AM – 9PM</span>
              </div>
              <div class="flex justify-between border-t border-teal-700 pt-2 mt-2">
                <span>Saturday</span><span class="text-teal-400">By Appointment</span>
              </div>
              <div class="flex justify-between">
                <span>Sunday</span><span class="text-teal-400">Closed</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8 md:p-10">
            <h2 class="font-serif font-bold text-2xl text-teal-700 mb-2">Send Us a Message</h2>
            <p class="text-gray-500 mb-8">Fill out the form below and a member of our team will be in touch within one business day. For urgent matters, please call us directly at (301) 289-8917.</p>

            <form class="space-y-6" action="/free-consultation" method="get">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="first-name" class="block text-sm font-semibold text-gray-700 mb-2">First Name *</label>
                  <input
                    type="text"
                    id="first-name"
                    name="first_name"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-colors text-gray-700"
                    placeholder="Your first name"
                  />
                </div>
                <div>
                  <label for="last-name" class="block text-sm font-semibold text-gray-700 mb-2">Last Name *</label>
                  <input
                    type="text"
                    id="last-name"
                    name="last_name"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-colors text-gray-700"
                    placeholder="Your last name"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email Address *</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-colors text-gray-700"
                    placeholder="your@email.com"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">Phone Number</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-colors text-gray-700"
                    placeholder="(301) 555-0000"
                  />
                </div>
              </div>

              <div>
                <label for="practice-area" class="block text-sm font-semibold text-gray-700 mb-2">Practice Area *</label>
                <select
                  id="practice-area"
                  name="practice_area"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-colors text-gray-700 bg-white"
                >
                  <option value="">Select a practice area...</option>
                  <option value="child-custody">Child Custody</option>
                  <option value="custody-modification">Child Custody Modification</option>
                  <option value="divorce">Divorce</option>
                  <option value="asset-division">Asset Division</option>
                  <option value="business-divorce">Divorces Involving Businesses</option>
                  <option value="professional-divorce">Divorce for Professionals</option>
                  <option value="high-net-worth">High Net Worth Divorce</option>
                  <option value="spousal-support">Spousal Support / Alimony</option>
                  <option value="other">Other / Not Sure</option>
                </select>
              </div>

              <div>
                <label for="county" class="block text-sm font-semibold text-gray-700 mb-2">Maryland County</label>
                <select
                  id="county"
                  name="county"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-colors text-gray-700 bg-white"
                >
                  <option value="">Select your county...</option>
                  <option value="baltimore-city">Baltimore City</option>
                  <option value="baltimore-county">Baltimore County</option>
                  <option value="montgomery">Montgomery County</option>
                  <option value="howard">Howard County</option>
                  <option value="anne-arundel">Anne Arundel County</option>
                  <option value="prince-georges">Prince George's County</option>
                  <option value="other">Other Maryland County</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">Tell Us About Your Situation *</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-colors text-gray-700 resize-none"
                  placeholder="Briefly describe your situation and what type of assistance you're seeking..."
                ></textarea>
              </div>

              <div class="bg-teal-50 rounded-xl p-4 border border-teal-100">
                <p class="text-gray-500 text-xs leading-relaxed">
                  <strong class="text-teal-700">Confidentiality Notice:</strong> The information you submit through this form is confidential and protected by attorney-client privilege. Your information will not be shared with any third parties.
                </p>
              </div>

              <button
                type="submit"
                class="w-full bg-teal-500 hover:bg-teal-600 text-white font-semibold py-4 px-8 rounded-lg transition-colors shadow-md hover:shadow-lg text-base"
              >
                Send Message — We'll Respond Within 1 Business Day
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map placeholder section -->
  <section class="py-8 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-serif font-bold text-2xl text-teal-700 mb-6 text-center">Find Our Offices</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-teal-100 rounded-2xl h-64 flex items-center justify-center border border-teal-200">
          <div class="text-center">
            <svg class="w-12 h-12 text-teal-500 mx-auto mb-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            <p class="font-semibold text-teal-700">Rockville Office</p>
            <p class="text-teal-600 text-sm">100 Park Ave Suite 205</p>
            <p class="text-teal-600 text-sm">Rockville, MD 20850</p>
            <a href="https://maps.google.com/?q=100+Park+Ave+Suite+205+Rockville+MD+20850" target="_blank" rel="noopener" class="mt-3 inline-block text-teal-700 font-semibold text-sm underline">View on Google Maps</a>
          </div>
        </div>
        <div class="bg-teal-100 rounded-2xl h-64 flex items-center justify-center border border-teal-200">
          <div class="text-center">
            <svg class="w-12 h-12 text-teal-500 mx-auto mb-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            <p class="font-semibold text-teal-700">Baltimore Office</p>
            <p class="text-teal-600 text-sm">1537 Light St #100</p>
            <p class="text-teal-600 text-sm">Baltimore, MD 21230</p>
            <a href="https://maps.google.com/?q=1537+Light+St+%23100+Baltimore+MD+21230" target="_blank" rel="noopener" class="mt-3 inline-block text-teal-700 font-semibold text-sm underline">View on Google Maps</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
