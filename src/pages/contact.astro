---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Contact Child Custody with a Plan | Maryland Family Law Attorneys"
  description="Contact Child Custody with a Plan — Maryland family law attorneys in Rockville and Baltimore. Call (301) 289-8917 or schedule your free consultation online. Available Mon–Fri, 9AM–9PM."
>
  <Hero
    variant="interior"
    subtitle="Get In Touch"
    title="Contact Our Maryland Family Law Team"
    description="We're ready to listen. Reach out today to schedule your free, confidential consultation with one of our experienced family law attorneys."
    ctaText="Call (301) 289-8917"
    ctaHref="tel:+13012898917"
  />

  <!-- Contact section -->
  <section class="bg-offwhite py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-10">

        <!-- Contact info -->
        <div class="space-y-6">
          <div>
            <p class="text-gold font-semibold text-xs uppercase tracking-widest mb-3">Reach Us</p>
            <h2 class="text-2xl font-serif font-bold text-charcoal mb-4">We're Here for You</h2>
            <p class="text-gray-600 leading-relaxed text-sm">
              Whether you're ready to begin your case or simply have questions, our team is available to help. We offer free, confidential consultations — no pressure, no obligation.
            </p>
          </div>

          <!-- Phone -->
          <div class="card">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-teal-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-teal" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-charcoal text-sm mb-1">Phone</div>
                <a href="tel:+13012898917" class="text-teal font-bold text-lg hover:text-teal-600 transition-colors">(301) 289-8917</a>
                <div class="text-gray-500 text-xs mt-1">Mon–Fri, 9AM–9PM</div>
              </div>
            </div>
          </div>

          <!-- Rockville Office -->
          <div class="card">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-teal-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-teal" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-charcoal text-sm mb-1">Rockville Office</div>
                <address class="not-italic text-gray-600 text-sm leading-relaxed">
                  100 Park Ave, Suite 205<br/>
                  Rockville, MD 20850
                </address>
                <div class="text-gray-400 text-xs mt-2">Montgomery County</div>
              </div>
            </div>
          </div>

          <!-- Baltimore Office -->
          <div class="card">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-teal-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-teal" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-charcoal text-sm mb-1">Baltimore Office</div>
                <address class="not-italic text-gray-600 text-sm leading-relaxed">
                  1537 Light St, #100<br/>
                  Baltimore, MD 21230
                </address>
                <div class="text-gray-400 text-xs mt-2">Baltimore City</div>
              </div>
            </div>
          </div>

          <!-- Hours -->
          <div class="card">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-teal-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-teal" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-charcoal text-sm mb-2">Office Hours</div>
                <div class="space-y-1 text-sm text-gray-600">
                  <div class="flex justify-between gap-6">
                    <span>Monday – Friday</span>
                    <span class="font-semibold text-charcoal">9:00 AM – 9:00 PM</span>
                  </div>
                  <div class="flex justify-between gap-6">
                    <span>Saturday</span>
                    <span class="text-gray-400">By Appointment</span>
                  </div>
                  <div class="flex justify-between gap-6">
                    <span>Sunday</span>
                    <span class="text-gray-400">Closed</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Jurisdictions -->
          <div class="bg-teal-50 rounded-xl p-5 border border-teal-100">
            <div class="font-semibold text-teal text-sm mb-3">Jurisdictions We Serve</div>
            <div class="flex flex-wrap gap-2">
              {['Maryland', 'Virginia', 'Washington D.C.'].map((j) => (
                <span class="bg-teal text-white text-xs px-3 py-1 rounded-full font-medium">{j}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Contact form -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-card p-8">
            <div class="mb-7">
              <h2 class="text-2xl font-serif font-bold text-charcoal mb-2">Send Us a Message</h2>
              <p class="text-gray-500 text-sm">All consultations are confidential. We typically respond within one business day.</p>
            </div>

            <form class="space-y-5" action="#" method="POST">
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold text-charcoal mb-1.5" for="first-name">First Name *</label>
                  <input
                    type="text"
                    id="first-name"
                    name="first_name"
                    required
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors"
                    placeholder="Your first name"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-charcoal mb-1.5" for="last-name">Last Name *</label>
                  <input
                    type="text"
                    id="last-name"
                    name="last_name"
                    required
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors"
                    placeholder="Your last name"
                  />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold text-charcoal mb-1.5" for="email">Email Address *</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors"
                    placeholder="your@email.com"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-charcoal mb-1.5" for="phone">Phone Number</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors"
                    placeholder="(___) ___-____"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-charcoal mb-1.5" for="service">Area of Law *</label>
                <select
                  id="service"
                  name="service"
                  required
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors bg-white"
                >
                  <option value="">Select a practice area...</option>
                  <option>Child Custody</option>
                  <option>Child Custody Modification</option>
                  <option>Divorce (Uncontested)</option>
                  <option>Divorce (Contested)</option>
                  <option>High Net Worth Divorce</option>
                  <option>Asset Division</option>
                  <option>Spousal Support / Alimony</option>
                  <option>Divorce Involving a Business</option>
                  <option>Divorce for Professionals</option>
                  <option>Other Family Law Matter</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold text-charcoal mb-1.5" for="county">Maryland County / Location</label>
                <input
                  type="text"
                  id="county"
                  name="county"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors"
                  placeholder="e.g., Montgomery County, Baltimore City"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold text-charcoal mb-1.5" for="message">Tell Us About Your Situation *</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal transition-colors resize-y"
                  placeholder="Please briefly describe your situation. All information is kept strictly confidential."
                ></textarea>
              </div>

              <div>
                <label class="block text-sm font-semibold text-charcoal mb-1.5">Preferred Contact Method</label>
                <div class="flex gap-6">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="contact_method" value="phone" class="text-teal" />
                    <span class="text-sm text-gray-600">Phone</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="contact_method" value="email" class="text-teal" checked />
                    <span class="text-sm text-gray-600">Email</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="contact_method" value="either" class="text-teal" />
                    <span class="text-sm text-gray-600">Either</span>
                  </label>
                </div>
              </div>

              <div class="bg-gray-50 rounded-lg p-4 text-xs text-gray-500 leading-relaxed">
                <strong>Confidentiality Notice:</strong> The information you provide in this form is protected by attorney-client privilege and will remain strictly confidential. Submitting this form does not create an attorney-client relationship. We will contact you to schedule a consultation.
              </div>

              <button
                type="submit"
                class="w-full btn-primary py-4 text-base"
              >
                Send Message — Request a Free Consultation
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map placeholder / area served -->
  <section class="bg-teal py-12 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-serif font-bold mb-3">Serving All of Maryland & the DMV Region</h2>
      <p class="text-teal-100 text-sm mb-6 max-w-2xl mx-auto">
        With offices in Rockville and Baltimore, our attorneys serve clients throughout Maryland, northern Virginia, and Washington D.C.
      </p>
      <div class="flex flex-wrap justify-center gap-2 max-w-3xl mx-auto">
        {[
          'Rockville', 'Bethesda', 'Silver Spring', 'Gaithersburg', 'Frederick',
          'Baltimore', 'Annapolis', 'Columbia', 'Towson', 'Bowie',
          'Hyattsville', 'College Park', 'Waldorf', 'Dundalk', 'Ellicott City',
        ].map((city) => (
          <span class="bg-teal-700 text-teal-100 text-sm px-3 py-1 rounded-full">{city}</span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
