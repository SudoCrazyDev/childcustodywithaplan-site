---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us | Child Custody with a Plan | Maryland Child Custody Attorneys"
  description="Contact Child Custody with a Plan — Maryland's dedicated child custody attorneys in Rockville and Baltimore. Call (301) 289-8917 or complete the contact form. Free consultations available Mon–Fri, 9AM–9PM."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-teal-900 via-teal-800 to-teal-700 text-white py-20 relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gold-400 via-gold-300 to-gold-400"></div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">Contact <span class="text-gold-400">Our Team</span></h1>
      <p class="text-teal-100 text-xl leading-relaxed">
        Reach out today. Our Maryland child custody attorneys are ready to listen and start building your strategy.
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <div class="bg-white border-b border-gray-100 py-3">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-gray-500">
        <a href="/" class="hover:text-teal-600">Home</a>
        <span class="mx-2">/</span>
        <span class="text-teal-700 font-medium">Contact Us</span>
      </nav>
    </div>
  </div>

  <!-- Contact Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14">
        <!-- Contact Info -->
        <div>
          <div class="gold-bar"></div>
          <h2 class="font-serif text-3xl font-bold text-teal-800 mb-5">We're Here to Help</h2>
          <p class="text-gray-600 leading-relaxed mb-10">
            Whether you have a straightforward custody question or are facing an urgent legal situation, our team is available Monday through Friday from 9AM to 9PM. Phone and video consultations available for clients who cannot come to the office.
          </p>

          <!-- Phone (primary CTA) -->
          <div class="bg-teal-900 text-white rounded-2xl p-7 mb-6">
            <div class="flex items-center gap-4 mb-2">
              <div class="w-12 h-12 bg-gold-400 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
              </div>
              <div>
                <p class="text-teal-300 text-sm">Call or Text</p>
                <a href="tel:3012898917" class="text-2xl font-bold text-white hover:text-gold-400 transition-colors">(301) 289-8917</a>
              </div>
            </div>
            <p class="text-teal-300 text-sm mt-4">Available Monday – Friday, 9AM – 9PM<br/>Emergency cases: please call immediately</p>
          </div>

          <!-- Offices -->
          <div class="space-y-5 mb-8">
            <h3 class="font-serif font-bold text-teal-800 text-lg">Our Offices</h3>

            <div class="flex gap-4 p-5 bg-teal-50 rounded-xl border border-teal-100">
              <div class="w-10 h-10 bg-teal-600 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
              </div>
              <div>
                <h4 class="font-semibold text-teal-800 mb-1">Rockville Office (Primary)</h4>
                <p class="text-gray-600 text-sm">100 Park Ave Suite 205<br/>Rockville, MD 20850</p>
                <p class="text-teal-600 text-xs mt-2">Serving: Montgomery, Prince George's, Frederick Counties</p>
              </div>
            </div>

            <div class="flex gap-4 p-5 bg-teal-50 rounded-xl border border-teal-100">
              <div class="w-10 h-10 bg-teal-600 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
              </div>
              <div>
                <h4 class="font-semibold text-teal-800 mb-1">Baltimore Office</h4>
                <p class="text-gray-600 text-sm">1537 Light St #100<br/>Baltimore, MD 21230</p>
                <p class="text-teal-600 text-xs mt-2">Serving: Baltimore City, Baltimore County, Howard, Anne Arundel</p>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div class="flex gap-4 p-5 bg-gray-50 rounded-xl border border-gray-200 mb-6">
            <div class="w-10 h-10 bg-teal-600 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
            </div>
            <div>
              <p class="text-gray-500 text-sm">Email</p>
              <a href="mailto:info@childcustodywithaplan.com" class="text-teal-700 font-semibold hover:text-teal-600 transition-colors">info@childcustodywithaplan.com</a>
            </div>
          </div>

          <!-- Hours -->
          <div class="bg-white border border-gray-200 rounded-xl p-6">
            <h4 class="font-semibold text-teal-800 mb-4">Office Hours</h4>
            <div class="space-y-2">
              {[
                { day: "Monday – Friday", hours: "9:00 AM – 9:00 PM" },
                { day: "Saturday", hours: "By appointment only" },
                { day: "Sunday", hours: "Closed" },
              ].map((h) => (
                <div class="flex justify-between text-sm">
                  <span class="text-gray-600">{h.day}</span>
                  <span class="font-semibold text-teal-800">{h.hours}</span>
                </div>
              ))}
            </div>
            <div class="mt-4 pt-4 border-t border-gray-100">
              <p class="text-teal-600 text-xs font-semibold">⚡ Emergency cases are handled outside regular hours when necessary.</p>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
            <h3 class="font-serif font-bold text-teal-800 text-2xl mb-2">Send Us a Message</h3>
            <p class="text-gray-600 text-sm mb-6">Complete the form and we'll respond within one business hour during office hours.</p>

            <form class="space-y-5" action="#" method="POST">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="first_name" class="block text-sm font-semibold text-gray-700 mb-1.5">First Name *</label>
                  <input type="text" id="first_name" name="first_name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-sm" placeholder="First name" />
                </div>
                <div>
                  <label for="last_name" class="block text-sm font-semibold text-gray-700 mb-1.5">Last Name *</label>
                  <input type="text" id="last_name" name="last_name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-sm" placeholder="Last name" />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address *</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-sm" placeholder="your@email.com" />
              </div>

              <div>
                <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">Phone Number</label>
                <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-sm" placeholder="(xxx) xxx-xxxx" />
              </div>

              <div>
                <label for="matter_type" class="block text-sm font-semibold text-gray-700 mb-1.5">Type of Matter *</label>
                <select id="matter_type" name="matter_type" required class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-sm bg-white">
                  <option value="">Select a matter type</option>
                  <option value="initial_custody">Initial Child Custody</option>
                  <option value="fathers_rights">Father's Rights</option>
                  <option value="mothers_rights">Mother's Rights</option>
                  <option value="modification">Custody Modification</option>
                  <option value="emergency">Emergency Custody</option>
                  <option value="visitation">Visitation Rights</option>
                  <option value="other">Other / Not Sure</option>
                </select>
              </div>

              <div>
                <label for="county" class="block text-sm font-semibold text-gray-700 mb-1.5">County / Location</label>
                <input type="text" id="county" name="county" class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-sm" placeholder="e.g. Montgomery County, Baltimore City" />
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">Brief Description of Your Situation *</label>
                <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent text-sm resize-none" placeholder="Briefly describe your custody situation and what you're looking for..."></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input type="checkbox" id="consent" name="consent" required class="w-4 h-4 text-teal-600 mt-0.5" />
                <label for="consent" class="text-xs text-gray-600">
                  I understand that submitting this form does not create an attorney-client relationship. The information provided is confidential. *
                </label>
              </div>

              <button type="submit" class="btn-primary w-full justify-center text-base py-4">
                Send Message
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </button>
            </form>
          </div>

          <!-- Alternative CTA -->
          <div class="mt-5 text-center">
            <p class="text-gray-500 text-sm mb-3">Prefer to schedule right away?</p>
            <a href="/free-consultation" class="btn-outline w-full justify-center">Schedule Your Free Consultation →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Placeholder / Service Area -->
  <section class="py-16 bg-teal-900 text-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10">
        <div class="w-16 h-1 bg-gold-400 mx-auto mb-6"></div>
        <h2 class="font-serif text-3xl font-bold mb-3">Maryland Counties We Serve</h2>
        <p class="text-teal-200">We represent clients throughout Maryland from our Rockville and Baltimore offices.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 max-w-5xl mx-auto">
        {[
          "Montgomery County",
          "Prince George's County",
          "Baltimore City",
          "Baltimore County",
          "Howard County",
          "Anne Arundel County",
          "Frederick County",
          "Charles County",
          "Calvert County",
          "Carroll County",
          "Harford County",
          "Washington County",
        ].map((county) => (
          <div class="bg-teal-800 bg-opacity-60 rounded-lg p-3 text-center text-teal-200 text-xs border border-teal-700 hover:border-gold-400 transition-colors">
            {county}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
