---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Contact Us | Free Consultation | Child Custody with a Plan — Maryland"
  description="Schedule a free initial consultation with our Maryland family law attorneys. Serving Rockville, Baltimore, Montgomery County, Howard County, and across Maryland. Call (240) 269-3592 today."
>

  <Hero
    subtitle="Get In Touch"
    title="Your Free Consultation Starts Here"
    description="Tell us about your situation. Our attorneys are ready to listen, evaluate your case, and provide honest guidance — at no cost for your first consultation."
    variant="compact"
  />

  <!-- Contact Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Contact Form -->
        <div>
          <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">Send Us a Message</p>
          <h2 class="text-3xl font-serif font-bold text-[#0D6E6E] mb-6">Schedule Your Consultation</h2>

          <form class="space-y-5" action="#" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="first-name" class="block text-sm font-semibold text-gray-700 mb-1.5">First Name *</label>
                <input
                  type="text"
                  id="first-name"
                  name="first_name"
                  required
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent transition"
                  placeholder="Jane"
                />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-semibold text-gray-700 mb-1.5">Last Name *</label>
                <input
                  type="text"
                  id="last-name"
                  name="last_name"
                  required
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent transition"
                  placeholder="Smith"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent transition"
                placeholder="jane@example.com"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">Phone Number</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent transition"
                placeholder="(240) 555-0100"
              />
            </div>

            <div>
              <label for="matter-type" class="block text-sm font-semibold text-gray-700 mb-1.5">Type of Matter *</label>
              <select
                id="matter-type"
                name="matter_type"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent transition bg-white"
              >
                <option value="">Select a practice area...</option>
                <option value="child-custody">Child Custody / Visitation</option>
                <option value="divorce">Divorce</option>
                <option value="high-asset-divorce">High-Asset Divorce</option>
                <option value="spousal-support">Spousal Support / Alimony</option>
                <option value="asset-division">Asset & Property Division</option>
                <option value="custody-modification">Custody / Support Modification</option>
                <option value="other">Other Family Law Matter</option>
              </select>
            </div>

            <div>
              <label for="county" class="block text-sm font-semibold text-gray-700 mb-1.5">Maryland County</label>
              <select
                id="county"
                name="county"
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent transition bg-white"
              >
                <option value="">Select your county...</option>
                <option value="montgomery">Montgomery County</option>
                <option value="howard">Howard County</option>
                <option value="baltimore-city">Baltimore City</option>
                <option value="baltimore-county">Baltimore County</option>
                <option value="prince-georges">Prince George's County</option>
                <option value="anne-arundel">Anne Arundel County</option>
                <option value="frederick">Frederick County</option>
                <option value="dc">Washington D.C.</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">Brief Description of Your Situation *</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#0D6E6E] focus:border-transparent transition resize-none"
                placeholder="Please briefly describe your situation and what you hope to achieve. All information is strictly confidential."
              ></textarea>
            </div>

            <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 text-xs text-amber-800">
              <strong>Confidentiality Notice:</strong> The information you submit is confidential and protected. Submitting this form does not create an attorney-client relationship.
            </div>

            <button
              type="submit"
              class="w-full bg-[#D4A843] text-white font-bold py-4 rounded-lg hover:bg-[#B8902E] transition-colors text-lg"
            >
              Submit Consultation Request
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">Contact Information</p>
          <h2 class="text-3xl font-serif font-bold text-[#0D6E6E] mb-8">Reach Us Directly</h2>

          <div class="space-y-6 mb-10">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#0D6E6E] rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-800 mb-1">Phone</h3>
                <a href="tel:2402693592" class="text-[#D4A843] font-semibold hover:text-[#B8902E] transition-colors block">(240) 269-3592 — Rockville</a>
                <a href="tel:2403267712" class="text-[#D4A843] font-semibold hover:text-[#B8902E] transition-colors block">(240) 326-7712 — Baltimore</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#0D6E6E] rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-800 mb-1">Email</h3>
                <a href="mailto:info@josephialaw.com" class="text-[#D4A843] font-semibold hover:text-[#B8902E] transition-colors">info@josephialaw.com</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#0D6E6E] rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-800 mb-1">Rockville Office</h3>
                <p class="text-gray-600">100 Park Ave, Suite 205<br/>Rockville, MD 20850</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#0D6E6E] rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-800 mb-1">Baltimore Office</h3>
                <p class="text-gray-600">Baltimore, MD<br/>Serving Baltimore City &amp; County</p>
              </div>
            </div>
          </div>

          <!-- Service Areas -->
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 mb-8">
            <h3 class="font-bold text-[#0D6E6E] mb-4 text-sm uppercase tracking-wide">Counties We Serve</h3>
            <div class="grid grid-cols-2 gap-2">
              {[
                'Montgomery County',
                'Howard County',
                'Baltimore City',
                'Baltimore County',
                "Prince George's County",
                'Anne Arundel County',
                'Frederick County',
                'Washington D.C.',
              ].map(county => (
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#D4A843] flex-shrink-0"></span>
                  {county}
                </div>
              ))}
            </div>
          </div>

          <!-- What to Expect -->
          <div class="bg-[#0D6E6E] rounded-xl p-6 text-white">
            <h3 class="font-serif font-bold text-lg mb-4 text-[#D4A843]">What to Expect in Your Consultation</h3>
            <ul class="space-y-3 text-sm text-white/80">
              {[
                'Confidential, judgment-free conversation about your situation',
                'Clear explanation of your legal options and rights',
                'Honest assessment of your case\'s strengths and challenges',
                'Overview of the process and what comes next',
                'Opportunity to ask any and all questions',
              ].map(item => (
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 rounded-full bg-[#D4A843] flex-shrink-0 mt-1.5"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
