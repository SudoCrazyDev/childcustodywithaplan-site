---
import BaseLayout from '../layouts/BaseLayout.astro';

const contactSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ContactPage",
      "@id": "https://childcustodywithaplan.com/contact/#webpage",
      "url": "https://childcustodywithaplan.com/contact",
      "name": "Contact Child Custody with a Plan — Maryland Family Law Attorneys",
      "description": "Contact Child Custody with a Plan at our Rockville or Baltimore office. Call (240) 326-7712 or submit our online form. Free consultations for Maryland family law matters.",
      "isPartOf": { "@id": "https://childcustodywithaplan.com/#website" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://childcustodywithaplan.com/" },
          { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://childcustodywithaplan.com/contact" }
        ]
      }
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://childcustodywithaplan.com/#rockville-local",
      "name": "Child Custody with a Plan — Rockville Family Law Attorney",
      "description": "Family law attorney in Rockville MD specializing in child custody, divorce, spousal support, and asset division. Serving Montgomery County and all of Maryland.",
      "url": "https://childcustodywithaplan.com",
      "telephone": "(240) 326-7712",
      "priceRange": "$$",
      "image": "https://childcustodywithaplan.com/images/hero-landing.webp",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "100 Park Ave Suite 205",
        "addressLocality": "Rockville",
        "addressRegion": "MD",
        "postalCode": "20850",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "39.0840",
        "longitude": "-77.1528"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "09:00",
        "closes": "21:00"
      },
      "areaServed": [
        "Rockville MD", "Bethesda MD", "Gaithersburg MD", "Silver Spring MD",
        "Germantown MD", "Potomac MD", "Chevy Chase MD", "Montgomery County MD"
      ],
      "sameAs": "https://childcustodywithaplan.com"
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://childcustodywithaplan.com/#baltimore-local",
      "name": "Child Custody with a Plan — Baltimore Family Law Attorney",
      "description": "Family law attorney in Baltimore MD specializing in child custody, divorce, spousal support, and asset division. Serving Baltimore City, Baltimore County, and all of Maryland.",
      "url": "https://childcustodywithaplan.com",
      "telephone": "(240) 326-7712",
      "priceRange": "$$",
      "image": "https://childcustodywithaplan.com/images/hero-landing.webp",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1537 Light St #100",
        "addressLocality": "Baltimore",
        "addressRegion": "MD",
        "postalCode": "21230",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "39.2778",
        "longitude": "-76.6143"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "09:00",
        "closes": "21:00"
      },
      "areaServed": [
        "Baltimore MD", "Baltimore County MD", "Towson MD", "Columbia MD",
        "Ellicott City MD", "Annapolis MD", "Anne Arundel County MD"
      ],
      "sameAs": "https://childcustodywithaplan.com"
    }
  ]
});
---

<BaseLayout
  title="Contact Us — Family Law Attorney Rockville &amp; Baltimore MD"
  description="Contact Child Custody with a Plan at our Rockville or Baltimore MD office. Call (240) 326-7712 for a free consultation with our Maryland family law attorneys. Mon–Fri 9AM–9PM."
  canonicalURL="https://childcustodywithaplan.com/contact"
  ogImage="/images/hero-landing.webp"
  schema={contactSchema}
>
  <section class="bg-teal py-20 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="max-w-2xl">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-4">Get in Touch</p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
          Contact Our Maryland Family Law Attorneys
        </h1>
        <p class="text-lg text-teal-100 leading-relaxed">
          We are here to help. Reach out today to schedule your free consultation or ask a question about your family law matter in Rockville, Baltimore, or anywhere in Maryland.
        </p>
      </div>
    </div>
  </section>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3">
      <nav aria-label="Breadcrumb" class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-teal">Home</a>
        <span>/</span>
        <span class="text-gray-800 font-medium">Contact</span>
      </nav>
    </div>
  </div>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-14">
        <!-- Contact Form -->
        <div>
          <h2 class="font-serif text-2xl font-bold text-teal mb-2">Send Us a Message</h2>
          <p class="text-gray-600 text-sm mb-8">Complete the form below and a member of our team will respond within one business day. All inquiries are confidential.</p>

          <form class="space-y-5" action="#" method="POST">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="first-name" class="block text-sm font-medium text-gray-700 mb-1.5">First Name <span class="text-red-500">*</span></label>
                <input type="text" id="first-name" name="first-name" required class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent" placeholder="Jane" />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-medium text-gray-700 mb-1.5">Last Name <span class="text-red-500">*</span></label>
                <input type="text" id="last-name" name="last-name" required class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent" placeholder="Smith" />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email Address <span class="text-red-500">*</span></label>
              <input type="email" id="email" name="email" required class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent" placeholder="jane@example.com" />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone Number</label>
              <input type="tel" id="phone" name="phone" class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent" placeholder="(240) 326-7712" />
            </div>

            <div>
              <label for="matter-type" class="block text-sm font-medium text-gray-700 mb-1.5">Type of Matter <span class="text-red-500">*</span></label>
              <select id="matter-type" name="matter-type" required class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent bg-white">
                <option value="">Select a matter type...</option>
                <option value="child-custody">Child Custody</option>
                <option value="child-custody-modification">Child Custody Modification</option>
                <option value="divorce">Divorce</option>
                <option value="asset-division">Asset Division</option>
                <option value="high-net-worth-divorce">High Net Worth Divorce</option>
                <option value="spousal-support">Spousal Support / Alimony</option>
                <option value="business-divorce">Divorce Involving a Business</option>
                <option value="professional-divorce">Divorce for Professionals</option>
                <option value="other">Other Family Law Matter</option>
              </select>
            </div>

            <div>
              <label for="office" class="block text-sm font-medium text-gray-700 mb-1.5">Preferred Office</label>
              <select id="office" name="office" class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent bg-white">
                <option value="">No preference</option>
                <option value="rockville">Rockville, MD (Montgomery County)</option>
                <option value="baltimore">Baltimore, MD</option>
                <option value="virtual">Virtual / Phone Consultation</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Tell Us About Your Situation <span class="text-red-500">*</span></label>
              <textarea id="message" name="message" required rows="5" class="w-full border border-gray-300 rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent resize-none" placeholder="Briefly describe your situation. All information is kept strictly confidential."></textarea>
            </div>

            <div class="bg-gray-50 p-4 rounded-sm text-xs text-gray-500 leading-relaxed">
              By submitting this form, you acknowledge that this does not create an attorney-client relationship. Do not include any highly sensitive or confidential information in this form. A member of our team will contact you to schedule a formal consultation.
            </div>

            <button type="submit" class="w-full bg-teal text-white font-semibold py-4 px-8 rounded-sm hover:bg-teal-600 transition-colors uppercase tracking-wide text-sm">
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info & Maps -->
        <div class="space-y-8">
          <div>
            <h2 class="font-serif text-2xl font-bold text-teal mb-6">Contact Information</h2>
            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-teal rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-800 mb-1">Phone</p>
                  <a href="tel:+12403267712" class="text-teal hover:text-gold transition-colors font-medium text-lg">(240) 326-7712</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-teal rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-800 mb-1">Office Hours</p>
                  <p class="text-gray-600">Monday – Friday: 9:00 AM – 9:00 PM</p>
                  <p class="text-gray-500 text-sm mt-1">After-hours consultations available by appointment</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Rockville Office Card + Map -->
          <div class="rounded-sm overflow-hidden shadow-md">
            <div class="bg-teal text-white p-5">
              <h3 class="font-serif text-xl font-bold mb-1">Family Law Attorney Rockville MD</h3>
              <p class="text-gold text-sm font-semibold uppercase tracking-wide mb-3">Montgomery County</p>
              <address class="not-italic leading-relaxed mb-3 text-white/90 text-sm">
                100 Park Ave Suite 205<br />Rockville, MD 20850
              </address>
              <div class="flex gap-4 items-center">
                <a href="tel:+12403267712" class="text-sm font-semibold text-gold hover:text-white transition-colors">(240) 326-7712</a>
                <a href="https://maps.google.com/?q=100+Park+Ave+Suite+205+Rockville+MD+20850" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold hover:text-white transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  Get Directions
                </a>
              </div>
            </div>
            <!-- Google Maps Embed — Rockville -->
            <div class="w-full h-52">
              <iframe
                title="Rockville Office — 100 Park Ave Suite 205, Rockville, MD 20850"
                width="100%"
                height="100%"
                style="border:0;"
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3100.7!2d-77.1528!3d39.0840!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89b7cc6f7b3b3b3b%3A0x0!2s100+Park+Ave+Suite+205%2C+Rockville%2C+MD+20850!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus"
              ></iframe>
            </div>
          </div>

          <!-- Baltimore Office Card + Map -->
          <div class="rounded-sm overflow-hidden shadow-md">
            <div class="bg-gray-900 text-white p-5">
              <h3 class="font-serif text-xl font-bold mb-1">Family Law Attorney Baltimore MD</h3>
              <p class="text-gold text-sm font-semibold uppercase tracking-wide mb-3">Baltimore City</p>
              <address class="not-italic leading-relaxed mb-3 text-white/80 text-sm">
                1537 Light St #100<br />Baltimore, MD 21230
              </address>
              <div class="flex gap-4 items-center">
                <a href="tel:+12403267712" class="text-sm font-semibold text-gold hover:text-white transition-colors">(240) 326-7712</a>
                <a href="https://maps.google.com/?q=1537+Light+St+100+Baltimore+MD+21230" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold hover:text-white transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  Get Directions
                </a>
              </div>
            </div>
            <!-- Google Maps Embed — Baltimore -->
            <div class="w-full h-52">
              <iframe
                title="Baltimore Office — 1537 Light St #100, Baltimore, MD 21230"
                width="100%"
                height="100%"
                style="border:0;"
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3086.0!2d-76.6143!3d39.2778!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c80375cd6f9f2d%3A0x0!2s1537+Light+St+%23100%2C+Baltimore%2C+MD+21230!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus"
              ></iframe>
            </div>
          </div>

          <!-- Free Consultation CTA -->
          <div class="bg-gold-50 border-2 border-gold rounded-sm p-6">
            <h3 class="font-serif text-xl font-bold text-teal mb-3">Free Consultation Available</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">
              We offer free initial consultations for all Maryland family law matters including <a href="/child-custody" class="text-teal hover:text-gold font-medium">child custody</a>, <a href="/divorce" class="text-teal hover:text-gold font-medium">divorce</a>, <a href="/spousal-support" class="text-teal hover:text-gold font-medium">spousal support</a>, and <a href="/asset-division" class="text-teal hover:text-gold font-medium">asset division</a>. This is your opportunity to speak with an experienced Maryland attorney about your situation with no obligation.
            </p>
            <a href="/free-consultation" class="btn-primary text-xs">Schedule Your Free Consultation</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
