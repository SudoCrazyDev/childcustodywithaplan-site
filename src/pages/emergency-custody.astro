---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConsultationCTA from '../components/ConsultationCTA.astro';
---

<BaseLayout
  title="Emergency Custody Order Maryland | Emergency Child Custody Attorney | Child Custody with a Plan"
  description="Need an emergency custody order in Maryland? Our attorneys file emergency custody petitions fast to protect children in immediate danger. Call (301) 289-8917 now — Rockville & Baltimore."
>
  <!-- URGENT Hero -->
  <section class="bg-gradient-to-br from-red-900 via-teal-900 to-teal-800 text-white py-20 relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-500 via-gold-400 to-gold-400"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-red-500 bg-opacity-30 border border-red-400 border-opacity-50 text-red-200 px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
          🚨 URGENT — Emergency Custody
        </div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">
          Emergency Custody <span class="text-gold-400">Attorneys</span> in Maryland
        </h1>
        <p class="text-teal-100 text-xl leading-relaxed mb-8">
          When your child's safety is at immediate risk, every hour matters. Our Maryland emergency custody attorneys act fast — filing emergency orders and protective motions when you need them most.
        </p>

        <!-- URGENT CTA -->
        <div class="bg-red-900 bg-opacity-50 border border-red-500 rounded-2xl p-6 mb-8">
          <p class="text-red-200 font-semibold mb-4">⚡ If this is an emergency, call us immediately:</p>
          <a href="tel:3012898917" class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold px-8 py-4 rounded-lg transition-all shadow-lg text-xl">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
            (301) 289-8917
          </a>
          <p class="text-teal-300 text-sm mt-3">For life-threatening emergencies, call 911 first.</p>
        </div>

        <a href="/free-consultation" class="inline-flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-teal-800 font-bold px-8 py-4 rounded-lg transition-all">
          Schedule Emergency Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- Breadcrumb -->
  <div class="bg-white border-b border-gray-100 py-3">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-gray-500">
        <a href="/" class="hover:text-teal-600">Home</a>
        <span class="mx-2">/</span>
        <a href="/services" class="hover:text-teal-600">Services</a>
        <span class="mx-2">/</span>
        <span class="text-teal-700 font-medium">Emergency Custody</span>
      </nav>
    </div>
  </div>

  <!-- Main Content -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <div class="gold-bar"></div>
          <h2 class="font-serif text-3xl font-bold text-teal-800 mb-5">What Is an Emergency Custody Order?</h2>

          <div class="space-y-5 text-gray-600">
            <p class="leading-relaxed">
              An emergency custody order (also called an emergency temporary custody order or an ex parte order) is an immediate, short-term court order that changes or establishes custody arrangements without waiting for the standard court process. Maryland courts can issue these orders very quickly — sometimes within 24–48 hours — when a child's safety is at immediate risk.
            </p>
            <p class="leading-relaxed">
              Because emergency orders are issued <em>ex parte</em> — meaning only one parent's side is heard initially — courts apply a high standard. You must demonstrate that there is a genuine, immediate threat to the child's physical safety or welfare. Our attorneys know exactly what evidence and arguments Maryland courts require to grant emergency relief.
            </p>
          </div>

          <!-- When to Seek Emergency Custody -->
          <div class="mt-10">
            <h3 class="font-serif font-bold text-teal-800 text-xl mb-6">Situations That May Warrant Emergency Custody</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { icon: "🚨", title: "Domestic Violence", desc: "Physical abuse of the child or abuse in the home that puts the child at risk." },
                { icon: "💊", title: "Substance Abuse", desc: "A parent caring for the child while under the influence of drugs or alcohol." },
                { icon: "🏃", title: "Parental Abduction", desc: "The other parent has taken or threatens to take the child without permission." },
                { icon: "⚠️", title: "Neglect or Endangerment", desc: "The child is being left unsupervised or in unsafe living conditions." },
                { icon: "🌍", title: "Flight Risk", desc: "The other parent is threatening to take the child out of state or out of the country." },
                { icon: "🏥", title: "Medical Emergency", desc: "A parent is denying necessary medical care for the child." },
                { icon: "🛑", title: "Sexual Abuse Allegations", desc: "Credible, immediate allegations of sexual abuse by a parent or household member." },
                { icon: "🔒", title: "Abandonment", desc: "A parent has abandoned the child or is unable to care for them due to arrest or incarceration." },
              ].map((item) => (
                <div class="bg-red-50 border border-red-200 rounded-xl p-5">
                  <div class="flex items-center gap-3 mb-2">
                    <div class="text-2xl">{item.icon}</div>
                    <h4 class="font-semibold text-red-800 text-sm">{item.title}</h4>
                  </div>
                  <p class="text-gray-600 text-xs leading-relaxed">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Process -->
          <div class="mt-12">
            <h3 class="font-serif font-bold text-teal-800 text-xl mb-6">The Emergency Custody Process in Maryland</h3>
            <div class="space-y-4">
              {[
                { step: "1", title: "Immediate Assessment", desc: "You contact us — by phone or in person. We immediately evaluate the situation and determine whether emergency relief is available and appropriate." },
                { step: "2", title: "Drafting the Emergency Petition", desc: "We draft an emergency custody petition and supporting affidavit detailing the specific facts and evidence showing the imminent danger to your child." },
                { step: "3", title: "Filing at the Circuit Court", desc: "We file the petition at the appropriate Maryland Circuit Court — often the same day. Emergency motions go to a duty judge for rapid review." },
                { step: "4", title: "Ex Parte Hearing", desc: "A judge reviews the evidence and, if satisfied that an emergency exists, issues a temporary custody order immediately. The other parent is served shortly thereafter." },
                { step: "5", title: "Full Hearing Scheduled", desc: "The emergency order is temporary. A full adversarial hearing — where both parents present their cases — is typically scheduled within 7–10 days to determine longer-term arrangements." },
              ].map((step) => (
                <div class="flex gap-4 p-5 bg-gray-50 rounded-xl border border-gray-200">
                  <div class="w-10 h-10 bg-red-600 rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">
                    {step.step}
                  </div>
                  <div>
                    <h4 class="font-semibold text-teal-800 mb-1">{step.title}</h4>
                    <p class="text-gray-600 text-sm leading-relaxed">{step.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- What You Need -->
          <div class="mt-12 bg-teal-50 rounded-2xl p-8">
            <h3 class="font-serif font-bold text-teal-800 text-xl mb-5">Evidence That Supports an Emergency Custody Order</h3>
            <p class="text-gray-600 text-sm mb-5">Courts require concrete evidence of immediate danger. Gather as much of the following as possible:</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {[
                "Photos or video of injuries or unsafe conditions",
                "Police reports or incident numbers",
                "Medical records documenting injuries",
                "Text messages or emails with threats",
                "Witness statements from neighbors or family",
                "School or teacher reports of concerns",
                "CPS investigation records",
                "Prior protective orders",
                "Drug test results",
                "Your own sworn affidavit of events",
              ].map((item) => (
                <div class="flex items-start gap-2">
                  <div class="w-5 h-5 bg-teal-200 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <div class="w-2 h-2 bg-teal-600 rounded-full"></div>
                  </div>
                  <span class="text-gray-700 text-sm">{item}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQ -->
          <div class="mt-12">
            <h3 class="font-serif font-bold text-teal-800 text-2xl mb-6">Emergency Custody FAQ</h3>
            <div class="space-y-4">
              {[
                {
                  q: "How quickly can an emergency custody order be obtained?",
                  a: "In Maryland, emergency custody orders can sometimes be obtained within 24–48 hours if the evidence demonstrates immediate danger to the child. Courts have duty judges available to review emergency petitions quickly. The timeline depends on the specific court, the evidence provided, and how imminent the danger is.",
                },
                {
                  q: "Can I get an emergency custody order without a lawyer?",
                  a: "Technically yes, but emergency custody cases are difficult to win without experienced legal representation. Courts apply strict standards for emergency relief, and an improperly filed or insufficiently documented petition will be denied. Given the stakes — your child's immediate safety — having an experienced attorney dramatically improves your chances.",
                },
                {
                  q: "What happens after the emergency order is issued?",
                  a: "An emergency order is temporary. The court will schedule a full hearing — typically within 7–10 days — where both parents can present evidence and arguments. At that hearing, the judge decides whether to continue the temporary order, modify it, or dissolve it pending a full custody proceeding.",
                },
                {
                  q: "Can the other parent fight an emergency custody order?",
                  a: "Yes. The other parent has the right to contest the order at the follow-up hearing. This is why it's critical to be well-prepared with strong evidence. We prepare our clients thoroughly for the follow-up hearing to ensure the protections secured in the emergency order are maintained.",
                },
              ].map((faq) => (
                <div class="p-5 bg-teal-50 rounded-xl border-l-4 border-teal-600">
                  <h4 class="font-semibold text-teal-800 text-sm mb-2">{faq.q}</h4>
                  <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-red-900 text-white rounded-2xl p-7 sticky top-24">
            <div class="text-3xl mb-3">🚨</div>
            <h3 class="font-serif font-bold text-xl mb-3">Is Your Child in Danger?</h3>
            <p class="text-red-200 text-sm mb-5">If your child faces an immediate threat, every moment counts. Contact us now for emergency legal assistance.</p>
            <a href="tel:3012898917" class="block text-center bg-red-600 hover:bg-red-700 text-white font-bold py-4 rounded-lg mb-3 transition-colors text-lg">(301) 289-8917</a>
            <a href="/free-consultation" class="block text-center border border-white text-white hover:bg-white hover:text-red-900 font-semibold py-3 rounded-lg text-sm transition-colors">Emergency Consultation</a>

            <p class="text-red-300 text-xs text-center mt-4">For life-threatening situations, call 911 first.</p>
          </div>

          <div class="bg-white border border-gray-200 rounded-xl p-6">
            <h4 class="font-semibold text-teal-800 mb-4">Act Immediately If You See:</h4>
            <ul class="space-y-2">
              {[
                "Physical injuries on your child",
                "Your child being taken without permission",
                "Threats to flee with your child",
                "Evidence of drug/alcohol abuse at home",
                "Reports of abuse from your child",
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <div class="w-5 h-5 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="text-red-600 text-xs font-bold">!</span>
                  </div>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-white border border-gray-200 rounded-xl p-6">
            <h4 class="font-semibold text-teal-800 mb-4">Related Services</h4>
            <ul class="space-y-2">
              {[
                { label: "Father's Rights", href: "/fathers-rights" },
                { label: "Mother's Rights", href: "/mothers-rights" },
                { label: "Custody Modifications", href: "/custody-modifications" },
                { label: "Visitation Rights", href: "/visitation-rights" },
              ].map((link) => (
                <li>
                  <a href={link.href} class="flex items-center gap-2 text-teal-600 hover:text-teal-800 text-sm transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ConsultationCTA
    heading="Don't Wait — Protect Your Child Now"
    subtext="Emergency custody situations can change rapidly. Our Maryland attorneys are experienced in fast-moving emergency filings. Contact us today for immediate legal assistance."
  />
</BaseLayout>
