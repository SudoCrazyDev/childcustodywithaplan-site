---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Child Custody with a Plan"
  description="The page you are looking for could not be found. Visit Child Custody with a Plan for Maryland child custody and family law representation."
  noIndex={true}
>
  <section class="bg-teal py-20 min-h-screen flex items-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="font-serif text-9xl font-bold text-white opacity-20 mb-2">404</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-white mb-6 -mt-8 relative z-10">
        Page Not Found
      </h1>
      <p class="text-lg text-teal-100 mb-10 leading-relaxed max-w-xl mx-auto">
        The page you are looking for does not exist or may have been moved. Let us help you find what you need.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mb-14">
        <a href="/" class="btn-primary">Return Home</a>
        <a href="/contact" class="btn-secondary">Contact Us</a>
        <a href="/free-consultation" class="btn-secondary">Free Consultation</a>
      </div>
      <div class="bg-white bg-opacity-10 rounded-sm p-8 max-w-2xl mx-auto">
        <h2 class="font-serif text-2xl font-bold text-white mb-6">Quick Links</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {[
            { label: 'Child Custody', href: '/child-custody' },
            { label: 'Divorce', href: '/divorce' },
            { label: 'Asset Division', href: '/asset-division' },
            { label: 'Spousal Support', href: '/spousal-support' },
            { label: 'High Net Worth Divorce', href: '/high-net-worth-divorce' },
            { label: 'Our Attorneys', href: '/attorneys' },
            { label: 'About the Firm', href: '/about' },
            { label: 'Blog', href: '/blog' },
            { label: 'Contact', href: '/contact' },
          ].map((link) => (
            <a href={link.href} class="bg-white bg-opacity-10 text-white text-sm py-2.5 px-3 rounded-sm hover:bg-white hover:text-teal transition-colors font-medium">
              {link.label}
            </a>
          ))}
        </div>
        <div class="mt-8 pt-8 border-t border-white border-opacity-20">
          <p class="text-teal-200 text-sm mb-3">Need immediate assistance?</p>
          <a href="tel:3012898917" class="text-gold font-bold text-xl hover:text-white transition-colors">(301) 289-8917</a>
          <p class="text-teal-300 text-sm mt-1">Mon–Fri 9AM–9PM</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
