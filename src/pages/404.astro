---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Child Custody with a Plan"
  description="The page you're looking for doesn't exist. Return to the Child Custody with a Plan homepage or contact us for help."
  noindex={true}
>
  <section class="teal-gradient min-h-[70vh] flex items-center justify-center text-white relative overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold-400 rounded-full opacity-10 blur-3xl"></div>
    <div class="max-w-2xl mx-auto px-4 text-center relative z-10">
      <div class="text-8xl font-serif font-bold text-gold-400 mb-4">404</div>
      <h1 class="font-serif font-bold text-3xl md:text-4xl text-white mb-4">
        Page Not Found
      </h1>
      <p class="text-teal-100 text-lg mb-8 leading-relaxed">
        We couldn't find the page you're looking for. It may have been moved, renamed, or may not exist. Let us help you find what you need.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
        <a href="/" class="btn-primary !py-4 !px-8">
          Return to Homepage
        </a>
        <a href="/contact" class="btn-secondary !py-4 !px-8">
          Contact Us
        </a>
      </div>

      <!-- Quick links -->
      <div class="bg-teal-600/30 backdrop-blur rounded-2xl p-6 mt-4">
        <p class="text-teal-200 font-semibold mb-4">Looking for one of these?</p>
        <div class="grid grid-cols-2 gap-2 text-sm">
          {[
            ['Child Custody', '/child-custody'],
            ['Custody Modification', '/child-custody-modification'],
            ['Divorce', '/divorce'],
            ['Spousal Support', '/spousal-support'],
            ['Our Attorneys', '/attorneys'],
            ['Free Consultation', '/free-consultation'],
            ['Contact Us', '/contact'],
            ['All Services', '/services'],
          ].map(([label, href]) => (
            <a href={href} class="text-teal-100 hover:text-gold-400 transition-colors py-1">
              → {label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
