---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Child Custody with a Plan"
  description="The page you're looking for doesn't exist. Visit Child Custody with a Plan to find information about Maryland divorce, child custody, spousal support, and family law."
  ogTitle="Page Not Found | Child Custody with a Plan"
  ogDescription="We couldn't find that page. Browse our Maryland family law resources or contact us for help."
>

  <section class="min-h-[70vh] flex items-center bg-gray-50">
    <div class="max-w-3xl mx-auto px-6 py-20 text-center">

      <!-- 404 Display -->
      <div class="mb-8">
        <p class="text-8xl md:text-9xl font-bold text-[#0D6E6E]/15 leading-none select-none">404</p>
        <div class="-mt-8 relative z-10">
          <div class="w-16 h-16 bg-[#0D6E6E] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">⚖️</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Page Not Found</h1>
          <p class="text-gray-600 max-w-lg mx-auto">
            We couldn't find the page you're looking for. It may have moved, been updated, or never existed. Let us help you find what you need.
          </p>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 mb-8 text-left">
        <h2 class="text-lg font-bold text-gray-900 mb-4 text-center">You might be looking for:</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {[
            { title: "Divorce Services", link: "/divorce", icon: "⚖️" },
            { title: "Child Custody", link: "/child-custody", icon: "👨‍👩‍👧" },
            { title: "Spousal Support / Alimony", link: "/spousal-support", icon: "💰" },
            { title: "Asset Division", link: "/asset-division", icon: "🏠" },
            { title: "High-Net-Worth Divorce", link: "/high-net-worth-divorce", icon: "📈" },
            { title: "Divorce for Professionals", link: "/divorce-lawyer-for-professionals", icon: "💼" },
            { title: "Business & Divorce", link: "/divorces-involving-businesses", icon: "🏢" },
            { title: "Custody Modification", link: "/child-custody-modification", icon: "📋" },
            { title: "Free Consultation", link: "/free-consultation", icon: "📅" },
            { title: "Our Attorneys", link: "/our-attorneys", icon: "👥" },
            { title: "Resources & Blog", link: "/blog", icon: "📖" },
            { title: "Contact Us", link: "/contact", icon: "✉️" }
          ].map(link => (
            <a
              href={link.link}
              class="flex items-center gap-3 p-3 rounded-lg bg-gray-50 hover:bg-[#0D6E6E]/5 hover:text-[#0D6E6E] transition-colors group"
            >
              <span class="text-xl">{link.icon}</span>
              <span class="text-gray-700 group-hover:text-[#0D6E6E] font-medium text-sm">{link.title}</span>
              <span class="ml-auto text-gray-300 group-hover:text-[#D4A843] text-sm">→</span>
            </a>
          ))}
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <a href="/" class="bg-[#0D6E6E] text-white font-bold px-8 py-4 rounded-lg hover:bg-[#0a5a5a] transition-colors">
          Go to Homepage
        </a>
        <a href="/free-consultation" class="bg-[#D4A843] text-white font-bold px-8 py-4 rounded-lg hover:bg-[#b8902f] transition-colors">
          Book Free Consultation
        </a>
      </div>

      <!-- Contact Info -->
      <div class="bg-[#0D6E6E] text-white rounded-xl p-5">
        <p class="font-semibold mb-1">Need immediate help? Call us directly:</p>
        <a href="tel:3012898917" class="text-2xl font-bold text-[#D4A843] hover:text-white transition-colors">(301) 289-8917</a>
        <p class="text-white/60 text-sm mt-1">Mon–Fri 9AM–9PM · Rockville & Baltimore</p>
      </div>

    </div>
  </section>

</BaseLayout>
