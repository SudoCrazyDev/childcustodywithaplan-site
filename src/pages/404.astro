---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found | Divorce With A Plan"
  description="The page you're looking for doesn't exist. Return to the homepage or contact Divorce With A Plan at (240) 269-3592."
  ogTitle="Page Not Found | Divorce With A Plan"
  ogDescription="This page doesn't exist. Visit our homepage or contact our Maryland divorce attorneys directly."
>
  <section class="min-h-[70vh] flex items-center justify-center py-20 px-4 bg-slate-50">
    <div class="max-w-2xl mx-auto text-center">
      <div class="text-8xl font-bold text-amber-500 mb-4">404</div>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
        Page Not Found
      </h1>
      <p class="text-lg text-slate-600 mb-8">
        The page you're looking for doesn't exist or may have been moved. Let's get you back on track.
      </p>

      <!-- Quick Links -->
      <div class="grid sm:grid-cols-2 gap-4 mb-10 text-left">
        {[
          { href: "/", label: "Homepage", desc: "Return to the Divorce With A Plan homepage" },
          { href: "/divorce", label: "Divorce Services", desc: "Learn about our Maryland divorce representation" },
          { href: "/child-custody", label: "Child Custody", desc: "Maryland child custody attorneys" },
          { href: "/free-consultation", label: "Free Consultation", desc: "Schedule a free consultation with our team" },
          { href: "/high-net-worth-divorce", label: "High-Asset Divorce", desc: "High-net-worth divorce representation" },
          { href: "/blog", label: "Blog", desc: "Maryland family law articles and guides" }
        ].map(link => (
          <a href={link.href} class="flex items-start gap-3 bg-white border border-slate-200 rounded-lg p-4 hover:border-amber-400 hover:shadow-sm transition-all group">
            <span class="text-amber-500 font-bold mt-0.5 group-hover:translate-x-0.5 transition-transform">→</span>
            <div>
              <span class="font-semibold text-slate-900 block">{link.label}</span>
              <span class="text-sm text-slate-500">{link.desc}</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Contact -->
      <div class="bg-slate-900 text-white rounded-2xl p-8">
        <h2 class="text-xl font-bold mb-3">Need Immediate Assistance?</h2>
        <p class="text-slate-300 mb-6">Our Maryland divorce attorneys are ready to help. Reach out directly:</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:2402693592" class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 px-6 rounded-lg transition-colors">
            📞 (240) 269-3592
          </a>
          <a href="/free-consultation" class="border-2 border-white text-white hover:bg-white hover:text-slate-900 font-bold py-3 px-6 rounded-lg transition-colors">
            Schedule Free Consultation
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
