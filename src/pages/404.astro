---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Child Custody with a Plan"
  description="The page you're looking for doesn't exist. Visit our homepage or contact Child Custody with a Plan — Maryland family law attorneys in Rockville and Baltimore."
  noindex={true}
>
  <section class="bg-gradient-to-br from-teal-900 to-teal-600 text-white min-h-[70vh] flex items-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
      <div class="text-8xl font-serif font-bold text-gold mb-4 opacity-80">404</div>
      <h1 class="text-3xl sm:text-4xl font-serif font-bold mb-4">
        Page Not Found
      </h1>
      <p class="text-lg text-teal-100 mb-8 max-w-xl mx-auto leading-relaxed">
        The page you're looking for doesn't exist or may have moved. Let us help you find what you need.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a href="/" class="btn-primary text-base px-8 py-4">
          Go to Homepage
        </a>
        <a href="/contact" class="btn-white text-base px-8 py-4">
          Contact Us
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-2xl mx-auto">
        {[
          { label: 'Child Custody', href: '/child-custody' },
          { label: 'Divorce', href: '/divorce' },
          { label: 'Our Attorneys', href: '/attorneys' },
          { label: 'Free Consultation', href: '/free-consultation' },
        ].map((link) => (
          <a
            href={link.href}
            class="bg-teal-700 hover:bg-teal-600 text-white text-sm font-medium px-4 py-3 rounded-xl transition-colors text-center"
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="mt-10 text-teal-200 text-sm">
        Need help immediately? Call us: <a href="tel:+13012898917" class="text-gold font-bold hover:text-gold-300">(301) 289-8917</a>
      </div>
    </div>
  </section>
</BaseLayout>
