---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const services = [
  {
    number: '01',
    icon: '⚖️',
    title: 'Divorce',
    href: '/divorce',
    tagline: 'Contested & Uncontested Maryland Divorce',
    desc: 'Whether you are pursuing an uncontested divorce by agreement or facing a contested divorce requiring full litigation, our attorneys provide the strategic representation you need to reach a resolution that protects your interests.',
    highlights: ['Contested divorce representation', 'Uncontested divorce guidance', 'Property and debt negotiation', 'Separation agreement drafting', 'Maryland grounds for divorce'],
    counties: ['Baltimore City', 'Montgomery County', 'Baltimore County', 'Howard County'],
  },
  {
    number: '02',
    icon: '🏠',
    title: 'Asset Division',
    href: '/asset-division',
    tagline: 'Equitable Distribution Under Maryland Law',
    desc: 'Maryland is an equitable distribution state — meaning marital property is divided fairly, but not always equally. Our attorneys fight to ensure you receive your fair share of all marital assets, from the family home to retirement accounts.',
    highlights: ['Marital vs. separate property analysis', 'Real estate division strategy', 'Retirement account (QDRO) division', 'Investment and bank account division', 'Debt allocation'],
    counties: ['All Maryland Counties'],
  },
  {
    number: '03',
    icon: '🏢',
    title: 'Divorces Involving Businesses',
    href: '/divorces-involving-businesses',
    tagline: 'Business Valuation, Buyout & Co-Ownership',
    desc: 'When a business is part of your marriage, the stakes in divorce become exponentially more complex. We work with professional business valuators and financial experts to protect your business interests — whether you own it alone or with your spouse.',
    highlights: ['Professional business valuation', 'Buyout negotiation', 'Co-ownership agreements', 'LLC, S-Corp, and partnership interests', 'Business income analysis'],
    counties: ['Montgomery County', 'Baltimore', 'Howard County'],
  },
  {
    number: '04',
    icon: '💼',
    title: 'Divorce for Professionals',
    href: '/divorce-lawyer-for-professionals',
    tagline: 'Discreet Representation for Executives & High Earners',
    desc: 'Doctors, executives, attorneys, and other high-earning professionals face unique challenges in divorce — from protecting professional licenses to managing public reputation. We provide the discreet, strategic representation that professionals demand.',
    highlights: ['Professional license protection', 'Executive compensation analysis', 'Business interest protection', 'Media-sensitive handling', 'Minimal career disruption strategy'],
    counties: ['Montgomery County', 'Howard County', 'Baltimore County'],
  },
  {
    number: '05',
    icon: '💎',
    title: 'High Net Worth Divorce',
    href: '/high-net-worth-divorce',
    tagline: 'Complex Asset Portfolios, Real Estate & Investments',
    desc: 'High-asset divorces require a different level of legal sophistication. Our team handles complex portfolios including investment accounts, multiple real estate holdings, retirement assets, business interests, and international assets with the strategic precision these cases demand.',
    highlights: ['Complex portfolio division', 'Multiple real estate properties', 'Offshore and international assets', 'Investment and brokerage accounts', 'Pension and retirement planning'],
    counties: ['Montgomery County', 'Baltimore', 'Howard County', 'Anne Arundel County'],
  },
  {
    number: '06',
    icon: '💰',
    title: 'Spousal Support',
    href: '/spousal-support',
    tagline: 'Maryland Alimony Law & Modification',
    desc: 'Maryland recognizes several types of alimony — pendente lite (temporary), rehabilitative, and indefinite. Whether you are seeking support or defending against it, our attorneys build the strongest possible case under Maryland family law.',
    highlights: ['Pendente lite support', 'Rehabilitative alimony', 'Indefinite alimony arguments', 'Spousal support modification', 'Income and lifestyle analysis'],
    counties: ['All Maryland Counties'],
  },
  {
    number: '07',
    icon: '👨‍👩‍👧',
    title: 'Child Custody',
    href: '/child-custody',
    tagline: 'Legal & Physical Custody, Parenting Plans',
    desc: "Child custody is the heart of what we do. We represent parents in all types of Maryland custody proceedings — building parenting plans centered on the child's best interests while powerfully advocating for your parental rights.",
    highlights: ['Legal custody determination', 'Physical custody arrangements', 'Parenting plan development', 'Joint vs. sole custody', 'Best interests standard advocacy'],
    counties: ['All Maryland Counties'],
  },
  {
    number: '08',
    icon: '📋',
    title: 'Child Custody Modification',
    href: '/child-custody-modification',
    tagline: 'Post-Divorce Custody Order Modifications',
    desc: 'Life changes — and custody orders should reflect those changes. When a material change in circumstances affects your family, our attorneys build the legal case needed to modify an existing custody order in Maryland family court.',
    highlights: ['Material change in circumstances', 'Relocation custody disputes', 'Parental fitness changes', 'Agreement-based modifications', 'Emergency custody modifications'],
    counties: ['All Maryland Counties'],
  },
];
---

<BaseLayout
  title="Practice Areas | Child Custody with a Plan — Maryland Family Law Services"
  description="Child Custody with a Plan offers 8 comprehensive family law practice areas in Maryland: divorce, asset division, business divorce, divorce for professionals, high net worth divorce, spousal support, child custody, and custody modification."
>
  <!-- Hero -->
  <section class="teal-gradient text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold-400 rounded-full opacity-10 blur-3xl"></div>
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <div class="max-w-3xl">
        <p class="text-gold-400 font-semibold text-sm uppercase tracking-widest mb-3">What We Do</p>
        <h1 class="font-serif font-bold text-4xl md:text-5xl text-white leading-tight mb-6">
          Maryland Family Law Practice Areas
        </h1>
        <p class="text-teal-100 text-xl leading-relaxed">
          Eight comprehensive practice areas, one strategic mission: protecting Maryland families with expert legal representation and the PROMISE Framework™.
        </p>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="space-y-8">
        {services.map((service) => (
          <div class="bg-white rounded-2xl shadow-md hover:shadow-xl transition-shadow border border-gray-100 overflow-hidden group">
            <div class="grid grid-cols-1 lg:grid-cols-4">
              <!-- Icon & number sidebar -->
              <div class="lg:col-span-1 teal-gradient p-8 flex flex-col justify-between text-white">
                <div>
                  <div class="text-5xl font-serif font-bold text-teal-400/50 mb-4">{service.number}</div>
                  <div class="text-5xl mb-4">{service.icon}</div>
                  <h2 class="font-serif font-bold text-2xl text-white mb-2">{service.title}</h2>
                  <p class="text-gold-400 text-sm font-medium">{service.tagline}</p>
                </div>
                <a href={service.href} class="mt-6 inline-block bg-gold-400 hover:bg-gold-500 text-white font-semibold px-5 py-2.5 rounded-lg text-sm transition-colors text-center">
                  Learn More →
                </a>
              </div>
              <!-- Content -->
              <div class="lg:col-span-3 p-8">
                <p class="text-gray-700 text-lg leading-relaxed mb-6">{service.desc}</p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <h3 class="font-semibold text-teal-700 mb-3 text-sm uppercase tracking-wide">Key Services Include:</h3>
                    <ul class="space-y-2">
                      {service.highlights.map((h) => (
                        <li class="flex items-center gap-2 text-sm text-gray-700">
                          <span class="w-1.5 h-1.5 bg-gold-400 rounded-full flex-shrink-0"></span>
                          {h}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <h3 class="font-semibold text-teal-700 mb-3 text-sm uppercase tracking-wide">Counties Served:</h3>
                    <div class="flex flex-wrap gap-2">
                      {service.counties.map((c) => (
                        <span class="bg-teal-50 text-teal-700 text-xs px-3 py-1 rounded-full border border-teal-200">
                          {c}
                        </span>
                      ))}
                    </div>
                    <div class="mt-6">
                      <a href="/free-consultation" class="text-teal-600 font-semibold text-sm hover:text-teal-700 flex items-center gap-1">
                        Schedule free consultation
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
