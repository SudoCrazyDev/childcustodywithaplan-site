---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';

const services = [
  {
    title: 'Divorce',
    subtitle: 'Contested & Uncontested',
    description: 'Comprehensive divorce representation — from uncontested dissolutions to complex contested proceedings. We guide you through every step with strategy and clarity.',
    href: '/divorce',
    icon: '⚖️',
    features: ['Contested Divorce', 'Uncontested Divorce', 'Separation Agreements', 'Legal Separation', 'Divorce Mediation'],
  },
  {
    title: 'Asset Division',
    subtitle: 'Equitable Distribution',
    description: 'Maryland is an equitable distribution state. We ensure fair division of marital property — real estate, retirement accounts, investments, and personal property.',
    href: '/asset-division',
    icon: '🏠',
    features: ['Marital Property Identification', 'Real Estate Division', 'Retirement Accounts', 'Investment Portfolios', 'Debt Allocation'],
  },
  {
    title: 'Divorces Involving Businesses',
    subtitle: 'Business Valuation & Division',
    description: 'When a family business is part of your divorce, you need specialized counsel. We handle business valuations, buyout negotiations, and equitable business division.',
    href: '/divorces-involving-businesses',
    icon: '🏢',
    features: ['Business Valuation', 'Buyout Negotiations', 'Business Division Strategies', 'Forensic Accounting Coordination', 'Partnership Dissolution'],
  },
  {
    title: 'Divorce for Professionals',
    subtitle: 'Doctors, Executives & High-Profile Clients',
    description: 'Discreet, sophisticated representation for professionals with complex compensation packages, partnerships, licenses, and reputational considerations.',
    href: '/divorce-lawyer-for-professionals',
    icon: '👩‍⚕️',
    features: ['Physicians & Medical Professionals', 'C-Suite Executives', 'Partnership Interests', 'Stock Options & RSUs', 'Professional Licenses'],
  },
  {
    title: 'High Net Worth Divorce',
    subtitle: 'Complex Asset Litigation',
    description: 'For divorces involving significant wealth — real estate portfolios, business interests, investments, trusts, and international assets — precision and sophistication matter.',
    href: '/high-net-worth-divorce',
    icon: '💼',
    features: ['Complex Asset Division', 'Real Estate Portfolios', 'Investment Accounts', 'Trust & Estate Issues', 'International Assets'],
  },
  {
    title: 'Spousal Support',
    subtitle: 'Alimony & Support Orders',
    description: 'Strategic advocacy for spousal support, pendente lite support, rehabilitative alimony, and indefinite alimony — whether you are seeking or contesting support.',
    href: '/spousal-support',
    icon: '🤝',
    features: ['Alimony Negotiation', 'Pendente Lite Support', 'Rehabilitative Alimony', 'Indefinite Alimony', 'Support Modification'],
  },
  {
    title: 'Child Custody',
    subtitle: 'Legal & Physical Custody',
    description: 'Our core practice area. We advocate for parenting arrangements that truly serve your children\'s best interests — from parenting plans to contested custody hearings.',
    href: '/child-custody',
    icon: '👨‍👩‍👧',
    features: ['Legal Custody', 'Physical Custody', 'Parenting Plans', 'Best Interests Analysis', 'Custody Mediation'],
    featured: true,
  },
  {
    title: 'Child Custody Modification',
    subtitle: 'Post-Divorce Custody Changes',
    description: 'Life changes — and so should your custody order when circumstances materially shift. We handle post-divorce modifications efficiently and effectively.',
    href: '/child-custody-modification',
    icon: '🔄',
    features: ['Material Change of Circumstances', 'Relocation Cases', 'Schedule Modifications', 'Emergency Modifications', 'Contempt Proceedings'],
  },
];
---

<BaseLayout
  title="Practice Areas | Maryland Family Law Services | Child Custody with a Plan"
  description="Child Custody with a Plan offers comprehensive Maryland family law services: divorce, child custody, asset division, spousal support, high net worth divorce, and more. Rockville & Baltimore."
>
  <Hero
    variant="interior"
    subtitle="Our Practice Areas"
    title="Comprehensive Maryland Family Law Services"
    description="From child custody strategy to complex divorce litigation, our attorneys provide full-spectrum family law representation across Maryland, Virginia, and D.C."
    ctaText="Free Consultation"
    ctaHref="/free-consultation"
  />

  <!-- Services grid -->
  <section class="bg-offwhite py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-gold font-semibold text-sm uppercase tracking-widest mb-3">What We Handle</p>
        <h2 class="section-heading">8 Areas of Family Law Excellence</h2>
        <div class="gold-bar mx-auto"></div>
        <p class="section-subheading mx-auto text-center">
          Every practice area is approached with the same commitment: a clear strategy, relentless advocacy, and genuine care for your family.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {services.map((service) => (
          <div class={`bg-white rounded-2xl p-7 border-2 hover:shadow-card-hover transition-all group ${service.featured ? 'border-gold' : 'border-gray-100 hover:border-teal'}`}>
            {service.featured && (
              <div class="inline-flex items-center gap-1.5 bg-gold text-white text-xs font-semibold px-3 py-1 rounded-full mb-4">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                Core Practice
              </div>
            )}
            <div class="flex items-start gap-4">
              <div class="text-3xl shrink-0">{service.icon}</div>
              <div class="flex-1">
                <div class="text-gold text-xs font-semibold uppercase tracking-wider mb-1">{service.subtitle}</div>
                <h3 class="text-xl font-serif font-bold text-charcoal mb-3 group-hover:text-teal transition-colors">{service.title}</h3>
                <p class="text-gray-600 leading-relaxed text-sm mb-5">{service.description}</p>

                <div class="flex flex-wrap gap-2 mb-5">
                  {service.features.map((f) => (
                    <span class="bg-teal-50 text-teal text-xs px-2.5 py-1 rounded-full font-medium">{f}</span>
                  ))}
                </div>

                <a
                  href={service.href}
                  class="inline-flex items-center gap-2 text-teal font-semibold text-sm hover:text-teal-600 transition-colors"
                >
                  Learn More About This Service
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why choose us for family law -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-gold font-semibold text-sm uppercase tracking-widest mb-3">Our Approach</p>
          <h2 class="section-heading">Strategy That Sets Us Apart</h2>
          <div class="gold-bar"></div>
          <p class="text-gray-700 leading-relaxed mb-5">
            In every practice area, our approach is defined by our proprietary <strong>PROMISE Framework™</strong> — a 7-step methodology that transforms complex family law matters into clear, manageable strategies with defined milestones and goals.
          </p>
          <p class="text-gray-700 leading-relaxed mb-5">
            We don't believe in one-size-fits-all representation. Every case is unique, every family is different, and every strategy we build is custom-crafted to your specific circumstances, goals, and priorities.
          </p>
          <p class="text-gray-700 leading-relaxed mb-7">
            With offices in Rockville and Baltimore, our attorneys are equipped to handle family law matters throughout Maryland — from Montgomery County and Howard County to Baltimore City and the Eastern Shore.
          </p>
          <a href="/about#promise" class="btn-primary">Learn About Our PROMISE Process</a>
        </div>

        <div class="grid grid-cols-2 gap-5">
          {[
            { title: 'Free Consultation', desc: 'Start with a complimentary, no-obligation case evaluation.', icon: '💬' },
            { title: 'Strategic Planning', desc: 'A custom legal strategy from day one of your engagement.', icon: '♟️' },
            { title: 'Clear Communication', desc: 'Regular updates and transparent guidance at every stage.', icon: '📋' },
            { title: 'Two Offices', desc: 'Convenient locations in Rockville and Baltimore.', icon: '📍' },
            { title: '3 Jurisdictions', desc: 'Licensed in Maryland, Virginia, and Washington D.C.', icon: '🗺️' },
            { title: 'Founded 2013', desc: 'Over a decade of Maryland family law experience.', icon: '⚖️' },
          ].map((item) => (
            <div class="bg-offwhite rounded-xl p-5 border border-gray-100">
              <div class="text-2xl mb-3">{item.icon}</div>
              <h3 class="font-semibold text-charcoal text-sm mb-1">{item.title}</h3>
              <p class="text-xs text-gray-500 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Not Sure Which Service You Need?"
    description="Schedule a free consultation and our attorneys will help you understand your options and build the right plan for your situation."
  />
</BaseLayout>
