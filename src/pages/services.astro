---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const practiceAreas = [
  {
    id: 'child-custody',
    icon: '👨‍👧‍👦',
    title: 'Child Custody & Visitation',
    summary: 'Strategic advocacy for parenting arrangements that protect your children\'s best interests.',
    description: 'Child custody disputes are among the most emotionally charged legal matters families face. Our attorneys provide strategic, compassionate representation designed to achieve parenting arrangements that truly serve your children\'s wellbeing — while protecting your parental rights every step of the way.',
    details: [
      'Legal custody (decision-making authority) and physical custody arrangements',
      'Primary and shared parenting plans tailored to your family\'s needs',
      'Visitation schedules and holiday/vacation planning',
      'Interstate custody disputes and relocation cases',
      'Emergency custody orders when children are at risk',
      'Custody evaluations and guardian ad litem proceedings',
    ],
  },
  {
    id: 'divorce',
    icon: '📋',
    title: 'Divorce',
    summary: 'Comprehensive divorce representation — protecting your rights from start to finish.',
    description: 'Whether your divorce is uncontested or highly contested, our attorneys provide the strategic representation you need to achieve a fair resolution. We handle all aspects of the divorce process, from initial filing through final decree, ensuring your rights and interests are protected throughout.',
    details: [
      'Contested and uncontested divorce proceedings',
      'Separation agreements and consent orders',
      'Divorce involving minor children and custody arrangements',
      'Fault-based and no-fault divorce in Maryland',
      'Property classification (marital vs. non-marital)',
      'Business interests and complex financial structures',
    ],
  },
  {
    id: 'high-asset-divorce',
    icon: '🏛️',
    title: 'High-Asset Divorce',
    summary: 'Sophisticated representation for complex divorces involving significant assets.',
    description: 'When significant wealth, business interests, or complex financial portfolios are involved, divorce requires a higher level of strategic and financial sophistication. Our firm has experience handling high-net-worth divorce cases where the stakes — and the complexity — are elevated.',
    details: [
      'Business valuation and division of business interests',
      'Investment portfolios, retirement accounts, and pension plans',
      'Real estate holdings and commercial property',
      'Executive compensation packages and deferred income',
      'Stock options, RSUs, and equity compensation',
      'Forensic accounting and hidden asset discovery',
    ],
  },
  {
    id: 'spousal-support',
    icon: '🤝',
    title: 'Spousal Support & Alimony',
    summary: 'Fair alimony advocacy — whether you\'re seeking support or defending against it.',
    description: 'Spousal support determinations in Maryland involve numerous factors, from the length of the marriage to each party\'s earning capacity and contributions. Our attorneys understand how Maryland courts approach alimony and provide strategic counsel whether you\'re seeking support or responding to a claim.',
    details: [
      'Pendente lite (temporary) alimony during divorce proceedings',
      'Rehabilitative alimony to support career re-entry',
      'Indefinite alimony in long-term marriages',
      'Alimony modification when circumstances change',
      'Enforcement of alimony obligations',
      'Alimony in high-income and high-asset situations',
    ],
  },
  {
    id: 'asset-division',
    icon: '⚖️',
    title: 'Asset & Property Division',
    summary: 'Equitable distribution of marital property — protecting what you\'ve built.',
    description: 'Maryland follows equitable distribution principles, meaning marital property is divided fairly — but not necessarily equally. Our attorneys work to ensure a thorough accounting of all marital assets and advocate for a division that truly reflects your contributions and needs.',
    details: [
      'Classification of marital vs. separate property',
      'Division of real estate and the marital home',
      'Retirement accounts and pension QDROs',
      'Marital debt allocation and credit protection',
      'Inheritance and gifted asset treatment',
      'Complex financial instrument valuation',
    ],
  },
  {
    id: 'custody-modification',
    icon: '🔄',
    title: 'Custody & Support Modification',
    summary: 'Modifying existing orders when your circumstances have substantially changed.',
    description: 'Life changes — and sometimes existing custody, visitation, or support orders no longer reflect your family\'s current reality. Our attorneys can help you petition to modify existing orders when there has been a material change in circumstances, or defend against modification attempts.',
    details: [
      'Child custody and visitation modification petitions',
      'Child support modification (income changes, new children, relocation)',
      'Spousal support modification and termination',
      'Relocation petitions and out-of-state moves',
      'Emergency modification for urgent safety concerns',
      'Enforcement of existing custody and support orders',
    ],
  },
];
---

<BaseLayout
  title="Practice Areas | Child Custody, Divorce & Family Law | Maryland"
  description="Comprehensive family law services in Maryland — child custody, divorce, high-asset divorce, spousal support, asset division, and custody modification. Strategic representation throughout Montgomery County, Baltimore, and beyond."
>

  <Hero
    subtitle="What We Handle"
    title="Comprehensive Maryland Family Law Representation"
    description="From child custody to complex high-asset divorce, our attorneys provide strategic, knowledgeable representation across every major area of Maryland family law."
    primaryCta={{ label: "Schedule Free Consultation", href: "/contact" }}
    secondaryCta={{ label: "Meet Our Attorneys", href: "/attorneys" }}
    variant="compact"
  />

  <!-- Practice Area Overview Grid -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-2">Our Expertise</p>
        <h2 class="text-4xl font-serif font-bold text-[#0D6E6E] mb-4">Practice Areas</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          We focus exclusively on family law — giving you the benefit of deep, specialized expertise in every matter we handle.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {practiceAreas.map(area => (
          <a href={`#${area.id}`} class="group bg-white rounded-xl shadow-sm border border-gray-100 p-7 hover:shadow-md hover:border-[#0D6E6E]/20 transition-all">
            <div class="text-4xl mb-4">{area.icon}</div>
            <h3 class="text-xl font-serif font-bold text-[#0D6E6E] mb-2 group-hover:text-[#D4A843] transition-colors">{area.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{area.summary}</p>
            <div class="mt-4 text-[#D4A843] text-sm font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
              Learn more <span>→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Detailed Practice Area Sections -->
  {practiceAreas.map((area, index) => (
    <section id={area.id} class={`py-20 ${index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-start">
          <div class={index % 2 !== 0 ? 'lg:order-2' : ''}>
            <div class="text-5xl mb-5">{area.icon}</div>
            <h2 class="text-3xl font-serif font-bold text-[#0D6E6E] mb-4">{area.title}</h2>
            <p class="text-gray-600 leading-relaxed mb-6 text-lg">{area.description}</p>
            <a href="/contact" class="inline-block bg-[#D4A843] text-white font-semibold px-7 py-3 rounded hover:bg-[#B8902E] transition-colors">
              Discuss Your Case
            </a>
          </div>
          <div class={index % 2 !== 0 ? 'lg:order-1' : ''}>
            <div class="bg-[#0D6E6E] rounded-2xl p-8 text-white">
              <h4 class="text-[#D4A843] font-bold text-sm uppercase tracking-wider mb-5">What This Covers</h4>
              <ul class="space-y-3">
                {area.details.map(detail => (
                  <li class="flex items-start gap-3 text-sm text-white/80">
                    <span class="w-2 h-2 rounded-full bg-[#D4A843] flex-shrink-0 mt-1.5"></span>
                    {detail}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="py-16 bg-[#D4A843]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-serif font-bold text-white mb-4">Not Sure Where to Start?</h2>
      <p class="text-white/90 text-lg mb-8">
        Our free initial consultation helps us understand your situation and recommend the right path forward.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-[#D4A843] font-bold px-10 py-4 rounded hover:bg-gray-100 transition-colors">
          Book Free Consultation
        </a>
        <a href="/attorneys" class="border-2 border-white text-white font-semibold px-10 py-4 rounded hover:bg-white hover:text-[#D4A843] transition-colors">
          Meet Our Team
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
