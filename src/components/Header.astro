---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Attorneys', href: '/attorneys' },
  {
    label: 'Practice Areas',
    href: '/services',
    dropdown: [
      { label: 'Divorce', href: '/divorce' },
      { label: 'Asset Division', href: '/asset-division' },
      { label: 'Divorces Involving Businesses', href: '/divorces-involving-businesses' },
      { label: 'Divorce for Professionals', href: '/divorce-lawyer-for-professionals' },
      { label: 'High Net Worth Divorce', href: '/high-net-worth-divorce' },
      { label: 'Spousal Support', href: '/spousal-support' },
      { label: 'Child Custody', href: '/child-custody' },
      { label: 'Child Custody Modification', href: '/child-custody-modification' },
    ],
  },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <!-- Top bar -->
  <div class="bg-teal text-white text-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 flex flex-col sm:flex-row items-center justify-between gap-1">
      <div class="flex items-center gap-4 flex-wrap justify-center sm:justify-start">
        <a href="tel:+13012898917" class="flex items-center gap-1.5 hover:text-gold transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          (301) 289-8917
        </a>
        <span class="hidden sm:inline text-teal-300">|</span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
          </svg>
          Mon–Fri: 9AM–9PM
        </span>
      </div>
      <div class="flex items-center gap-4 flex-wrap justify-center sm:justify-end text-xs">
        <span>Rockville &amp; Baltimore, MD</span>
        <a href="/free-consultation" class="bg-gold text-white font-semibold px-3 py-1 rounded hover:bg-gold-500 transition-colors">
          Free Consultation
        </a>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <div class="w-10 h-10 bg-teal rounded-lg flex items-center justify-center">
          <span class="text-gold font-serif font-bold text-xl">C</span>
        </div>
        <div class="leading-tight">
          <div class="text-teal font-serif font-bold text-lg leading-none">Child Custody</div>
          <div class="text-gold font-semibold text-sm leading-none">with a Plan</div>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-6">
        {navLinks.map((link) =>
          link.dropdown ? (
            <div class="dropdown relative">
              <button class="nav-link flex items-center gap-1 py-2">
                {link.label}
                <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="dropdown-menu absolute top-full left-0 mt-1 w-64 bg-white rounded-xl shadow-xl border border-gray-100 py-2 z-50">
                {link.dropdown.map((item) => (
                  <a
                    href={item.href}
                    class={`block px-4 py-2.5 text-sm hover:bg-teal-50 hover:text-teal transition-colors ${currentPath === item.href ? 'text-teal font-semibold' : 'text-gray-700'}`}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class={`nav-link py-2 ${currentPath === link.href ? 'text-teal font-semibold border-b-2 border-teal' : ''}`}
            >
              {link.label}
            </a>
          )
        )}
      </nav>

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-3">
        <a href="/free-consultation" class="hidden lg:inline-block btn-primary text-sm">
          Free Consultation
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg text-teal hover:bg-teal-50 transition-colors"
          aria-label="Open menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 pb-4">
    <div class="max-w-7xl mx-auto px-4 pt-2 flex flex-col gap-1">
      {navLinks.map((link) =>
        link.dropdown ? (
          <div>
            <div class="px-3 py-2 text-sm font-semibold text-teal uppercase tracking-wider">{link.label}</div>
            {link.dropdown.map((item) => (
              <a href={item.href} class="block px-6 py-2 text-sm text-gray-700 hover:text-teal hover:bg-teal-50 rounded-lg transition-colors">
                {item.label}
              </a>
            ))}
          </div>
        ) : (
          <a href={link.href} class={`block px-3 py-2.5 rounded-lg font-medium hover:bg-teal-50 hover:text-teal transition-colors ${currentPath === link.href ? 'text-teal bg-teal-50' : 'text-gray-700'}`}>
            {link.label}
          </a>
        )
      )}
      <a href="/free-consultation" class="btn-primary mt-3 text-center">Schedule Free Consultation</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
