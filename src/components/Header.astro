---
// Standalone Header component (navigation already embedded in BaseLayout)
// This component can be used independently if needed for specialized pages
---

<header class="bg-white shadow-sm">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-20">
      <a href="/" class="flex items-center gap-3">
        <div class="w-10 h-10 bg-teal-600 rounded-lg flex items-center justify-center shadow-md">
          <svg class="w-6 h-6 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
          </svg>
        </div>
        <div>
          <div class="font-serif font-bold text-teal-700 text-base leading-tight">Child Custody</div>
          <div class="font-serif font-bold text-gold-500 text-base leading-tight">with a Plan</div>
        </div>
      </a>
      <a href="/free-consultation" class="btn-primary text-sm">Free Consultation</a>
    </div>
  </div>
</header>
