---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Attorneys', href: '/attorneys' },
  {
    label: 'Practice Areas',
    href: '/services',
    children: [
      { label: 'Divorce', href: '/divorce' },
      { label: 'Asset Division', href: '/asset-division' },
      { label: 'Divorces Involving Businesses', href: '/divorces-involving-businesses' },
      { label: 'Divorce for Professionals', href: '/divorce-lawyer-for-professionals' },
      { label: 'High Net Worth Divorce', href: '/high-net-worth-divorce' },
      { label: 'Spousal Support', href: '/spousal-support' },
      { label: 'Child Custody', href: '/child-custody' },
      { label: 'Child Custody Modification', href: '/child-custody-modification' },
    ],
  },
  { label: 'Resources', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="bg-white shadow-sm sticky top-0 z-50 border-b-2 border-gold-400">
  <!-- Top bar -->
  <div class="bg-teal-500 text-white text-sm py-2">
    <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row justify-between items-center gap-1">
      <div class="flex items-center gap-4">
        <a href="tel:3012898917" class="flex items-center gap-1.5 hover:text-gold-400 transition-colors font-medium">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          (301) 289-8917
        </a>
        <span class="hidden sm:inline text-teal-300">|</span>
        <span class="hidden sm:inline text-teal-100">Mon–Fri 9AM–9PM</span>
      </div>
      <div class="flex items-center gap-4">
        <span class="hidden md:inline text-teal-100 text-xs">Rockville &amp; Baltimore, Maryland</span>
        <a href="/free-consultation" class="bg-gold-400 hover:bg-gold-500 text-white font-semibold px-4 py-1 rounded transition-colors text-xs uppercase tracking-wide">
          Free Consultation
        </a>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="max-w-7xl mx-auto px-4" aria-label="Main navigation">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group flex-shrink-0">
        <div class="w-12 h-12 bg-teal-500 rounded-lg flex items-center justify-center shadow-md group-hover:bg-teal-600 transition-colors">
          <svg viewBox="0 0 40 40" class="w-8 h-8" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="14" r="6" fill="#D4A843"/>
            <path d="M8 34c0-6.627 5.373-12 12-12s12 5.373 12 12" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M20 26l4 4-4 4" stroke="#D4A843" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <div class="font-serif font-bold text-teal-500 text-lg leading-tight">Child Custody</div>
          <div class="font-serif font-bold text-gold-400 text-lg leading-tight">with a Plan</div>
        </div>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          item.children ? (
            <div class="relative group">
              <a
                href={item.href}
                class={`flex items-center gap-1 px-3 py-2 rounded-md font-medium text-sm transition-colors ${
                  isActive(item.href) ? 'text-teal-500' : 'text-gray-700 hover:text-teal-500'
                }`}
              >
                {item.label}
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </a>
              <!-- Dropdown -->
              <div class="absolute top-full left-1/2 -translate-x-1/2 mt-1 w-64 bg-white rounded-xl shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="py-2">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class={`block px-4 py-2.5 text-sm transition-colors ${
                        isActive(child.href)
                          ? 'bg-teal-50 text-teal-600 font-medium'
                          : 'text-gray-700 hover:bg-teal-50 hover:text-teal-600'
                      }`}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class={`px-3 py-2 rounded-md font-medium text-sm transition-colors ${
                isActive(item.href) ? 'text-teal-500' : 'text-gray-700 hover:text-teal-500'
              }`}
            >
              {item.label}
            </a>
          )
        ))}
        <a href="/free-consultation" class="ml-3 btn-primary text-sm !py-2.5 !px-5">
          Free Consultation
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md text-gray-700 hover:text-teal-500 hover:bg-teal-50 transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle menu"
      >
        <svg id="menu-open-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="menu-close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navItems.map((item) => (
        item.children ? (
          <div>
            <div class="px-3 py-2 text-xs font-bold uppercase tracking-wider text-teal-500">{item.label}</div>
            {item.children.map((child) => (
              <a
                href={child.href}
                class={`block px-5 py-2 text-sm rounded-md transition-colors ${
                  isActive(child.href) ? 'bg-teal-50 text-teal-600 font-medium' : 'text-gray-600 hover:bg-teal-50 hover:text-teal-600'
                }`}
              >
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a
            href={item.href}
            class={`block px-3 py-2 rounded-md font-medium transition-colors ${
              isActive(item.href) ? 'bg-teal-50 text-teal-600' : 'text-gray-700 hover:bg-teal-50 hover:text-teal-600'
            }`}
          >
            {item.label}
          </a>
        )
      ))}
      <div class="pt-3 pb-1">
        <a href="/free-consultation" class="btn-primary w-full block text-center">
          Free Consultation
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    btn?.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
