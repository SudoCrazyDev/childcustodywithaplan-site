---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About Us' },
  { href: '/attorneys', label: 'Our Attorneys' },
  { href: '/services', label: 'Practice Areas' },
  { href: '/process', label: 'Our Process' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-[#0D6E6E] shadow-lg sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo / Brand -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 bg-[#D4A843] rounded-lg flex items-center justify-center flex-shrink-0">
          <span class="text-white font-bold font-serif text-xl">C</span>
        </div>
        <div class="leading-tight">
          <span class="block text-white font-bold text-lg font-serif leading-none">Child Custody</span>
          <span class="block text-[#D4A843] text-sm font-medium tracking-wide">with a Plan</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-3 py-2 rounded text-sm font-medium transition-colors duration-150 ${
              currentPath === link.href
                ? 'text-[#D4A843] bg-white/10'
                : 'text-white/90 hover:text-white hover:bg-white/10'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA Button -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="tel:2402693592" class="text-white/80 hover:text-white text-sm transition-colors">
          (240) 269-3592
        </a>
        <a href="/contact" class="bg-[#D4A843] text-white text-sm font-semibold px-5 py-2.5 rounded hover:bg-[#B8902E] transition-colors duration-200">
          Free Consultation
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden text-white p-2 rounded hover:bg-white/10 transition-colors"
        aria-label="Toggle navigation menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-white/20 bg-[#095555]">
    <nav class="px-4 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="px-4 py-3 text-white/90 hover:text-white hover:bg-white/10 rounded font-medium transition-colors"
        >
          {link.label}
        </a>
      ))}
      <div class="mt-4 pt-4 border-t border-white/20 flex flex-col gap-3">
        <a href="tel:2402693592" class="text-[#D4A843] font-semibold text-center">
          (240) 269-3592
        </a>
        <a href="/contact" class="bg-[#D4A843] text-white font-semibold px-5 py-3 rounded text-center hover:bg-[#B8902E] transition-colors">
          Free Consultation
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
