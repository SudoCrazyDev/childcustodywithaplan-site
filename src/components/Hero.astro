---
export interface Props {
  heading: string;
  subheading?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
  bgClass?: string;
  overlay?: boolean;
  size?: 'lg' | 'md' | 'sm';
  centered?: boolean;
  /**
   * When provided, renders a native <picture>/<img> as the hero background
   * instead of a CSS background-image, so the browser can discover
   * and fetch the image early (critical for LCP).
   *
   * If imageSrcset400 / imageSrcset800 / imageSrcset1200 are also provided,
   * a full responsive <picture> element with WebP sources is rendered.
   * Otherwise falls back to a plain <img> using imageSrc.
   */
  imageSrc?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  /** WebP srcset variants for responsive <picture> element */
  imageSrcset400?: string;
  imageSrcset800?: string;
  imageSrcset1200?: string;
  imageSizes?: string;
}

const {
  heading,
  subheading,
  ctaText = 'Schedule a Free Consultation',
  ctaHref = '/free-consultation',
  ctaSecondaryText,
  ctaSecondaryHref,
  bgClass = 'bg-teal',
  overlay = false,
  size = 'lg',
  centered = false,
  imageSrc,
  imageAlt = '',
  imageWidth = 1200,
  imageHeight = 686,
  imageSrcset400,
  imageSrcset800,
  imageSrcset1200,
  imageSizes = '(max-width: 480px) 400px, (max-width: 1024px) 800px, 1200px',
} = Astro.props;

const sizeClasses = {
  lg: 'py-24 md:py-36',
  md: 'py-16 md:py-24',
  sm: 'py-10 md:py-16',
};

// Determine whether we have the full responsive WebP srcset trio
const hasResponsiveSrcset = !!(imageSrcset400 && imageSrcset800 && imageSrcset1200);
---

<section
  class={'relative overflow-hidden ' + (imageSrc ? '' : bgClass + ' ') + sizeClasses[size]}
  style={imageSrc ? 'min-height: 480px;' : ''}
>
  {imageSrc && (
    <>
      {hasResponsiveSrcset ? (
        /* ── Responsive <picture> with WebP srcset — LCP element ────────────
           • <source type="image/webp"> with 3 size variants lets the browser
             pick the smallest appropriate WebP for the viewport.
           • Fallback <img> uses the 1200w WebP directly (modern browsers only
             ever hit this if <source> is not matched, which is rare).
           • loading="eager" — this is the LCP element; must NOT be lazy.
           • fetchpriority="high" — signals to the browser this is the LCP.
           • decoding="async" — decodes off the main thread.
           • Explicit width/height — prevents CLS by reserving layout space.
        ─────────────────────────────────────────────────────────────────── */
        <picture class="absolute inset-0 w-full h-full" style="z-index:0;">
          <source
            srcset={`${imageSrcset400} 400w, ${imageSrcset800} 800w, ${imageSrcset1200} 1200w`}
            sizes={imageSizes}
            type="image/webp"
          />
          <img
            src={imageSrcset1200}
            alt={imageAlt}
            width={imageWidth}
            height={imageHeight}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover object-center"
            style="z-index:0;"
          />
        </picture>
      ) : (
        /* ── Plain <img> fallback when no WebP srcset is provided ───────── */
        <img
          src={imageSrc}
          alt={imageAlt}
          width={imageWidth}
          height={imageHeight}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover object-center"
          style="z-index:0;"
        />
      )}
      <!-- Dark overlay for text legibility -->
      <div class="absolute inset-0 bg-black" style="opacity:0.65;z-index:1;"></div>
    </>
  )}
  {!imageSrc && overlay && <div class="absolute inset-0 bg-teal bg-opacity-80"></div>}
  <div class={'max-w-7xl mx-auto px-4 sm:px-6 relative ' + (imageSrc ? 'z-10 py-24 md:py-32' : 'z-10 ') + (centered ? 'text-center' : '')}>
    <div class={centered ? 'max-w-3xl mx-auto' : 'max-w-3xl'}>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        {heading}
      </h1>
      {subheading && (
        <p class="text-lg md:text-xl text-teal-100 leading-relaxed mb-8">
          {subheading}
        </p>
      )}
      <slot />
      {(ctaText || ctaSecondaryText) && (
        <div class={'flex flex-wrap gap-4 ' + (centered ? 'justify-center' : '')}>
          {ctaText && (
            <a href={ctaHref} class="btn-primary">{ctaText}</a>
          )}
          {ctaSecondaryText && ctaSecondaryHref && (
            <a href={ctaSecondaryHref} class="btn-secondary">{ctaSecondaryText}</a>
          )}
        </div>
      )}
    </div>
  </div>
</section>
