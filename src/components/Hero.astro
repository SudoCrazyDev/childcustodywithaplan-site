---
export interface Props {
  heading: string;
  subheading?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
  bgClass?: string;
  overlay?: boolean;
  size?: 'lg' | 'md' | 'sm';
  centered?: boolean;
}

const {
  heading,
  subheading,
  ctaText = 'Schedule a Free Consultation',
  ctaHref = '/free-consultation',
  ctaSecondaryText,
  ctaSecondaryHref,
  bgClass = 'bg-teal',
  overlay = false,
  size = 'lg',
  centered = false,
} = Astro.props;

const sizeClasses = {
  lg: 'py-24 md:py-36',
  md: 'py-16 md:py-24',
  sm: 'py-10 md:py-16',
};
---

<section class={bgClass + ' relative ' + sizeClasses[size]}>
  {overlay && <div class="absolute inset-0 bg-teal bg-opacity-80"></div>}
  <div class={'max-w-7xl mx-auto px-4 sm:px-6 relative z-10 ' + (centered ? 'text-center' : '')}>
    <div class={centered ? 'max-w-3xl mx-auto' : 'max-w-3xl'}>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        {heading}
      </h1>
      {subheading && (
        <p class="text-lg md:text-xl text-teal-100 leading-relaxed mb-8">
          {subheading}
        </p>
      )}
      <slot />
      {(ctaText || ctaSecondaryText) && (
        <div class={'flex flex-wrap gap-4 ' + (centered ? 'justify-center' : '')}>
          {ctaText && (
            <a href={ctaHref} class="btn-primary">{ctaText}</a>
          )}
          {ctaSecondaryText && ctaSecondaryHref && (
            <a href={ctaSecondaryHref} class="btn-secondary">{ctaSecondaryText}</a>
          )}
        </div>
      )}
    </div>
  </div>
</section>
