---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
  badge?: string;
  variant?: 'home' | 'interior' | 'service';
  imageBg?: boolean;
}

const {
  title,
  subtitle,
  description,
  ctaText = 'Schedule Free Consultation',
  ctaHref = '/free-consultation',
  ctaSecondaryText,
  ctaSecondaryHref,
  badge,
  variant = 'home',
  imageBg = false,
} = Astro.props;
---

{variant === 'home' && (
  <section class="relative bg-gradient-to-br from-teal-900 via-teal-700 to-teal-500 text-white overflow-hidden">
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-full h-full" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(255,255,255,.05) 40px, rgba(255,255,255,.05) 80px);"></div>
    </div>
    <!-- Gold accent shape -->
    <div class="absolute top-0 right-0 w-1/3 h-full opacity-10">
      <div class="absolute top-10 right-10 w-96 h-96 bg-gold rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="max-w-3xl">
        {badge && (
          <div class="inline-flex items-center gap-2 bg-teal-600 bg-opacity-60 border border-gold border-opacity-40 rounded-full px-4 py-1.5 text-sm font-medium text-gold mb-6">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            {badge}
          </div>
        )}

        {subtitle && (
          <p class="text-gold font-semibold text-sm uppercase tracking-widest mb-3">{subtitle}</p>
        )}

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-bold leading-tight mb-6">
          {title}
        </h1>

        {description && (
          <p class="text-lg sm:text-xl text-teal-100 leading-relaxed mb-8 max-w-2xl">
            {description}
          </p>
        )}

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={ctaHref} class="btn-primary text-base px-8 py-4 shadow-lg">
            {ctaText}
          </a>
          {ctaSecondaryText && ctaSecondaryHref && (
            <a href={ctaSecondaryHref} class="btn-white text-base px-8 py-4">
              {ctaSecondaryText}
            </a>
          )}
        </div>

        <!-- Trust signals -->
        <div class="mt-10 flex flex-wrap gap-6 text-sm text-teal-200">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Serving MD, VA & DC
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Founded 2013
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Free Consultations
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Proprietary PROMISE Framework
          </div>
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'interior' && (
  <section class="bg-gradient-to-r from-teal-900 to-teal-700 text-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        {badge && (
          <div class="inline-flex items-center gap-2 bg-teal-600 bg-opacity-60 border border-gold border-opacity-40 rounded-full px-4 py-1.5 text-sm font-medium text-gold mb-5">
            {badge}
          </div>
        )}
        {subtitle && (
          <p class="text-gold font-semibold text-xs uppercase tracking-widest mb-3">{subtitle}</p>
        )}
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-bold leading-tight mb-4">
          {title}
        </h1>
        {description && (
          <p class="text-lg text-teal-100 leading-relaxed mb-8">
            {description}
          </p>
        )}
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={ctaHref} class="btn-primary">
            {ctaText}
          </a>
          {ctaSecondaryText && ctaSecondaryHref && (
            <a href={ctaSecondaryHref} class="btn-white">
              {ctaSecondaryText}
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'service' && (
  <section class="bg-gradient-to-br from-teal-800 to-teal-600 text-white py-14 lg:py-18 border-b-4 border-gold">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        {subtitle && (
          <p class="text-gold font-semibold text-xs uppercase tracking-widest mb-3">{subtitle}</p>
        )}
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-bold leading-tight mb-4">
          {title}
        </h1>
        {description && (
          <p class="text-lg text-teal-100 leading-relaxed mb-7">
            {description}
          </p>
        )}
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={ctaHref} class="btn-primary">
            {ctaText}
          </a>
          <a href="tel:+13012898917" class="btn-white">
            Call (301) 289-8917
          </a>
        </div>
      </div>
    </div>
  </section>
)}
