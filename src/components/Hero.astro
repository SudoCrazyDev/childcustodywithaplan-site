---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  badges?: string[];
  variant?: 'full' | 'compact';
}

const {
  title,
  subtitle,
  description,
  primaryCta,
  secondaryCta,
  badges,
  variant = 'full',
} = Astro.props;
---

<section class={`bg-[#0D6E6E] relative overflow-hidden ${variant === 'full' ? 'py-24 md:py-32' : 'py-16 md:py-20'}`}>
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-grid" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)" />
    </svg>
  </div>

  <!-- Gold accent bar -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[#D4A843] via-[#DFB85C] to-[#D4A843]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    {subtitle && (
      <p class="inline-block text-[#D4A843] font-semibold text-sm uppercase tracking-widest mb-4 bg-white/10 px-4 py-1.5 rounded-full">
        {subtitle}
      </p>
    )}

    <h1 class={`font-serif font-bold text-white leading-tight mb-6 ${variant === 'full' ? 'text-4xl md:text-5xl lg:text-6xl' : 'text-3xl md:text-4xl'}`}>
      {title}
    </h1>

    {description && (
      <p class={`text-white/80 mx-auto leading-relaxed mb-8 ${variant === 'full' ? 'text-lg md:text-xl max-w-3xl' : 'text-base max-w-2xl'}`}>
        {description}
      </p>
    )}

    {badges && badges.length > 0 && (
      <div class="flex flex-wrap justify-center gap-3 mb-10">
        {badges.map(badge => (
          <span class="bg-white/10 border border-white/20 text-white/90 text-sm px-4 py-2 rounded-full font-medium">
            {badge}
          </span>
        ))}
      </div>
    )}

    {(primaryCta || secondaryCta) && (
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        {primaryCta && (
          <a href={primaryCta.href} class="bg-[#D4A843] text-white font-semibold px-8 py-4 rounded hover:bg-[#B8902E] transition-colors duration-200 text-lg">
            {primaryCta.label}
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="border-2 border-white text-white font-semibold px-8 py-4 rounded hover:bg-white hover:text-[#0D6E6E] transition-colors duration-200 text-lg">
            {secondaryCta.label}
          </a>
        )}
      </div>
    )}
  </div>
</section>
