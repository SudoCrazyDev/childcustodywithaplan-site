---
const services = [
  { label: 'Divorce', href: '/divorce' },
  { label: 'Asset Division', href: '/asset-division' },
  { label: 'Divorces Involving Businesses', href: '/divorces-involving-businesses' },
  { label: 'Divorce for Professionals', href: '/divorce-lawyer-for-professionals' },
  { label: 'High Net Worth Divorce', href: '/high-net-worth-divorce' },
  { label: 'Spousal Support', href: '/spousal-support' },
  { label: 'Child Custody', href: '/child-custody' },
  { label: 'Child Custody Modification', href: '/child-custody-modification' },
];

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'About Us', href: '/about' },
  { label: 'Our Attorneys', href: '/attorneys' },
  { label: 'Practice Areas', href: '/services' },
  { label: 'Resources & Blog', href: '/blog' },
  { label: 'Contact Us', href: '/contact' },
  { label: 'Free Consultation', href: '/free-consultation' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-teal-800 text-white">
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-12 h-12 bg-gold-400 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg viewBox="0 0 40 40" class="w-8 h-8" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="14" r="6" fill="white"/>
              <path d="M8 34c0-6.627 5.373-12 12-12s12 5.373 12 12" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <div class="font-serif font-bold text-white text-lg leading-tight">Child Custody</div>
            <div class="font-serif font-bold text-gold-400 text-lg leading-tight">with a Plan</div>
          </div>
        </div>
        <p class="text-teal-200 text-sm leading-relaxed mb-5 italic">
          "Where Child Custody Meets Strategy"
        </p>
        <p class="text-teal-200 text-sm leading-relaxed mb-6">
          A women-led Maryland family law firm dedicated to protecting your parental rights and crafting strategic, child-centered custody plans.
        </p>
        <div class="flex items-center gap-2 text-gold-400 font-semibold text-sm mb-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          2025 Elite Lawyer Award
        </div>
        <p class="text-teal-300 text-xs">Josephia Rouse, Founding Attorney</p>
      </div>

      <!-- Practice Areas -->
      <div>
        <h3 class="font-serif font-bold text-white text-lg mb-5 pb-2 border-b border-teal-600">Practice Areas</h3>
        <ul class="space-y-2">
          {services.map((s) => (
            <li>
              <a href={s.href} class="text-teal-200 hover:text-gold-400 transition-colors text-sm flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-gold-400 rounded-full flex-shrink-0"></span>
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-serif font-bold text-white text-lg mb-5 pb-2 border-b border-teal-600">Quick Links</h3>
        <ul class="space-y-2 mb-6">
          {quickLinks.map((l) => (
            <li>
              <a href={l.href} class="text-teal-200 hover:text-gold-400 transition-colors text-sm flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-gold-400 rounded-full flex-shrink-0"></span>
                {l.label}
              </a>
            </li>
          ))}
        </ul>
        <a href="/free-consultation" class="inline-block bg-gold-400 hover:bg-gold-500 text-white font-semibold px-5 py-2.5 rounded-lg text-sm transition-colors w-full text-center">
          Schedule Free Consultation
        </a>
      </div>

      <!-- Contact & Offices -->
      <div>
        <h3 class="font-serif font-bold text-white text-lg mb-5 pb-2 border-b border-teal-600">Our Offices</h3>

        <!-- Rockville -->
        <div class="mb-5">
          <div class="flex items-center gap-2 text-gold-400 font-semibold text-sm mb-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Rockville Office
          </div>
          <p class="text-teal-200 text-sm">100 Park Ave Suite 205</p>
          <p class="text-teal-200 text-sm">Rockville, MD 20850</p>
        </div>

        <!-- Baltimore -->
        <div class="mb-5">
          <div class="flex items-center gap-2 text-gold-400 font-semibold text-sm mb-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Baltimore Office
          </div>
          <p class="text-teal-200 text-sm">1537 Light St #100</p>
          <p class="text-teal-200 text-sm">Baltimore, MD 21230</p>
        </div>

        <!-- Phone & Hours -->
        <div class="space-y-2">
          <a href="tel:3012898917" class="flex items-center gap-2 text-teal-200 hover:text-gold-400 transition-colors text-sm">
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            (301) 289-8917
          </a>
          <div class="flex items-center gap-2 text-teal-200 text-sm">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Mon–Fri: 9AM–9PM
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-teal-700">
    <div class="max-w-7xl mx-auto px-4 py-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-teal-300">
      <p>© {currentYear} Child Custody with a Plan. All rights reserved. Sister site to <a href="https://divorcewithaplan.com" target="_blank" rel="noopener" class="text-gold-400 hover:underline">Divorce with a Plan</a>.</p>
      <p class="text-center sm:text-right">
        <strong class="text-teal-200">Disclaimer:</strong> This website is for informational purposes only and does not constitute legal advice. Consult an attorney for advice specific to your situation.
      </p>
    </div>
  </div>
</footer>
