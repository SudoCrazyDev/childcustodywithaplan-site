---
const practiceAreas = [
  { label: 'Divorce', href: '/divorce' },
  { label: 'Asset Division', href: '/asset-division' },
  { label: 'Divorces Involving Businesses', href: '/divorces-involving-businesses' },
  { label: 'Divorce for Professionals', href: '/divorce-lawyer-for-professionals' },
  { label: 'High Net Worth Divorce', href: '/high-net-worth-divorce' },
  { label: 'Spousal Support', href: '/spousal-support' },
  { label: 'Child Custody', href: '/child-custody' },
  { label: 'Child Custody Modification', href: '/child-custody-modification' },
];

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'About Us', href: '/about' },
  { label: 'Our Attorneys', href: '/attorneys' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
  { label: 'Free Consultation', href: '/free-consultation' },
];
---

<footer class="bg-charcoal text-gray-300">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-teal rounded-lg flex items-center justify-center">
            <span class="text-gold font-serif font-bold text-xl">C</span>
          </div>
          <div class="leading-tight">
            <div class="text-white font-serif font-bold text-lg leading-none">Child Custody</div>
            <div class="text-gold font-semibold text-sm leading-none">with a Plan</div>
          </div>
        </a>
        <p class="text-sm text-gray-400 mb-5 leading-relaxed italic">
          "Where Child Custody Meets Strategy"
        </p>
        <p class="text-sm text-gray-400 leading-relaxed">
          Maryland's trusted family law firm serving Rockville, Baltimore, and surrounding communities since 2013.
        </p>
        <div class="mt-6">
          <a href="/free-consultation" class="btn-primary text-sm">
            Free Consultation
          </a>
        </div>
      </div>

      <!-- Practice areas -->
      <div>
        <h3 class="text-white font-semibold text-base mb-5 uppercase tracking-wide">Practice Areas</h3>
        <ul class="space-y-2">
          {practiceAreas.map((area) => (
            <li>
              <a href={area.href} class="text-sm text-gray-400 hover:text-gold transition-colors flex items-center gap-2">
                <svg class="w-3 h-3 text-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                </svg>
                {area.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-base mb-5 uppercase tracking-wide">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-gold transition-colors flex items-center gap-2">
                <svg class="w-3 h-3 text-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact / Offices -->
      <div>
        <h3 class="text-white font-semibold text-base mb-5 uppercase tracking-wide">Our Offices</h3>

        <div class="mb-5">
          <div class="text-gold text-xs font-semibold uppercase tracking-wider mb-2">Rockville Office</div>
          <address class="not-italic text-sm text-gray-400 leading-relaxed">
            100 Park Ave, Suite 205<br/>
            Rockville, MD 20850
          </address>
        </div>

        <div class="mb-5">
          <div class="text-gold text-xs font-semibold uppercase tracking-wider mb-2">Baltimore Office</div>
          <address class="not-italic text-sm text-gray-400 leading-relaxed">
            1537 Light St, #100<br/>
            Baltimore, MD 21230
          </address>
        </div>

        <div class="space-y-2">
          <a href="tel:+13012898917" class="flex items-center gap-2 text-sm text-gray-400 hover:text-gold transition-colors">
            <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            (301) 289-8917
          </a>
          <div class="flex items-center gap-2 text-sm text-gray-400">
            <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
            Mon–Fri: 9AM–9PM
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Disclaimer -->
  <div class="border-t border-gray-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-xs text-gray-500 text-center leading-relaxed mb-3">
        <strong class="text-gray-400">Attorney Advertising Disclaimer:</strong> The information on this website is for general informational purposes only and does not constitute legal advice. Viewing this site or contacting Child Custody with a Plan does not create an attorney-client relationship. Past results do not guarantee future outcomes. If you have a legal matter, please consult a qualified attorney.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-gray-500">
        <p>© {new Date().getFullYear()} Child Custody with a Plan. All rights reserved. Founded 2013.</p>
        <div class="flex gap-4">
          <a href="/sitemap.xml" class="hover:text-gray-300 transition-colors">Sitemap</a>
          <span>Maryland Family Law Attorneys</span>
        </div>
      </div>
    </div>
  </div>
</footer>
