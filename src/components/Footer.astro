---
const currentYear = new Date().getFullYear();

const practiceAreas = [
  { href: '/services', label: 'Child Custody' },
  { href: '/services', label: 'Divorce' },
  { href: '/services', label: 'High-Asset Divorce' },
  { href: '/services', label: 'Spousal Support' },
  { href: '/services', label: 'Asset Division' },
  { href: '/services', label: 'Custody Modification' },
];

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About Our Firm' },
  { href: '/attorneys', label: 'Our Attorneys' },
  { href: '/services', label: 'Practice Areas' },
  { href: '/process', label: 'Our Process' },
  { href: '/contact', label: 'Contact Us' },
];

const counties = [
  'Montgomery County', 'Howard County', 'Baltimore City',
  'Prince George\'s County', 'Anne Arundel County', 'Frederick County',
];
---

<footer class="bg-[#063d3d] text-white">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-[#D4A843] rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-white font-bold font-serif text-xl">C</span>
          </div>
          <div class="leading-tight">
            <span class="block text-white font-bold font-serif text-lg leading-none">Child Custody</span>
            <span class="block text-[#D4A843] text-sm font-medium">with a Plan</span>
          </div>
        </div>
        <p class="text-white/70 text-sm leading-relaxed mb-5">
          Maryland's trusted family law firm dedicated to protecting your children's best interests and your parental rights — with strategy, compassion, and a clear plan.
        </p>
        <div class="space-y-2 text-sm text-white/80">
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-[#D4A843] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>100 Park Ave, Suite 205<br/>Rockville, MD 20850</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#D4A843] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:2402693592" class="hover:text-[#D4A843] transition-colors">(240) 269-3592</a>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#D4A843] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:info@josephialaw.com" class="hover:text-[#D4A843] transition-colors">info@josephialaw.com</a>
          </div>
        </div>
      </div>

      <!-- Practice Areas -->
      <div>
        <h3 class="text-[#D4A843] font-bold text-sm uppercase tracking-widest mb-5">Practice Areas</h3>
        <ul class="space-y-2">
          {practiceAreas.map(link => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white text-sm transition-colors flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-[#D4A843] flex-shrink-0"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-[#D4A843] font-bold text-sm uppercase tracking-widest mb-5">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white text-sm transition-colors flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-[#D4A843] flex-shrink-0"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Service Area & CTA -->
      <div>
        <h3 class="text-[#D4A843] font-bold text-sm uppercase tracking-widest mb-5">Areas We Serve</h3>
        <ul class="space-y-2 mb-6">
          {counties.map(county => (
            <li class="text-white/70 text-sm flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-[#D4A843] flex-shrink-0"></span>
              {county}
            </li>
          ))}
        </ul>
        <a
          href="/contact"
          class="block w-full bg-[#D4A843] text-white text-center font-semibold py-3 rounded hover:bg-[#B8902E] transition-colors text-sm"
        >
          Schedule Free Consultation
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/50">
      <p>&copy; {currentYear} Child Custody with a Plan. All rights reserved. A Maryland Family Law Firm. Established 2013.</p>
      <div class="flex gap-4">
        <a href="/contact" class="hover:text-white/80 transition-colors">Privacy Policy</a>
        <a href="/contact" class="hover:text-white/80 transition-colors">Disclaimer</a>
      </div>
    </div>
  </div>
</footer>
