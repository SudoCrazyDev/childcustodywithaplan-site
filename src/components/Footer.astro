---
const services = [
  { label: 'Divorce', href: '/divorce' },
  { label: 'Asset Division', href: '/asset-division' },
  { label: 'Divorces Involving Businesses', href: '/divorces-involving-businesses' },
  { label: 'Divorce Lawyer for Professionals', href: '/divorce-lawyer-for-professionals' },
  { label: 'High Net Worth Divorce', href: '/high-net-worth-divorce' },
  { label: 'Spousal Support', href: '/spousal-support' },
  { label: 'Child Custody', href: '/child-custody' },
  { label: 'Child Custody Modification', href: '/child-custody-modification' },
];

const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
    <!-- Brand -->
    <div class="lg:col-span-1">
      <a href="/" class="flex flex-col leading-tight mb-4">
        <span class="font-serif text-xl font-bold text-white">Child Custody</span>
        <span class="font-serif text-xl font-bold text-gold">with a Plan</span>
      </a>
      <p class="text-sm text-gray-400 mb-5 leading-relaxed">
        Where Child Custody Meets Strategy. Maryland family law attorneys dedicated to protecting your family and securing your future.
      </p>
      <p class="text-xs text-gray-500">Founded 2013 &nbsp;|&nbsp; Serving All of Maryland</p>
    </div>

    <!-- Services -->
    <div>
      <h3 class="font-semibold text-white mb-4 uppercase tracking-wider text-xs">Our Services</h3>
      <ul class="space-y-2">
        {services.map((s) => (
          <li>
            <a href={s.href} class="text-sm text-gray-400 hover:text-gold transition-colors">
              {s.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Quick Links -->
    <div>
      <h3 class="font-semibold text-white mb-4 uppercase tracking-wider text-xs">Quick Links</h3>
      <ul class="space-y-2">
        <li><a href="/about" class="text-sm text-gray-400 hover:text-gold transition-colors">About the Firm</a></li>
        <li><a href="/attorneys" class="text-sm text-gray-400 hover:text-gold transition-colors">Our Attorneys</a></li>
        <li><a href="/services" class="text-sm text-gray-400 hover:text-gold transition-colors">All Services</a></li>
        <li><a href="/blog" class="text-sm text-gray-400 hover:text-gold transition-colors">Blog &amp; Resources</a></li>
        <li><a href="/contact" class="text-sm text-gray-400 hover:text-gold transition-colors">Contact Us</a></li>
        <li><a href="/free-consultation" class="text-sm text-gold hover:text-gold-300 font-semibold transition-colors">Free Consultation</a></li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="font-semibold text-white mb-4 uppercase tracking-wider text-xs">Contact Us</h3>
      <div class="space-y-4 text-sm">
        <div>
          <p class="text-gold font-semibold mb-1">Phone</p>
          <a href="tel:+12403267712" class="text-gray-400 hover:text-white transition-colors">(240) 326-7712</a>
        </div>
        <div>
          <p class="text-gold font-semibold mb-1">Rockville Office</p>
          <address class="not-italic text-gray-400 leading-relaxed">
            100 Park Ave Suite 205<br />
            Rockville, MD 20850
          </address>
        </div>
        <div>
          <p class="text-gold font-semibold mb-1">Baltimore Office</p>
          <address class="not-italic text-gray-400 leading-relaxed">
            1537 Light St #100<br />
            Baltimore, MD 21230
          </address>
        </div>
        <div>
          <p class="text-gold font-semibold mb-1">Hours</p>
          <p class="text-gray-400">Mon – Fri: 9AM – 9PM</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Disclaimer -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
      <p class="text-xs text-gray-500 leading-relaxed mb-4">
        <strong class="text-gray-400">Attorney Advertising Disclaimer:</strong> The information on this website is for general informational purposes only and does not constitute legal advice. No attorney-client relationship is formed by viewing or using this website. Past results do not guarantee similar outcomes. Child Custody with a Plan is licensed to practice law in Maryland, Virginia, and Washington D.C.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
        <p>&copy; {year} Child Custody with a Plan. All rights reserved.</p>
        <div class="flex gap-4">
          <a href="/contact" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
          <a href="/contact" class="hover:text-gray-300 transition-colors">Terms of Use</a>
          <a href="/sitemap.xml" class="hover:text-gray-300 transition-colors">Sitemap</a>
        </div>
      </div>
    </div>
  </div>
</footer>
