---
export interface Props {
  heading?: string;
  subheading?: string;
  ctaText?: string;
  ctaHref?: string;
  variant?: 'teal' | 'gold' | 'dark';
}

const {
  heading = 'Ready to Protect What Matters Most?',
  subheading = 'Our Maryland child custody and family law attorneys are ready to build your strategy. Schedule your free consultation today.',
  ctaText = 'Get Your Free Consultation',
  ctaHref = '/free-consultation',
  variant = 'teal',
} = Astro.props;

const variantClasses = {
  teal: 'bg-teal',
  gold: 'bg-gold',
  dark: 'bg-gray-900',
};
---

<section class={variantClasses[variant] + ' py-16 md:py-20'}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">{heading}</h2>
    <p class="text-lg text-white/80 mb-8 leading-relaxed">{subheading}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={ctaHref} class="inline-block bg-white text-teal font-semibold px-10 py-3.5 rounded-sm hover:bg-gray-100 transition-colors uppercase tracking-wide text-sm">
        {ctaText}
      </a>
      <a href="tel:3012898917" class="inline-block border-2 border-white text-white font-semibold px-10 py-3.5 rounded-sm hover:bg-white hover:text-teal transition-colors uppercase tracking-wide text-sm">
        Call (301) 289-8917
      </a>
    </div>
    <p class="mt-6 text-white/60 text-sm">Mon–Fri 9AM–9PM &nbsp;|&nbsp; Rockville &amp; Baltimore offices</p>
  </div>
</section>
