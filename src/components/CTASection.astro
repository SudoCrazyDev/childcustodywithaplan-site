---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  variant?: 'teal' | 'gold' | 'dark';
}

const {
  title = 'Ready to Protect What Matters Most?',
  description = 'Schedule your free consultation today. Our attorneys are ready to listen, strategize, and guide you through every step of your custody or divorce case.',
  ctaText = 'Schedule Free Consultation',
  ctaHref = '/free-consultation',
  variant = 'teal',
} = Astro.props;

const bgClass = {
  teal: 'bg-teal text-white',
  gold: 'bg-gold text-white',
  dark: 'bg-charcoal text-white',
}[variant];

const btnClass = {
  teal: 'bg-white text-teal hover:bg-offwhite font-semibold px-8 py-4 rounded-lg shadow transition-all',
  gold: 'bg-white text-gold hover:bg-offwhite font-semibold px-8 py-4 rounded-lg shadow transition-all',
  dark: 'bg-gold text-white hover:bg-gold-500 font-semibold px-8 py-4 rounded-lg shadow transition-all',
}[variant];
---

<section class={`${bgClass} py-16`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-serif font-bold mb-4">{title}</h2>
    <p class="text-lg opacity-90 mb-8 max-w-2xl mx-auto leading-relaxed">{description}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={ctaHref} class={btnClass}>{ctaText}</a>
      <a href="tel:+13012898917" class="flex items-center gap-2 text-lg font-semibold opacity-90 hover:opacity-100 transition-opacity">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
        </svg>
        (301) 289-8917
      </a>
    </div>
    <p class="text-sm opacity-75 mt-5">
      Available Mon–Fri, 9AM–9PM &nbsp;·&nbsp; Rockville &amp; Baltimore Offices
    </p>
  </div>
</section>
