---
export interface Props {
  headline?: string;
  subheadline?: string;
  ctaText?: string;
  ctaHref?: string;
  variant?: 'teal' | 'gold' | 'light';
}

const {
  headline = 'Ready to Protect Your Parental Rights?',
  subheadline = 'Schedule your free consultation today. Our women-led team is here to build a strategic plan for your child custody case.',
  ctaText = 'Schedule Free Consultation',
  ctaHref = '/free-consultation',
  variant = 'teal',
} = Astro.props;
---

<section class={`py-16 md:py-20 ${variant === 'teal' ? 'teal-gradient' : variant === 'gold' ? 'bg-gold-400' : 'bg-teal-50'}`}>
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class={`font-serif font-bold text-3xl md:text-4xl mb-4 ${variant === 'light' ? 'text-teal-700' : 'text-white'}`}>
      {headline}
    </h2>
    <p class={`text-lg mb-8 leading-relaxed ${variant === 'light' ? 'text-gray-600' : 'text-teal-100'}`}>
      {subheadline}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={ctaHref} class={`font-semibold px-8 py-4 rounded-lg transition-all duration-200 shadow-md hover:shadow-lg text-center text-base ${variant === 'light' ? 'bg-teal-500 hover:bg-teal-600 text-white' : 'bg-gold-400 hover:bg-gold-500 text-white'}`}>
        {ctaText}
      </a>
      <a href="tel:3012898917" class={`font-semibold px-8 py-4 rounded-lg transition-all duration-200 border-2 text-center text-base ${variant === 'light' ? 'border-teal-500 text-teal-500 hover:bg-teal-500 hover:text-white' : 'border-white text-white hover:bg-white hover:text-teal-600'}`}>
        (301) 289-8917
      </a>
    </div>
    <p class={`mt-6 text-sm ${variant === 'light' ? 'text-gray-500' : 'text-teal-200'}`}>
      Free consultations available · Mon–Fri 9AM–9PM · Rockville &amp; Baltimore offices
    </p>
  </div>
</section>
