---
const testimonials = [
  {
    quote: "Child Custody with a Plan gave me the strategy I needed to secure primary custody of my children. They didn't just know the law — they knew how to present my case in a way that resonated with the court. I'm forever grateful.",
    author: "Marcus T.",
    location: "Rockville, MD",
    result: "Primary Custody Secured",
    stars: 5,
  },
  {
    quote: "As a father, I was terrified the system would be stacked against me. This team fought hard to ensure I got equal parenting time. They were strategic, empathetic, and always kept me informed throughout the entire process.",
    author: "David K.",
    location: "Baltimore, MD",
    result: "Equal Parenting Time",
    stars: 5,
  },
  {
    quote: "When my ex tried to relocate our kids out of state, I needed help fast. The attorneys at Child Custody with a Plan immediately went to work and stopped the move. They literally changed my children's lives.",
    author: "Renée M.",
    location: "Silver Spring, MD",
    result: "Relocation Blocked",
    stars: 5,
  },
  {
    quote: "I needed to modify my custody order after my ex's living situation became unsafe for my daughter. The team walked me through every step, filed quickly, and we got the modification approved. Professional and compassionate.",
    author: "Theresa W.",
    location: "Bethesda, MD",
    result: "Modification Approved",
    stars: 5,
  },
  {
    quote: "The emergency custody order process was terrifying, but my attorney was calm, clear, and effective. We had a protective order in place within days. I can't thank Child Custody with a Plan enough.",
    author: "Alexis P.",
    location: "Gaithersburg, MD",
    result: "Emergency Order Granted",
    stars: 5,
  },
  {
    quote: "Josephia and her team truly listen. They understood my situation, crafted a thoughtful parenting plan, and negotiated a fair agreement without unnecessary conflict. My kids are thriving because of their help.",
    author: "James H.",
    location: "Columbia, MD",
    result: "Parenting Plan Agreed",
    stars: 5,
  },
];
---

<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-14">
      <div class="gold-bar mx-auto"></div>
      <h2 class="section-heading">Families We've Helped</h2>
      <p class="section-subheading">Real results. Real families. Hear from clients who trusted us with what matters most.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white rounded-xl shadow-md p-6 border border-gray-100 flex flex-col hover:shadow-xl transition-shadow duration-300">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array(t.stars).fill(null).map(() => (
              <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-gray-700 text-sm leading-relaxed flex-grow italic mb-5">
            "{t.quote}"
          </blockquote>

          <!-- Result Badge -->
          <div class="mb-4">
            <span class="inline-flex items-center gap-1.5 bg-teal-100 text-teal-700 px-3 py-1 rounded-full text-xs font-semibold">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              {t.result}
            </span>
          </div>

          <!-- Author -->
          <div class="flex items-center gap-3 border-t border-gray-100 pt-4">
            <div class="w-10 h-10 bg-teal-600 rounded-full flex items-center justify-center text-white font-bold text-sm">
              {t.author.charAt(0)}
            </div>
            <div>
              <p class="font-semibold text-gray-800 text-sm">{t.author}</p>
              <p class="text-gray-500 text-xs">{t.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <p class="text-gray-500 text-sm">*Client reviews reflect individual experiences. Results may vary.</p>
    </div>
  </div>
</section>
