---
export interface Props {
  heading?: string;
  subtext?: string;
  variant?: 'dark' | 'light' | 'gold';
}

const {
  heading = "Ready to Protect What Matters Most?",
  subtext = "Every custody case is unique. Get a free, confidential consultation with one of our experienced Maryland child custody attorneys and learn how we can build a winning strategy for you.",
  variant = 'dark',
} = Astro.props;

const bgClass = variant === 'dark'
  ? 'bg-teal-900'
  : variant === 'gold'
  ? 'bg-gradient-to-r from-gold-500 to-gold-400'
  : 'bg-teal-50';

const headingClass = variant === 'light' ? 'text-teal-800' : 'text-white';
const textClass = variant === 'light' ? 'text-teal-600' : variant === 'gold' ? 'text-yellow-50' : 'text-teal-200';
---

<section class={`${bgClass} py-16 md:py-20`}>
  <div class="max-w-4xl mx-auto px-4 text-center">
    <div class="flex justify-center mb-4">
      <svg class="w-12 h-12 text-gold-400 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
      </svg>
    </div>
    <h2 class={`font-serif text-3xl md:text-4xl font-bold mb-5 ${headingClass}`}>{heading}</h2>
    <p class={`text-lg mb-8 leading-relaxed ${textClass}`}>{subtext}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/free-consultation" class="inline-flex items-center gap-2 bg-gold-400 hover:bg-gold-500 text-white font-bold px-8 py-4 rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
        Schedule Free Consultation
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </a>
      <a href="tel:3012898917" class="inline-flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-teal-800 font-bold px-8 py-4 rounded-lg transition-all duration-200">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
        (301) 289-8917
      </a>
    </div>
    <p class={`mt-5 text-sm ${textClass} opacity-80`}>
      Available Mon–Fri, 9AM–9PM · Serving Rockville, Baltimore & all of Maryland
    </p>
  </div>
</section>
