---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  schema?: object;
}

const {
  title,
  description,
  canonicalURL = Astro.url.href,
  ogImage = '/og-default.png',
  ogType = 'website',
  noindex = false,
  schema,
} = Astro.props;

const siteURL = 'https://childcustodywithaplan.com';
const fullTitle = title.includes('Child Custody with a Plan')
  ? title
  : `${title} | Child Custody with a Plan`;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary Meta -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={`${siteURL}${ogImage}`} />
  <meta property="og:site_name" content="Child Custody with a Plan" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteURL}${ogImage}`} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Preconnect for fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Local Business Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LegalService",
    "name": "Child Custody with a Plan",
    "alternateName": "Child Custody with a Plan",
    "description": "Maryland family law firm specializing in child custody, divorce, and related family matters. Where Child Custody Meets Strategy.",
    "url": siteURL,
    "telephone": "+13012898917",
    "foundingDate": "2013",
    "areaServed": [
      { "@type": "State", "name": "Maryland" },
      { "@type": "State", "name": "Virginia" },
      { "@type": "State", "name": "Washington D.C." }
    ],
    "address": [
      {
        "@type": "PostalAddress",
        "streetAddress": "100 Park Ave, Suite 205",
        "addressLocality": "Rockville",
        "addressRegion": "MD",
        "postalCode": "20850",
        "addressCountry": "US"
      },
      {
        "@type": "PostalAddress",
        "streetAddress": "1537 Light St, #100",
        "addressLocality": "Baltimore",
        "addressRegion": "MD",
        "postalCode": "21230",
        "addressCountry": "US"
      }
    ],
    "openingHours": "Mo-Fr 09:00-21:00",
    "priceRange": "$$",
    "serviceType": [
      "Child Custody",
      "Divorce",
      "Spousal Support",
      "Asset Division",
      "High Net Worth Divorce",
      "Child Custody Modification"
    ]
  })} />

  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body class="flex flex-col min-h-screen">
  <Header />
  <main class="flex-grow">
    <slot />
  </main>
  <Footer />
</body>
</html>
