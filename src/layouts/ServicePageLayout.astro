---
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';

interface Props {
  title: string;
  metaTitle?: string;
  description: string;
  heroSubtitle?: string;
  heroDescription?: string;
  badge?: string;
}

const {
  title,
  metaTitle,
  description,
  heroSubtitle = 'Maryland Family Law',
  heroDescription,
  badge,
} = Astro.props;

const relatedServices = [
  { label: 'Divorce', href: '/divorce' },
  { label: 'Asset Division', href: '/asset-division' },
  { label: 'Divorces Involving Businesses', href: '/divorces-involving-businesses' },
  { label: 'Divorce for Professionals', href: '/divorce-lawyer-for-professionals' },
  { label: 'High Net Worth Divorce', href: '/high-net-worth-divorce' },
  { label: 'Spousal Support', href: '/spousal-support' },
  { label: 'Child Custody', href: '/child-custody' },
  { label: 'Child Custody Modification', href: '/child-custody-modification' },
];
---

<BaseLayout title={metaTitle || title} description={description}>
  <Hero
    variant="service"
    title={title}
    subtitle={heroSubtitle}
    description={heroDescription || description}
    badge={badge}
  />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <!-- Main content -->
      <div class="lg:col-span-2 prose-content">
        <slot />
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- Contact card -->
        <div class="bg-teal rounded-2xl p-6 text-white shadow-card">
          <h3 class="text-xl font-serif font-bold mb-2">Speak With an Attorney</h3>
          <p class="text-teal-100 text-sm mb-5 leading-relaxed">
            Ready to discuss your case? Schedule a free, confidential consultation with one of our experienced attorneys.
          </p>
          <a href="/free-consultation" class="block text-center bg-gold text-white font-semibold py-3 rounded-lg hover:bg-gold-500 transition-colors mb-3">
            Free Consultation
          </a>
          <a href="tel:+13012898917" class="flex items-center justify-center gap-2 text-teal-100 hover:text-white transition-colors text-sm font-medium">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            (301) 289-8917
          </a>
          <p class="text-xs text-teal-200 text-center mt-3">Mon–Fri, 9AM–9PM</p>
        </div>

        <!-- Related services -->
        <div class="bg-white rounded-2xl p-6 shadow-card">
          <h3 class="text-lg font-serif font-bold text-teal mb-4">Practice Areas</h3>
          <ul class="space-y-2">
            {relatedServices.map((s) => (
              <li>
                <a
                  href={s.href}
                  class={`flex items-center gap-2 text-sm py-1.5 rounded transition-colors ${Astro.url.pathname === s.href ? 'text-teal font-semibold' : 'text-gray-600 hover:text-teal'}`}
                >
                  <svg class="w-3 h-3 text-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- PROMISE Framework teaser -->
        <div class="bg-gold-50 border border-gold-200 rounded-2xl p-6">
          <div class="text-gold font-bold text-xs uppercase tracking-widest mb-2">Proprietary Process</div>
          <h3 class="text-lg font-serif font-bold text-charcoal mb-2">The PROMISE Framework™</h3>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">
            Our exclusive PROMISE methodology gives every client a clear, strategic roadmap — turning complexity into clarity.
          </p>
          <a href="/about#promise" class="text-teal text-sm font-semibold hover:text-teal-600 transition-colors flex items-center gap-1">
            Learn More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Offices -->
        <div class="bg-white rounded-2xl p-6 shadow-card">
          <h3 class="text-lg font-serif font-bold text-teal mb-4">Our Offices</h3>
          <div class="space-y-4 text-sm text-gray-600">
            <div>
              <div class="font-semibold text-charcoal mb-1">Rockville</div>
              <div>100 Park Ave, Suite 205<br/>Rockville, MD 20850</div>
            </div>
            <div class="border-t pt-4">
              <div class="font-semibold text-charcoal mb-1">Baltimore</div>
              <div>1537 Light St, #100<br/>Baltimore, MD 21230</div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <CTASection />
</BaseLayout>

<style is:global>
  .prose-content h2 {
    @apply text-2xl font-serif font-bold text-teal mt-10 mb-4;
  }
  .prose-content h3 {
    @apply text-xl font-serif font-semibold text-charcoal mt-8 mb-3;
  }
  .prose-content p {
    @apply text-gray-700 leading-relaxed mb-4;
  }
  .prose-content ul {
    @apply space-y-2 mb-6;
  }
  .prose-content ul li {
    @apply flex items-start gap-2 text-gray-700;
  }
  .prose-content ul li::before {
    content: '';
    @apply w-2 h-2 bg-gold rounded-full shrink-0 mt-2;
  }
  .prose-content ol {
    @apply list-decimal list-inside space-y-2 mb-6 text-gray-700;
  }
  .prose-content strong {
    @apply text-charcoal font-semibold;
  }
  .prose-content .highlight-box {
    @apply bg-teal-50 border-l-4 border-teal rounded-r-lg p-5 my-6;
  }
  .prose-content .gold-box {
    @apply bg-amber-50 border-l-4 border-gold rounded-r-lg p-5 my-6;
  }
</style>
